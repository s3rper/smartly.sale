---
import MainLayout from '../layouts/main.astro';

const pageTitle = "Terms of Service - smartly.sale Philippines | Legal Terms & Conditions";
const pageDescription = "Read the terms of service for smartly.sale. Understand the legal terms, conditions, and guidelines for using our Shopee deals and product review website.";
---

<MainLayout 
  title={pageTitle}
  description={pageDescription}
  ogImage="/og-image.jpg"
>
  <!-- SEO Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Terms of Service",
    "description": pageDescription,
    "url": "https://smartly.sale/terms",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://smartly.sale"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Terms of Service",
          "item": "https://smartly.sale/terms"
        }
      ]
    }
  })} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    
    <h1 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
      Terms of Service
    </h1>
    
    <p class="text-muted-foreground mb-8">
      <strong>Effective Date:</strong> January 15, 2025<br>
      <strong>Last Updated:</strong> {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
    </p>

    <div class="prose prose-lg max-w-none space-y-6">
      
      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">1. Acceptance of Terms</h2>
        <p class="text-muted-foreground leading-relaxed">
          Welcome to smartly.sale ("Website," "we," "our," or "us"). By accessing or using our website, you agree to be bound 
          by these Terms of Service ("Terms"). If you do not agree to these Terms, please do not use our website.
        </p>
        <p class="text-muted-foreground leading-relaxed mt-3">
          We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting. Your 
          continued use of the website after changes constitutes acceptance of the modified Terms.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">2. Description of Service</h2>
        <p class="text-muted-foreground leading-relaxed">
          smartly.sale is a product discovery and affiliate marketing website that:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Curates and features products from Shopee Philippines</li>
          <li>Provides product reviews, recommendations, and deals</li>
          <li>Shares information about earning money online</li>
          <li>Offers affiliate links to third-party e-commerce platforms</li>
        </ul>
        <p class="text-muted-foreground leading-relaxed mt-3">
          We are not an online store and do not sell products directly. We are an informational and referral service.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">3. Affiliate Marketing Disclosure</h2>
        <p class="text-muted-foreground leading-relaxed">
          <strong>Important Notice:</strong> smartly.sale participates in affiliate marketing programs, including the Shopee 
          Affiliate Program. When you click on our affiliate links and make a purchase, we may earn a commission at no additional 
          cost to you.
        </p>
        <p class="text-muted-foreground leading-relaxed mt-3">
          Our affiliate relationships do not influence our editorial content or product recommendations. We only recommend products 
          we believe will provide value to our users.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">4. User Responsibilities</h2>
        
        <h3 class="text-xl font-bold text-foreground mb-3">4.1 Lawful Use</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">
          You agree to use our website only for lawful purposes. You must not:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li>Violate any local, national, or international laws</li>
          <li>Infringe on intellectual property rights</li>
          <li>Transmit harmful code (viruses, malware, etc.)</li>
          <li>Attempt to gain unauthorized access to our systems</li>
          <li>Engage in any form of harassment or abuse</li>
          <li>Scrape or copy content without permission</li>
        </ul>

        <h3 class="text-xl font-bold text-foreground mb-3 mt-6">4.2 Accuracy of Information</h3>
        <p class="text-muted-foreground leading-relaxed">
          If you provide information through our contact forms or newsletter signup, you agree to provide accurate, current, 
          and complete information.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">5. Third-Party Links and Services</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our website contains links to third-party websites and services (primarily Shopee Philippines). We are not responsible 
          for the content, privacy practices, or terms of service of these third-party sites.
        </p>
        <p class="text-muted-foreground leading-relaxed mt-3">
          When you click on an affiliate link and make a purchase:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>You are entering into a transaction with the merchant (e.g., Shopee), not with smartly.sale</li>
          <li>The merchant's terms and conditions apply to your purchase</li>
          <li>We are not responsible for product quality, shipping, refunds, or customer service</li>
          <li>Any disputes should be resolved directly with the merchant</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">6. Disclaimer of Warranties</h2>
        <p class="text-muted-foreground leading-relaxed">
          <strong>Our website is provided "AS IS" and "AS AVAILABLE" without any warranties of any kind.</strong>
        </p>
        <p class="text-muted-foreground leading-relaxed mt-3">
          We make no guarantees regarding:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li><strong>Accuracy:</strong> Product information, prices, and availability may change</li>
          <li><strong>Quality:</strong> We do not guarantee the quality of products featured</li>
          <li><strong>Earnings:</strong> Income estimates are approximations, not guarantees</li>
          <li><strong>Availability:</strong> Website uptime or continuous access</li>
          <li><strong>Results:</strong> Outcomes from following our guides or recommendations</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">7. Limitation of Liability</h2>
        <p class="text-muted-foreground leading-relaxed">
          To the fullest extent permitted by law, smartly.sale and its owners, employees, and affiliates shall not be liable for:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Any indirect, incidental, special, or consequential damages</li>
          <li>Loss of profits, data, or business opportunities</li>
          <li>Damages resulting from third-party products or services</li>
          <li>Issues with purchases made through affiliate links</li>
          <li>Technical failures or security breaches</li>
        </ul>
        <p class="text-muted-foreground leading-relaxed mt-3">
          Our total liability shall not exceed the amount paid by you (if any) for accessing our services.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">8. Intellectual Property Rights</h2>
        
        <h3 class="text-xl font-bold text-foreground mb-3">8.1 Our Content</h3>
        <p class="text-muted-foreground leading-relaxed">
          All content on smartly.sale, including text, images, logos, graphics, and code, is owned by or licensed to us and 
          protected by copyright and trademark laws.
        </p>

        <h3 class="text-xl font-bold text-foreground mb-3 mt-6">8.2 Limited License</h3>
        <p class="text-muted-foreground leading-relaxed">
          We grant you a limited, non-exclusive, non-transferable license to access and use our website for personal, 
          non-commercial purposes. You may not:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Reproduce, distribute, or modify our content without permission</li>
          <li>Use our content for commercial purposes</li>
          <li>Remove copyright or trademark notices</li>
          <li>Create derivative works based on our content</li>
        </ul>

        <h3 class="text-xl font-bold text-foreground mb-3 mt-6">8.3 User-Generated Content</h3>
        <p class="text-muted-foreground leading-relaxed">
          If you submit comments, feedback, or other content to our website, you grant us a worldwide, perpetual, royalty-free 
          license to use, reproduce, and distribute that content.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">9. Product Information</h2>
        <p class="text-muted-foreground leading-relaxed">
          We strive to provide accurate product information, but:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Product details, prices, and availability are subject to change</li>
          <li>Information is sourced from merchants and may contain errors</li>
          <li>We do not guarantee inventory availability</li>
          <li>Product images may differ from actual items</li>
          <li>Discounts and promotions are time-sensitive and subject to merchant terms</li>
        </ul>
        <p class="text-muted-foreground leading-relaxed mt-3">
          Always verify product details on the merchant's website before making a purchase.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">10. Earning Opportunities</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our website provides information about online earning opportunities. Please understand:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li><strong>No Guarantees:</strong> Income estimates are approximations, not guarantees</li>
          <li><strong>Individual Results Vary:</strong> Your success depends on effort, skills, and circumstances</li>
          <li><strong>Third-Party Offers:</strong> Earning opportunities are provided by third parties</li>
          <li><strong>Due Diligence:</strong> Research opportunities before participating</li>
          <li><strong>Scam Warning:</strong> We try to feature legitimate opportunities but cannot guarantee all offers</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">11. Privacy</h2>
        <p class="text-muted-foreground leading-relaxed">
          Your use of our website is also governed by our <a href="/privacy" class="text-brand hover:underline font-bold">Privacy Policy</a>. 
          Please review it to understand how we collect, use, and protect your information.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">12. Termination</h2>
        <p class="text-muted-foreground leading-relaxed">
          We reserve the right to terminate or suspend your access to our website at any time, without notice, for:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Violation of these Terms</li>
          <li>Fraudulent or abusive behavior</li>
          <li>Any reason we deem necessary</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">13. Governing Law</h2>
        <p class="text-muted-foreground leading-relaxed">
          These Terms are governed by the laws of the Republic of the Philippines. Any disputes arising from these Terms or 
          your use of our website shall be resolved in the courts of the Philippines.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">14. Indemnification</h2>
        <p class="text-muted-foreground leading-relaxed">
          You agree to indemnify and hold harmless smartly.sale, its owners, employees, and affiliates from any claims, damages, 
          or expenses (including legal fees) arising from:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mt-3">
          <li>Your use of our website</li>
          <li>Your violation of these Terms</li>
          <li>Your violation of any third-party rights</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">15. Severability</h2>
        <p class="text-muted-foreground leading-relaxed">
          If any provision of these Terms is found to be invalid or unenforceable, the remaining provisions shall continue in 
          full force and effect.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">16. Contact Information</h2>
        <p class="text-muted-foreground leading-relaxed">
          If you have questions about these Terms of Service, please contact us:
        </p>
        <div class="bg-orange-50 p-6 rounded-lg mt-4 border border-orange-100">
          <p class="text-muted-foreground mb-2"><strong>Email:</strong> legal@smartly.sale</p>
          <p class="text-muted-foreground mb-2"><strong>Contact Form:</strong> <a href="/contact" class="text-brand hover:underline">smartly.sale/contact</a></p>
          <p class="text-muted-foreground"><strong>Response Time:</strong> We aim to respond within 7 business days</p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">17. Entire Agreement</h2>
        <p class="text-muted-foreground leading-relaxed">
          These Terms, together with our Privacy Policy, constitute the entire agreement between you and smartly.sale regarding 
          your use of our website.
        </p>
      </section>

    </div>

    <!-- Back to Home CTA -->
    <div class="mt-12 text-center">
      <a 
        href="/" 
        class="inline-block bg-brand text-white px-8 py-3 rounded-full font-bold hover:bg-brand-hover transition-colors"
      >
        Back to Homepage
      </a>
    </div>

  </div>
</MainLayout>

<style>
  .prose h2 {
    font-family: var(--heading-font);
    scroll-margin-top: 2rem;
  }
  
  .prose h3 {
    font-family: var(--heading-font);
  }
  
  .prose p, .prose li {
    font-family: var(--body-font);
  }

  .prose section {
    margin-bottom: 3rem;
  }
</style>
