---
import MainLayout from '../layouts/main.astro';
import Hero from '../components/Hero';
import FeaturedProducts from '../components/FeaturedProducts';
import WhyChooseUs from '../components/WhyChooseUs';
import HowItWorks from '../components/HowItWorks';
import TrustIndicators from '../components/TrustIndicators';
import Newsletter from '../components/Newsletter';
import { fetchProductsFromWebflow } from '../lib/products';
import type { CMSProduct } from '../types/product';
import { transformCMSProduct } from '../types/product';

const pageTitle = "smartly.sale - Best Shopee Deals & Viral Products Philippines 2026";
const pageDescription = "Discover trending Shopee products, viral finds, budget gadgets, and exclusive deals in the Philippines. Smart shopping made easy with curated reviews and affiliate links.";
const pageKeywords = "Shopee Philippines 2026, viral Shopee products, budget gadgets Philippines, best Shopee deals, online shopping Philippines, trending products Shopee, earn GCash online";

// Fetch products server-side — eliminates client-side waterfall for initial render
let initialProducts: CMSProduct[] = [];
try {
  const data = await fetchProductsFromWebflow(undefined, 20, 0);
  initialProducts = data.items || [];
} catch (_e) {
  // Client-side fetch fallback will handle this
}

// Build ItemList schema from first 8 featured products
const featuredForSchema = initialProducts
  .filter(item => !item.fieldData._draft && !item.fieldData._archived)
  .slice(0, 8)
  .map((item, idx) => {
    const p = transformCMSProduct(item);
    return {
      "@type": "ListItem",
      "position": idx + 1,
      "url": `https://smartly.sale/product/${p.slug}`,
      "name": p.name
    };
  });

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "smartly.sale",
  "url": "https://smartly.sale",
  "description": pageDescription,
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://smartly.sale/products?q={search_term_string}"
    },
    "query-input": "required name=search_term_string"
  }
};

const itemListSchema = featuredForSchema.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Featured Viral Products",
  "description": "Handpicked trending Shopee products in the Philippines",
  "url": "https://smartly.sale/#products",
  "numberOfItems": featuredForSchema.length,
  "itemListElement": featuredForSchema
} : null;

const homeFaqs = [
  {
    q: "What is smartly.sale?",
    a: "smartly.sale is a Shopee Philippines affiliate shopping guide that curates trending, viral, and budget-friendly products for Filipino shoppers. We hand-pick deals across categories like gadgets, home & living, fashion, beauty, and food so you can discover the best Shopee finds without wasting hours scrolling."
  },
  {
    q: "How do affiliate links on smartly.sale work?",
    a: "When you click a 'Buy on Shopee' button and make a purchase, smartly.sale may earn a small commission from Shopee at no extra cost to you. The price you pay on Shopee is exactly the same whether you come through us or visit Shopee directly. Our commissions help keep the site free and updated with fresh deals."
  },
  {
    q: "How do I find the best deals on Shopee Philippines?",
    a: "Browse our curated categories — Gadgets, Home & Living, Fashion, Beauty, Sports, and Food. Use the search bar on the Products page to filter by keyword. We also update picks regularly, so bookmark us and check back before Shopee's monthly sales (11.11, 12.12, Payday Sales, and more)."
  },
  {
    q: "Is smartly.sale free to use?",
    a: "Yes, smartly.sale is completely free for shoppers. You can browse all products, read buying guides, and click through to Shopee without paying anything. The site is supported by small affiliate commissions that don't affect your prices."
  },
  {
    q: "What product categories are available on smartly.sale?",
    a: "We currently cover six main categories: Gadgets & Tech (phones, earphones, power banks), Home & Living (fans, organizers, kitchen tools), Fashion (clothes, bags, shoes), Beauty & Health (skincare, makeup, wellness), Sports & Outdoor (fitness gear, outdoor equipment), and Food & Snacks (local snacks, pantry staples). New categories are added as trends emerge on Shopee Philippines."
  }
];

---

<MainLayout
title={pageTitle}
description={pageDescription}
ogImage="https://smartly.sale/og-image.jpg"
canonicalUrl="https://smartly.sale"
keywords={pageKeywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
  </Fragment>

<!-- Hero Section -->
<Hero client:load />

<!-- Fast Money Funnel -->
<section class="py-8 bg-muted/20 border-y border-border">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-3 mb-5">
      <div>
        <h2 class="text-2xl font-bold text-foreground">Start With the Highest-Intent Pages</h2>
        <p class="text-sm text-muted-foreground mt-1">These pages are optimized for reward, giveaway, and earn-online intent first.</p>
      </div>
      <a href="/earn-gcash" class="text-sm font-semibold text-brand hover:underline">Open the main money page →</a>
    </div>
    <div class="grid sm:grid-cols-3 gap-5">
      {[
        {
          href: '/earn-gcash',
          title: 'Earn GCash Online',
          body: 'Verified reward offers and prize draws — libre sumali, walang bayad. Claim live GCash credits and cash rewards.',
          accent: 'border-blue-200 hover:border-blue-400',
        },
        {
          href: '/online-contests-philippines',
          title: 'Online Contests PH',
          body: 'Legit online contests and giveaways in the Philippines — win gadgets, gift cards, and cash prizes. Updated daily.',
          accent: 'border-purple-200 hover:border-purple-400',
        },
        {
          href: '/free-gift-cards-philippines',
          title: 'Free Gift Cards PH',
          body: 'Win Visa cards, GCash credits, and e-wallet rewards online — no purchase required. Available in the Philippines.',
          accent: 'border-emerald-200 hover:border-emerald-400',
        },
      ].map(({ href, title, body, accent }) => (
        <a href={href} class={`rounded-2xl border bg-card p-6 transition-all hover:-translate-y-0.5 hover:shadow-md ${accent}`}>
          <p class="font-bold text-foreground mb-2">{title}</p>
          <p class="text-sm text-muted-foreground leading-relaxed">{body}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Featured Products Section -->
<FeaturedProducts initialProducts={initialProducts} client:visible />

<!-- Category Cluster — static SSR so Google indexes these links immediately -->
<section class="py-12 bg-muted/30 border-y border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground text-center mb-8">
      Shop by Category
    </h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      <a href="/category/gadgets" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">📱</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Gadgets & Tech</span>
      </a>
      <a href="/category/home-living" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">🏠</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Home & Living</span>
      </a>
      <a href="/category/fashion" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">👗</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Fashion</span>
      </a>
      <a href="/category/beauty" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">💄</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Beauty & Health</span>
      </a>
      <a href="/category/sports-outdoor" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">⚽</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Sports & Outdoor</span>
      </a>
      <a href="/category/food-snacks" class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
        <span class="text-3xl">🍜</span>
        <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Food & Snacks</span>
      </a>
    </div>
  </div>
</section>

<!-- Why Choose Us Section -->
<section style="content-visibility: auto; contain-intrinsic-size: auto 600px;">
<WhyChooseUs client:visible />
</section>

<!-- How It Works Section -->
<section style="content-visibility: auto; contain-intrinsic-size: auto 500px;">
<HowItWorks client:visible />
</section>

<!-- Trust Indicators Section -->
<section style="content-visibility: auto; contain-intrinsic-size: auto 400px;">
<TrustIndicators client:visible />
</section>

<!-- FAQ Section — FAQPage schema is in <head>; accordion makes content visible to Google -->
<section class="py-16 bg-muted/30 border-t border-border" id="faq">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl md:text-3xl font-bold text-foreground text-center mb-4">
      Frequently Asked Questions
    </h2>
    <p class="text-muted-foreground text-center mb-10 text-sm">Everything you need to know about smartly.sale and shopping on Shopee Philippines</p>
    <div class="space-y-4">
      {homeFaqs.map((faq, i) => (
        <details class="group bg-card border border-border rounded-xl overflow-hidden" open={i === 0}>
          <summary class="flex items-center px-6 py-5 cursor-pointer font-semibold text-foreground hover:text-brand transition-colors list-none">
            <span class="flex-1">{faq.q}</span>
            <span class="text-brand text-xl shrink-0 ml-6 transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-6 pb-6 text-muted-foreground leading-relaxed text-sm border-t border-border pt-4">
            {faq.a}
          </div>
        </details>
      ))}
    </div>
    <div class="text-center mt-8">
      <a href="/faq" class="text-brand hover:underline text-sm font-medium">See all FAQs →</a>
    </div>
  </div>
</section>

<!-- Popular Guides — internal links for topical authority + crawl depth reduction -->
<section class="py-14 bg-card border-t border-border">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground text-center mb-3">Popular Guides & Resources</h2>
    <p class="text-sm text-muted-foreground text-center mb-10">Expert guides updated for 2026 — trusted by thousands of Filipino shoppers</p>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {[
        { href: '/blog/shopee-6-6-mid-year-sale-2026-best-deals-guide', title: 'Shopee 6.6 Mid-Year Sale Guide', desc: 'Best deals, voucher codes & flash sale schedules for June 2026' },
        { href: '/blog/best-budget-phones-under-5000-shopee-philippines-2026', title: 'Best Phones Under PHP 5,000', desc: 'Top 5 budget smartphones compared — Xiaomi, realme, Samsung' },
        { href: '/shopee-sales-2026', title: 'Shopee Sales Calendar 2026', desc: 'Complete schedule of every Shopee sale event this year' },
        { href: '/earn-gcash', title: 'Earn GCash Online Free', desc: 'Verified reward offers — libreng sumali, walang bayad' },
        { href: '/free-gift-cards-philippines', title: 'Free Gift Cards PH', desc: 'Win Visa, GCash & more gift cards online — updated daily' },
        { href: '/tools/discount-calculator', title: 'Discount Calculator', desc: 'Calculate your final price after Shopee vouchers & discounts' },
      ].map(({ href, title, desc }) => (
        <a href={href} class="group flex flex-col gap-2 p-5 bg-muted/30 border border-border rounded-xl hover:border-brand hover:shadow-sm transition-all">
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">{title}</span>
          <span class="text-sm text-muted-foreground leading-relaxed">{desc}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- Deals by Budget — programmatic SEO internal links -->
<section class="py-14 bg-muted/20 border-t border-border">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-2xl font-bold text-foreground text-center mb-3">Shop by Budget</h2>
    <p class="text-sm text-muted-foreground text-center mb-10">Find the best Shopee deals for every price range — updated daily</p>
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
      {[
        { href: '/deals/under-100',  label: 'Under PHP 100',   emoji: '🪙' },
        { href: '/deals/under-200',  label: 'Under PHP 200',   emoji: '💰' },
        { href: '/deals/under-500',  label: 'Under PHP 500',   emoji: '🔥' },
        { href: '/deals/under-1000', label: 'Under PHP 1,000', emoji: '⭐' },
        { href: '/deals/under-2000', label: 'Under PHP 2,000', emoji: '💎' },
        { href: '/deals/under-5000', label: 'Under PHP 5,000', emoji: '🏆' },
      ].map(({ href, label, emoji }) => (
        <a href={href} class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
          <span class="text-3xl">{emoji}</span>
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">{label}</span>
        </a>
      ))}
    </div>
    <div class="text-center mt-5">
      <a href="/deals" class="text-sm text-brand hover:underline font-medium">View all price ranges →</a>
    </div>
  </div>
</section>

<!-- Newsletter Section -->
<Newsletter client:visible />
</MainLayout>
