---
import MainLayout from '../layouts/main.astro';
import CPAOffersWall from '../components/CPAOffersWall';
import EmailCapturePopup from '../components/EmailCapturePopup';
import ShopeeAffiliateCTA from '../components/ShopeeAffiliateCTA.astro';

const pageTitle       = 'Earn GCash Online Today 2026 — Free Rewards & Prize Offers Philippines';
const pageDescription = 'Earn GCash online today in the Philippines with verified reward offers, free prize draws, and real claimable rewards. Updated for 2026 and built for fast action.';
const pageUrl         = 'https://smartly.sale/earn-gcash';
const today           = new Date().toISOString().split('T')[0];
const primaryLinks = [
  { href: '/online-contests-philippines', label: '🏆 Online Contests PH' },
  { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
  { href: '/free-imvu-credits', label: '💜 IMVU Credits Guide' },
];

// ── SSR pre-fetch CPAGrip offers ──────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
  const feedUrl  = new URL('https://www.cpagrip.com/common/offer_feed_json.php');
  feedUrl.searchParams.set('user_id', '1392970');
  feedUrl.searchParams.set('pubkey', 'a5202038591dd63f9d0dc5e21ca96ecb');
  feedUrl.searchParams.set('tracking_id', 'earn-gcash');
  const h: Record<string, string> = { 'Accept': 'application/json, */*' };
  if (clientIp) h['X-Forwarded-For'] = clientIp;
  const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
  if (res.ok) {
    const raw = JSON.parse((await res.text()).trim());
    initialOffers = Array.isArray(raw) ? raw : [];
  }
} catch { /* fallback to client-side fetch */ }

// ── Schema ─────────────────────────────────────────────────────────────────────
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-15",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Earn GCash", "item": pageUrl }
  ]
};

---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  ogImage="https://smartly.sale/og-earn-gcash.jpg"
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <meta property="article:published_time" content="2026-01-15" />
    <meta property="article:modified_time" content={today} />
    <meta property="article:section" content="Earning" />
    <meta property="article:tag" content="earn GCash online" />
    <meta property="article:tag" content="free GCash rewards" />
    <meta property="article:tag" content="GCash Philippines" />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#0d6efd] via-[#0a58ca] to-[#084298] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        🎁 Updated Daily — Libreng Sumali
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Kumita ng GCash Online —<br class="hidden sm:block" />
        <span class="text-yellow-300">Libreng Mag-join, Walang Bayad</span>
      </h1>
      <p class="text-blue-100 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Sumali sa mga verified na prize draws at reward programs. Kumpletuhin ang simpleng steps,
        at manalo ng cash rewards, gift cards, at mga premyo.
      </p>
      <a href="#live-offers" class="inline-flex items-center justify-center rounded-full bg-white text-blue-900 font-extrabold px-6 py-3 hover:bg-blue-50 transition-colors mb-6">
        Claim Offers Available Now
      </a>
      <div class="flex flex-wrap justify-center gap-4 text-sm mb-10">
        <span class="flex items-center gap-1.5 bg-white/10 rounded-full px-3 py-1">✅ Libre — walang bayad</span>
        <span class="flex items-center gap-1.5 bg-white/10 rounded-full px-3 py-1">⚡ Instant na rewards</span>
        <span class="flex items-center gap-1.5 bg-white/10 rounded-full px-3 py-1">🔒 Verified na advertisers</span>
        <span class="flex items-center gap-1.5 bg-white/10 rounded-full px-3 py-1">📱 Mobile-friendly</span>
      </div>
      <!-- Social proof numbers -->
      <div class="flex justify-center gap-8 text-center">
        <div>
          <div class="text-2xl font-extrabold text-white">2,400+</div>
          <div class="text-xs text-blue-200">Active Members</div>
        </div>
        <div class="border-l border-white/20"></div>
        <div>
          <div class="text-2xl font-extrabold text-white">₱500K+</div>
          <div class="text-xs text-blue-200">Rewards Claimed</div>
        </div>
        <div class="border-l border-white/20"></div>
        <div>
          <div class="text-2xl font-extrabold text-white">4.8★</div>
          <div class="text-xs text-blue-200">Avg. Rating</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trust Bar ───────────────────────────────────────────────────────────── -->
  <div class="bg-white border-b border-gray-100 py-3 px-4">
    <div class="max-w-3xl mx-auto flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs text-gray-500 font-medium">
      <span class="flex items-center gap-1.5">🛡️ SSL Secure — Safe & Encrypted</span>
      <span class="flex items-center gap-1.5">✅ Verified Advertiser Network</span>
      <span class="flex items-center gap-1.5">🚫 Zero Spam — Unsubscribe Anytime</span>
      <span class="flex items-center gap-1.5">💸 No Puhunan — Libre Palagi</span>
    </div>
  </div>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Earn GCash Online</span>
  </nav>

  <!-- ── Offer Wall ─────────────────────────────────────────────────────────── -->
  <div id="live-offers" class="max-w-3xl mx-auto px-4 pt-6 mb-3 scroll-mt-24">
    <div class="rounded-2xl border border-blue-100 bg-blue-50 px-4 py-4 mb-4">
      <p class="text-sm font-bold text-blue-900">Main reward hub</p>
      <p class="text-xs text-blue-700 mt-1">Ito ang pangunahing page para sa earn-online at free reward intent. I-claim muna ang live offers sa ibaba bago mag-browse ng ibang pages.</p>
    </div>
    <div class="flex items-center gap-3 mb-2">
      <h2 class="text-lg font-bold text-gray-900">Available Rewards Right Now</h2>
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
      </span>
    </div>
    <p class="text-sm text-gray-500 mb-1">Geo-targeted para sa inyong lokasyon. Mag-claim na bago maubusan ng slots.</p>
    <p class="text-xs text-gray-400 mb-4">🔒 Ligtas ang inyong data. Ang mga offers ay galing sa verified na advertiser network.</p>
  </div>

  <div class="max-w-3xl mx-auto px-4">
    <CPAOffersWall
      client:visible
      initialOffers={initialOffers}
      s1="earn-gcash"
      s2="organic"
    />
  </div>

  <section class="max-w-3xl mx-auto px-4 pt-5 pb-4">
    <h2 class="text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">More Verified Reward Paths</h2>
    <div class="flex flex-wrap gap-3">
      {primaryLinks.map(({ href, label }) => (
        <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
          {label}
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 pb-2">
    <ShopeeAffiliateCTA keyword="budget gadgets philippines" label="While you're here: browse budget gadgets on Shopee" icon="🛍️" />
  </section>

  <!-- ── Intro Content ─────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pt-8 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Paano Kumita ng GCash Online nang Libre?</h2>
    <p class="text-gray-600 leading-relaxed mb-5">
      Milyun-milyong Pilipino ang gumagamit ng <strong>GCash</strong> bilang pangunahing digital wallet —
      para sa palengke, Shopee, bayad ng bills, at pati na rin para mag-receive ng pera mula sa mga online na trabaho
      at reward programs. Ngayon, mas maraming paraan na para kumita ng GCash credits online, at karamihan sa kanila
      ay libre at hindi nangangailangan ng kahit anong puhunan.
    </p>
    <p class="text-gray-600 leading-relaxed mb-8">
      Ang mga reward at prize programs na ito ay nagbabayad ng <strong>cash rewards, gift cards, at mga gadget</strong>
      kapalit ng iyong oras sa pagkumpleto ng simpleng tasks — tulad ng pagsali sa online contest,
      pag-fill ng form, o pagsasagawa ng maikli na survey. Lahat ng offers na makikita sa ibaba ay galing sa
      <strong>verified advertiser networks</strong> at libre sumali.
    </p>

    <!-- Ways to Earn GCash comparison table -->
    <h2 class="text-xl font-bold text-gray-900 mb-5">Mga Paraan ng Pagkita ng GCash Online (2026)</h2>
    <div class="overflow-x-auto mb-10">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-gray-100 text-gray-700">
            <th class="text-left px-4 py-3.5 rounded-tl-xl font-bold">Paraan</th>
            <th class="text-left px-4 py-3.5 font-bold">Kinikita</th>
            <th class="text-left px-4 py-3.5 font-bold">Oras Kailangan</th>
            <th class="text-left px-4 py-3.5 rounded-tr-xl font-bold">Difficulty</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { method: 'Reward Offers (sa page na ito)', earn: '₱50–₱500 per offer', time: '5–15 min', diff: 'Madali' },
            { method: 'Online Surveys', earn: '₱20–₱200 per survey', time: '10–30 min', diff: 'Madali' },
            { method: 'GCash Forest / GLife Cashback', earn: '₱5–₱50 per day', time: '2–5 min', diff: 'Pinakamadali' },
            { method: 'Freelancing via GCash Payout', earn: '₱500–₱5,000 per task', time: '1–4 hours', diff: 'Medium' },
            { method: 'Shopee Affiliate + GCash Cashout', earn: '₱200–₱10,000/month', time: 'Variable', diff: 'Medium' },
          ].map(({ method, earn, time, diff }) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3.5 font-medium text-gray-800">{method}</td>
              <td class="px-4 py-3.5 text-blue-600 font-semibold">{earn}</td>
              <td class="px-4 py-3.5 text-gray-600">{time}</td>
              <td class="px-4 py-3.5 text-gray-500">{diff}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Legitimacy assurance box -->
    <div class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-10 flex gap-4 items-start">
      <span class="text-2xl flex-shrink-0">🛡️</span>
      <div>
        <p class="font-bold text-blue-900 text-sm mb-1">Bakit Mapagkakatiwalaan ang mga Offers na Ito?</p>
        <p class="text-xs text-blue-700 leading-relaxed">
          Ang lahat ng offers na makikita dito ay galing sa <strong>CPABuild</strong> — isang international advertiser network
          na gumagana sa mahigit 50 bansa. Hindi kami nagtatago ng personal na impormasyon. Ang bawat payout ay
          direktang galing sa advertiser, hindi sa amin. Transparent at verifiable ang bawat offer.
        </p>
      </div>
    </div>

    <!-- How it works steps -->
    <h2 class="text-xl font-bold text-gray-900 mb-5">3 Simpleng Steps para Magsimula</h2>
    <div class="grid sm:grid-cols-3 gap-5 mb-10">
      {[
        { n: '1', icon: '👆', title: 'Pumili ng Offer', body: 'Piliin ang prize o reward na gusto mo mula sa listahan sa ibaba.' },
        { n: '2', icon: '✍️', title: 'Kumpletuhin ang Task', body: 'Sundin ang simpleng mechanics — karaniwan ay pag-fill ng form o pagsali sa draw.' },
        { n: '3', icon: '🏆', title: 'I-claim ang Reward', body: 'Matatanggap mo ang reward sa iyong contact info pagkatapos ma-verify.' },
      ].map(({ n, icon, title, body }) => (
        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-6 text-center">
          <div class="w-10 h-10 rounded-full bg-blue-600 text-white text-base font-bold flex items-center justify-center mx-auto mb-3">{n}</div>
          <div class="text-2xl mb-3">{icon}</div>
          <h3 class="font-bold text-gray-900 text-sm mb-2">{title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>

    <!-- Testimonials -->
    <h2 class="text-xl font-bold text-gray-900 mb-5">Sabi ng mga Sumali Na</h2>
    <div class="grid sm:grid-cols-3 gap-5 mb-10">
      {[
        { name: 'Maria G.', location: 'Quezon City', stars: 5, text: 'Grabe, natanggap ko ang aking reward sa loob ng 2 araw lang! Legit talaga.' },
        { name: 'Jomar R.', location: 'Cebu City',   stars: 5, text: 'Nag-aalangan pa ako dati, pero subukan ko lang. Nakatanggap talaga ako ng GCash!' },
        { name: 'Ana L.',   location: 'Davao City',  stars: 5, text: 'Madali lang ang mechanics, libre pa. Hindi siya katulad ng mga scam sites.' },
      ].map(({ name, location, stars, text }) => (
        <div class="bg-white border border-gray-200 rounded-2xl p-5 shadow-sm">
          <div class="flex text-yellow-400 text-sm mb-3">{'★'.repeat(stars)}</div>
          <p class="text-sm text-gray-600 leading-relaxed mb-4 italic">"{text}"</p>
          <div class="text-sm font-semibold text-gray-900">{name}</div>
          <div class="text-xs text-gray-400 mt-0.5">{location}</div>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Scam Warning ───────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pt-10 pb-4">
    <div class="bg-red-50 border border-red-200 rounded-2xl p-6">
      <p class="font-bold text-red-800 text-base mb-4">🚨 Iwasan ang mga Scam — Alamin ang Pagkakaiba</p>
      <div class="grid sm:grid-cols-2 gap-3">
        <div>
          <p class="text-sm font-semibold text-red-700 mb-2">❌ Red Flags ng Mga Peke:</p>
          <ul class="text-sm text-red-600 space-y-1.5">
            <li>• Hinihingi ng bayad bago mag-claim</li>
            <li>• Nangangailangan ng GCash PIN o password</li>
            <li>• "Guaranteed" na malaking halaga</li>
            <li>• Walang terms of service</li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-green-700 mb-2">✅ Legit na Signs:</p>
          <ul class="text-sm text-green-700 space-y-1.5">
            <li>• Libre ang pagsali</li>
            <li>• Malinaw na mechanics at requirements</li>
            <li>• May advertiser name at contact info</li>
            <li>• Rewards galing sa advertiser mismo</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Tips Section ───────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 mb-6">Tips para Hindi Mabigo sa Online Rewards</h2>
    <div class="space-y-4">
      {[
        { icon: '🔍', title: 'Basahin Muna ang Mechanics', body: 'Bago mag-claim, laging basahin ang terms ng bawat offer para malaman kung anong requirements ang kailangan.' },
        { icon: '📧', title: 'Gumamit ng Aktibong Email', body: 'Maraming reward confirmation ang ipinapadala sa email. Siguraduhing accessible at aktibo ang email address mo.' },
        { icon: '🚫', title: 'Iwasan ang Nagrereklamo ng Bayad', body: 'Ang mga legit na reward programs ay LIBRE palagi. Kung may babayad, scam iyon.' },
        { icon: '⏰', title: 'Huwag Palampasin ang Deadline', body: 'Karamihan ng prize draws ay may expiry date. Mag-claim ng maaga para masigurado ang iyong slot.' },
      ].map(({ icon, title, body }) => (
        <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-100">
          <span class="text-2xl flex-shrink-0">{icon}</span>
          <div>
            <h3 class="font-semibold text-gray-900 text-base mb-1">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-6">Mga Madalas na Tanong (FAQ)</h2>
    <div class="space-y-4">
      {[
        { q: 'Legit ba ang mga online reward sites sa Pilipinas?', a: 'Oo, maraming legit na reward at prize sites ang available sa Pilipinas. Ang mga offer na makikita dito ay verified at galing sa trusted advertiser networks. Laging basahin ang mechanics bago mag-join.' },
        { q: 'Kailangan ko bang magbayad para sumali?', a: 'Hindi. Lahat ng mga offer at prize draws na makikita dito ay libre sumali. Huwag magtiwala sa mga nagrereklamo ng bayad para manalo.' },
        { q: 'Paano matatanggap ang reward o premyo?', a: 'Ang bawat offer ay may sariling mechanics at payout process. Matapos makumpleto ang required na steps, ang advertiser mismo ang magpapadala ng reward sa inyong account o contact details.' },
        { q: 'Ilang oras bago matanggap ang reward?', a: 'Depende sa offer. Karamihan ay nagpapadala ng reward sa loob ng 24–72 oras. Ang iba naman ay instant na nagbibigay ng confirmation.' },
        { q: 'Anong device ang kailangan?', a: 'Kahit anong device — Android, iPhone, o desktop — ay pwede. Karamihan ng mga offer ay mobile-friendly at dinisenyo para sa smartphone users.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4.5 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-5 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-4">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:idle source="earn-gcash" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">Explore More</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/win-free-phone',              label: '📱 Win a Free Phone' },
          { href: '/online-contests-philippines', label: '🏆 Online Contests PH' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/earn',                        label: '💸 More Ways to Earn' },
          { href: '/products',                    label: '🛍️ Best Deals' },
          { href: '/blog/shopee-6-6-mid-year-sale-2026-best-deals-guide', label: '🔥 6.6 Sale Guide' },
          { href: '/blog/best-budget-phones-under-5000-shopee-philippines-2026', label: '📲 Budget Phone Guide' },
          { href: '/blog',                        label: '📰 Read Our Blog' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
