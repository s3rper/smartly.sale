---
import MainLayout from '../layouts/main.astro';
import CPAOffersWall from '../components/CPAOffersWall';
import EmailCapturePopup from '../components/EmailCapturePopup';
import ShopeeAffiliateCTA from '../components/ShopeeAffiliateCTA.astro';
import ReferralShare from '../components/ReferralShare';

const pageTitle       = 'Earn GCash Online Today 2026 — Free Rewards & Prize Offers Philippines';
const pageDescription = 'Earn GCash online today in the Philippines with verified reward offers, free prize draws, and real claimable rewards. Updated for 2026 and built for fast action.';
const pageUrl         = 'https://smartly.sale/earn-gcash';
const today           = new Date().toISOString().split('T')[0];
const primaryLinks = [
  { href: '/online-contests-philippines', label: 'Online Contests PH', icon: 'trophy' },
  { href: '/free-gift-cards-philippines', label: 'Free Gift Cards', icon: 'gift' },
  { href: '/free-imvu-credits', label: 'IMVU Credits Guide', icon: 'heart' },
];

// ── SSR pre-fetch CPAGrip offers ──────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
  const feedUrl  = new URL('https://www.cpagrip.com/common/offer_feed_json.php');
  feedUrl.searchParams.set('user_id', '1392970');
  feedUrl.searchParams.set('pubkey', 'a5202038591dd63f9d0dc5e21ca96ecb');
  feedUrl.searchParams.set('tracking_id', 'earn-gcash');
  const h: Record<string, string> = { 'Accept': 'application/json, */*' };
  if (clientIp) h['X-Forwarded-For'] = clientIp;
  const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
  if (res.ok) {
    const raw = JSON.parse((await res.text()).trim());
    initialOffers = Array.isArray(raw) ? raw : [];
  }
} catch { /* fallback to client-side fetch */ }

// ── Schema ─────────────────────────────────────────────────────────────────────
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-15",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Earn GCash", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Legit ba ang mga online reward sites sa Pilipinas?", "acceptedAnswer": { "@type": "Answer", "text": "Oo, maraming legit na reward at prize sites ang available sa Pilipinas. Ang mga offer na makikita dito ay verified at galing sa trusted advertiser networks." }},
    { "@type": "Question", "name": "Kailangan ko bang magbayad para sumali?", "acceptedAnswer": { "@type": "Answer", "text": "Hindi. Lahat ng mga offer at prize draws na makikita dito ay libre sumali." }},
    { "@type": "Question", "name": "Paano matatanggap ang reward o premyo?", "acceptedAnswer": { "@type": "Answer", "text": "Ang bawat offer ay may sariling mechanics at payout process. Matapos makumpleto ang steps, ang advertiser mismo ang magpapadala ng reward." }},
    { "@type": "Question", "name": "Paano gumagana ang referral program?", "acceptedAnswer": { "@type": "Answer", "text": "I-share ang iyong unique referral link sa kaibigan. Kapag nag-join sila gamit ang iyong link, makakakuha ka ng bonus reward points." }},
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  ogImage="https://smartly.sale/og-earn-gcash.jpg"
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <meta property="article:published_time" content="2026-01-15" />
    <meta property="article:modified_time" content={today} />
    <meta property="article:section" content="Earning" />
    <meta property="article:tag" content="earn GCash online" />
    <meta property="article:tag" content="free GCash rewards" />
    <meta property="article:tag" content="GCash Philippines" />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden bg-gradient-to-br from-[#0d6efd] via-[#0a58ca] to-[#084298] text-white py-16 sm:py-20 px-4">
    <!-- Decorative blobs -->
    <div class="absolute top-0 right-0 w-72 h-72 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-96 h-96 bg-blue-400/10 rounded-full translate-y-1/2 -translate-x-1/3 blur-3xl"></div>

    <div class="relative max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-6 backdrop-blur-sm">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
        </span>
        LIVE — Updated Daily
      </div>

      <h1 class="text-3xl sm:text-5xl font-extrabold leading-tight mb-5 tracking-tight">
        Kumita ng GCash Online
        <span class="block text-yellow-300 mt-1">Libreng Mag-join, Walang Bayad</span>
      </h1>

      <p class="text-white/80 text-base sm:text-lg max-w-xl mx-auto mb-8 leading-relaxed">
        Sumali sa mga verified reward offers at prize programs.
        I-share sa friends mo para sa bonus rewards!
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-8">
        <a href="#live-offers" style="color:#fff" class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-emerald-500 to-emerald-600 font-extrabold px-8 py-3.5 hover:from-emerald-400 hover:to-emerald-500 transition-all shadow-lg shadow-emerald-500/40 active:scale-95 text-base">
          Claim Rewards Now
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
        </a>
        <a href="#referral" class="inline-flex items-center justify-center rounded-full bg-white/15 border-2 border-white/30 text-white font-bold px-8 py-3.5 hover:bg-white/25 transition-all backdrop-blur-sm active:scale-95 text-base">
          Invite Friends
          <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.368 2.684 3 3 0 00-5.368-2.684z"/></svg>
        </a>
      </div>

      <!-- Trust badges row -->
      <div class="flex flex-wrap justify-center gap-2.5 text-sm mb-10">
        <span class="flex items-center gap-1.5 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20 font-medium">
          <svg class="w-4 h-4 text-emerald-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
          Libre
        </span>
        <span class="flex items-center gap-1.5 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20 font-medium">
          <svg class="w-4 h-4 text-yellow-300" fill="currentColor" viewBox="0 0 24 24"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          Instant Rewards
        </span>
        <span class="flex items-center gap-1.5 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20 font-medium">
          <svg class="w-4 h-4 text-cyan-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          Verified
        </span>
        <span class="flex items-center gap-1.5 bg-white/15 backdrop-blur-sm rounded-full px-4 py-2 border border-white/20 font-medium">
          <svg class="w-4 h-4 text-pink-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>
          Mobile-friendly
        </span>
      </div>

      <!-- Stats -->
      <div class="inline-flex items-center gap-6 sm:gap-10 bg-white/20 backdrop-blur-md border border-white/25 rounded-2xl px-8 sm:px-10 py-5">
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-extrabold text-white">2,400+</div>
          <div class="text-xs text-white/70 mt-0.5 font-medium">Active Members</div>
        </div>
        <div class="h-10 w-px bg-white/25"></div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-extrabold text-yellow-300">P500K+</div>
          <div class="text-xs text-white/70 mt-0.5 font-medium">Rewards Claimed</div>
        </div>
        <div class="h-10 w-px bg-white/25"></div>
        <div class="text-center">
          <div class="text-2xl sm:text-3xl font-extrabold text-white">4.8<span class="text-yellow-300">&#9733;</span></div>
          <div class="text-xs text-white/70 mt-0.5 font-medium">Avg. Rating</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ── Trust Bar ───────────────────────────────────────────────────────────── -->
  <div class="bg-white border-b border-gray-100 py-4 px-4">
    <div class="max-w-4xl mx-auto flex flex-wrap justify-center gap-x-6 gap-y-2 text-xs text-gray-500 font-medium">
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
        SSL Encrypted
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        Verified Advertisers
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636"/></svg>
        Zero Spam
      </span>
      <span class="flex items-center gap-1.5">
        <svg class="w-3.5 h-3.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        No Puhunan
      </span>
    </div>
  </div>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-4xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">/</span>
    <span class="text-gray-700 font-medium">Earn GCash Online</span>
  </nav>

  <!-- ── How It Works ─────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pt-12 pb-10">
    <div class="text-center mb-8">
      <h2 class="text-2xl font-extrabold text-gray-900 mb-2">Paano Ito Gumagana?</h2>
      <p class="text-sm text-gray-500 mt-2">3 simpleng steps para magsimulang kumita</p>
    </div>
    <div class="grid sm:grid-cols-3 gap-5">
      {[
        { n: '1', icon: 'cursor', title: 'Pumili ng Offer', body: 'Piliin ang reward o prize na gusto mo mula sa live offers sa ibaba.', color: 'from-blue-500 to-blue-600' },
        { n: '2', icon: 'edit', title: 'Kumpletuhin ang Task', body: 'Sundin ang simpleng mechanics — form, survey, o pagsali sa draw.', color: 'from-indigo-500 to-indigo-600' },
        { n: '3', icon: 'gift', title: 'I-claim & I-share', body: 'Matanggap ang reward, then i-share ang referral link mo para sa bonus!', color: 'from-purple-500 to-purple-600' },
      ].map(({ n, title, body, color }) => (
        <div class="relative group">
          <div class="bg-white border border-gray-100 rounded-2xl p-6 text-center hover:shadow-lg hover:border-blue-200 transition-all h-full">
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${color} text-white text-lg font-bold flex items-center justify-center mx-auto mb-4 shadow-lg group-hover:scale-110 transition-transform`}>
              {n}
            </div>
            <h3 class="font-bold text-gray-900 text-base mb-3">{title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mt-1">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Offer Wall ─────────────────────────────────────────────────────────── -->
  <div id="live-offers" class="max-w-4xl mx-auto px-4 pt-8 mb-3 scroll-mt-24">
    <div class="rounded-2xl border border-blue-100 bg-gradient-to-r from-blue-50 to-indigo-50 px-5 py-4 mb-5">
      <div class="flex items-start gap-3">
        <div class="w-10 h-10 rounded-xl bg-blue-600 text-white flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        </div>
        <div>
          <p class="text-sm font-bold text-blue-900">Main Reward Hub</p>
          <p class="text-xs text-blue-700 mt-2">Ito ang pangunahing page para sa earn-online rewards. I-claim muna ang live offers sa ibaba!</p>
        </div>
      </div>
    </div>

    <div class="flex items-center justify-between gap-3 mb-2">
      <div class="flex items-center gap-3">
        <h2 class="text-xl font-extrabold text-gray-900">Available Rewards</h2>
        <span class="relative flex h-2.5 w-2.5">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
        </span>
      </div>
      <span class="text-xs bg-emerald-50 text-emerald-700 font-semibold px-3 py-1 rounded-full border border-emerald-200">LIVE</span>
    </div>
    <p class="text-sm text-gray-500 mb-4">Geo-targeted para sa inyong lokasyon. Mag-claim na bago maubusan ng slots.</p>
    <p class="text-xs text-gray-400 mb-6">Ang mga offers ay galing sa verified na advertiser network.</p>
  </div>

  <div class="max-w-4xl mx-auto px-4 mb-6">
    <CPAOffersWall
      client:visible
      initialOffers={initialOffers}
      s1="earn-gcash"
      s2="organic"
    />
  </div>

  <!-- ── Referral / Share Section ──────────────────────────────────────────── -->
  <section id="referral" class="max-w-4xl mx-auto px-4 pt-10 pb-12 scroll-mt-24">
    <ReferralShare client:load />
  </section>

  <!-- ── More Reward Paths ────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pb-10">
    <h2 class="text-sm font-bold text-gray-700 mb-3 uppercase tracking-wide">More Verified Reward Paths</h2>
    <div class="grid sm:grid-cols-3 gap-3">
      {primaryLinks.map(({ href, label }) => (
        <a href={href} class="flex items-center gap-3 px-5 py-4 bg-white border border-gray-200 rounded-xl hover:border-blue-300 hover:shadow-md transition-all group">
          <span class="text-sm font-semibold text-gray-700 group-hover:text-blue-700 transition-colors">{label}</span>
          <svg class="w-4 h-4 text-gray-300 group-hover:text-blue-500 ml-auto transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
        </a>
      ))}
    </div>
  </section>

  <section class="max-w-4xl mx-auto px-4 pb-10">
    <ShopeeAffiliateCTA keyword="budget gadgets philippines" label="While you're here: browse budget gadgets on Shopee" icon="bag" />
  </section>

  <!-- ── Ways to Earn Table ───────────────────────────────────────────────── -->
  <article class="max-w-4xl mx-auto px-4 pt-10 pb-10">
    <h2 class="text-xl font-extrabold text-gray-900 mb-2">Paano Kumita ng GCash Online nang Libre?</h2>
    <p class="text-gray-500 text-sm leading-relaxed mb-8 max-w-2xl">
      Milyun-milyong Pilipino ang gumagamit ng GCash bilang pangunahing digital wallet.
      Ngayon, mas maraming paraan na para kumita ng GCash credits online — at karamihan ay libre.
    </p>

    <h3 class="text-lg font-bold text-gray-900 mb-4">Mga Paraan ng Pagkita ng GCash (2026)</h3>
    <div class="overflow-x-auto mb-10 rounded-xl border border-gray-200">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-gray-50 text-gray-700">
            <th class="text-left px-5 py-3.5 font-bold">Paraan</th>
            <th class="text-left px-5 py-3.5 font-bold">Kinikita</th>
            <th class="text-left px-5 py-3.5 font-bold hidden sm:table-cell">Oras</th>
            <th class="text-left px-5 py-3.5 font-bold">Difficulty</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { method: 'Reward Offers (sa page na ito)', earn: 'P50-P500/offer', time: '5-15 min', diff: 'Madali', diffColor: 'bg-emerald-50 text-emerald-700' },
            { method: 'Online Surveys', earn: 'P20-P200/survey', time: '10-30 min', diff: 'Madali', diffColor: 'bg-emerald-50 text-emerald-700' },
            { method: 'GCash Forest / GLife', earn: 'P5-P50/day', time: '2-5 min', diff: 'Pinakamadali', diffColor: 'bg-blue-50 text-blue-700' },
            { method: 'Referral Bonuses', earn: 'P10-P100/referral', time: '1 min', diff: 'Pinakamadali', diffColor: 'bg-blue-50 text-blue-700' },
            { method: 'Freelancing via GCash', earn: 'P500-P5,000/task', time: '1-4 hrs', diff: 'Medium', diffColor: 'bg-amber-50 text-amber-700' },
            { method: 'Shopee Affiliate + GCash', earn: 'P200-P10,000/mo', time: 'Variable', diff: 'Medium', diffColor: 'bg-amber-50 text-amber-700' },
          ].map(({ method, earn, time, diff, diffColor }) => (
            <tr class="hover:bg-gray-50 transition-colors">
              <td class="px-5 py-3.5 font-medium text-gray-800">{method}</td>
              <td class="px-5 py-3.5 text-blue-600 font-semibold">{earn}</td>
              <td class="px-5 py-3.5 text-gray-500 hidden sm:table-cell">{time}</td>
              <td class="px-5 py-3.5">
                <span class={`inline-flex px-2.5 py-1 rounded-full text-xs font-semibold ${diffColor}`}>{diff}</span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <!-- Legitimacy box -->
    <div class="bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-2xl p-6 mb-10">
      <div class="flex gap-4 items-start">
        <div class="w-10 h-10 rounded-xl bg-blue-600 text-white flex items-center justify-center flex-shrink-0">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
          </div>
        <div>
          <p class="font-bold text-blue-900 text-sm mb-2">Bakit Mapagkakatiwalaan ang mga Offers?</p>
          <p class="text-xs text-blue-700 leading-relaxed mt-1">
            Ang lahat ng offers ay galing sa CPABuild — isang international advertiser network.
            Hindi kami nagtatago ng personal na info. Ang bawat payout ay direkta mula sa advertiser.
          </p>
        </div>
      </div>
    </div>
  </article>

  <!-- ── Testimonials ─────────────────────────────────────────────────────── -->
  <section class="max-w-4xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-extrabold text-gray-900 mb-6">Sabi ng mga Sumali Na</h2>
    <div class="grid sm:grid-cols-3 gap-4">
      {[
        { name: 'Maria G.', location: 'Quezon City', stars: 5, text: 'Grabe, natanggap ko ang aking reward sa loob ng 2 araw lang! Legit talaga.', avatar: 'M' },
        { name: 'Jomar R.', location: 'Cebu City',   stars: 5, text: 'Nag-aalangan pa ako dati, pero subukan ko lang. Nakatanggap talaga ako ng GCash!', avatar: 'J' },
        { name: 'Ana L.',   location: 'Davao City',  stars: 5, text: 'Madali lang ang mechanics, libre pa. Hindi siya katulad ng mga scam sites.', avatar: 'A' },
      ].map(({ name, location, stars, text, avatar }) => (
        <div class="bg-white border border-gray-100 rounded-2xl p-6 hover:shadow-lg transition-all">
