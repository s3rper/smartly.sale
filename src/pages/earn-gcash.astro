---
import MainLayout from '../layouts/main.astro';
import CPAOffersWall from '../components/CPAOffersWall';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Earn GCash Online 2025 — Free Rewards & Prizes Philippines';
const pageDescription = 'Discover legitimate ways to earn GCash online in the Philippines. Complete simple tasks, join prize draws, and claim real rewards — no invite needed, libre!';
const pageUrl         = 'https://smartly.sale/earn-gcash';
const today           = new Date().toISOString().split('T')[0];

// ── SSR pre-fetch CPABuild offers ─────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const runtimeEnv = (Astro.locals as any)?.runtime?.env;
  const userId = runtimeEnv?.CPABUILD_USER_ID ?? import.meta.env.CPABUILD_USER_ID ?? process.env.CPABUILD_USER_ID ?? '48201';
  const apiKey = runtimeEnv?.CPABUILD_API_KEY ?? import.meta.env.CPABUILD_API_KEY ?? process.env.CPABUILD_API_KEY ?? '';
  if (apiKey) {
    const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
    const feedUrl  = new URL('https://d2dzcaq3bhqk1m.cloudfront.net/public/offers/feed.php');
    feedUrl.searchParams.set('user_id', userId);
    feedUrl.searchParams.set('api_key', apiKey);
    feedUrl.searchParams.set('s1', 'earn-gcash');
    feedUrl.searchParams.set('s2', 'organic');
    const h: Record<string, string> = { 'Accept': 'application/json, */*' };
    if (clientIp) h['X-Forwarded-For'] = clientIp;
    const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
    if (res.ok) {
      const raw = JSON.parse((await res.text()).trim());
      initialOffers = Array.isArray(raw) ? raw : (raw.offers ?? raw.data ?? []);
    }
  }
} catch { /* fallback to client-side fetch */ }

// ── Schema ─────────────────────────────────────────────────────────────────────
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2025-01-15",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",       "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Earn GCash", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Legit ba ang mga online reward sites sa Pilipinas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Oo, maraming legit na reward at prize sites ang available sa Pilipinas. Ang mga offer na makikita dito ay verified at galing sa trusted advertiser networks. Laging basahin ang mechanics bago mag-join." }
    },
    {
      "@type": "Question",
      "name": "Kailangan ko bang mag-bayad para sumali sa mga online contest?",
      "acceptedAnswer": { "@type": "Answer", "text": "Hindi. Lahat ng mga offer at prize draws na makikita dito ay libre sumali. Huwag magtiwala sa mga nagrereklamo ng bayad para manalo." }
    },
    {
      "@type": "Question",
      "name": "Paano matatanggap ang reward o premyo?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ang bawat offer ay may sariling mechanics at payout process. Matapos makumpleto ang required na steps, ang advertiser mismo ang magpapadala ng reward sa inyong account o contact details." }
    },
    {
      "@type": "Question",
      "name": "Ilang oras bago matanggap ang reward?",
      "acceptedAnswer": { "@type": "Answer", "text": "Depende sa offer. Karamihan ay nagpapadala ng reward sa loob ng 24–72 oras pagkatapos makumpleto ang task. Ang iba naman ay instant na nagbibigay ng confirmation." }
    },
    {
      "@type": "Question",
      "name": "Anong device ang kailangan ko para sumali?",
      "acceptedAnswer": { "@type": "Answer", "text": "Kahit anong device — Android, iPhone, o desktop computer — ay pwedeng gamitin. Karamihan ng mga offer ay mobile-friendly at dinisenyo para sa smartphone users." }
    }
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="earn gcash online, paano kumita ng gcash, free gcash rewards 2025, earn gcash no invite, gcash rewards Philippines, libreng gcash"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#0d6efd] via-[#0a58ca] to-[#084298] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        🎁 Updated Daily — Libreng Sumali
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Kumita ng GCash Online —<br class="hidden sm:block" />
        <span class="text-yellow-300">Libreng Mag-join, Walang Bayad</span>
      </h1>
      <p class="text-blue-100 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Sumali sa mga verified na prize draws at reward programs. Kumpletuhin ang simpleng steps,
        at manalo ng cash rewards, gift cards, at mga premyo.
      </p>
      <div class="flex flex-wrap justify-center gap-5 text-sm text-blue-200">
        <span>✅ Libre — walang bayad</span>
        <span>⚡ Instant na rewards</span>
        <span>🔒 Verified na advertisers</span>
        <span>📱 Mobile-friendly</span>
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Earn GCash Online</span>
  </nav>

  <!-- ── Intro Content ─────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-4">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">Paano Kumita ng GCash Online nang Libre?</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      Milyun-milyong Pilipino ang gumagamit ng <strong>GCash</strong> bilang pangunahing digital wallet —
      para sa palengke, Shopee, bayad ng bills, at pati na rin para mag-receive ng pera mula sa mga online na trabaho
      at reward programs. Ngayon, mas maraming paraan na para kumita ng GCash credits online, at karamihan sa kanila
      ay libre at hindi nangangailangan ng kahit anong puhunan.
    </p>
    <p class="text-gray-600 leading-relaxed mb-6">
      Ang mga reward at prize programs na ito ay nagbabayad ng <strong>cash rewards, gift cards, at mga gadget</strong>
      kapalit ng iyong oras sa pagkumpleto ng simpleng tasks — tulad ng pagsali sa online contest,
      pag-fill ng form, o pagsasagawa ng maikli na survey. Lahat ng offers na makikita sa ibaba ay galing sa
      <strong>verified advertiser networks</strong> at libre sumali.
    </p>

    <!-- How it works steps -->
    <h2 class="text-xl font-bold text-gray-900 mb-4">3 Simpleng Steps para Magsimula</h2>
    <div class="grid sm:grid-cols-3 gap-4 mb-8">
      {[
        { n: '1', icon: '👆', title: 'Pumili ng Offer', body: 'Piliin ang prize o reward na gusto mo mula sa listahan sa ibaba.' },
        { n: '2', icon: '✍️', title: 'Kumpletuhin ang Task', body: 'Sundin ang simpleng mechanics — karaniwan ay pag-fill ng form o pagsali sa draw.' },
        { n: '3', icon: '🏆', title: 'I-claim ang Reward', body: 'Matatanggap mo ang reward sa iyong contact info pagkatapos ma-verify.' },
      ].map(({ n, icon, title, body }) => (
        <div class="bg-blue-50 border border-blue-100 rounded-2xl p-5 text-center">
          <div class="w-10 h-10 rounded-full bg-blue-600 text-white text-base font-bold flex items-center justify-center mx-auto mb-3">{n}</div>
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-bold text-gray-900 text-sm mb-1">{title}</h3>
          <p class="text-xs text-gray-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Offer Wall ─────────────────────────────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-2">
    <div class="flex items-center gap-3 mb-1">
      <h2 class="text-lg font-bold text-gray-900">Available Rewards Right Now</h2>
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
      </span>
    </div>
    <p class="text-sm text-gray-500 mb-4">Geo-targeted para sa inyong lokasyon. Mag-claim na bago maubusan ng slots.</p>
  </div>

  <div class="max-w-3xl mx-auto px-4">
    <CPAOffersWall
      client:visible
      initialOffers={initialOffers}
      s1="earn-gcash"
      s2="organic"
    />
  </div>

  <!-- ── Tips Section ───────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Tips para Hindi Mabigo sa Online Rewards</h2>
    <div class="space-y-4">
      {[
        { icon: '🔍', title: 'Basahin Muna ang Mechanics', body: 'Bago mag-claim, laging basahin ang terms ng bawat offer para malaman kung anong requirements ang kailangan.' },
        { icon: '📧', title: 'Gumamit ng Aktibong Email', body: 'Maraming reward confirmation ang ipinapadala sa email. Siguraduhing accessible at aktibo ang email address mo.' },
        { icon: '🚫', title: 'Iwasan ang Nagrereklamo ng Bayad', body: 'Ang mga legit na reward programs ay LIBRE palagi. Kung may babayad, scam iyon.' },
        { icon: '⏰', title: 'Huwag Palampasin ang Deadline', body: 'Karamihan ng prize draws ay may expiry date. Mag-claim ng maaga para masigurado ang iyong slot.' },
      ].map(({ icon, title, body }) => (
        <div class="flex gap-4 p-4 bg-gray-50 rounded-xl border border-gray-100">
          <span class="text-2xl flex-shrink-0">{icon}</span>
          <div>
            <h3 class="font-semibold text-gray-900 text-sm">{title}</h3>
            <p class="text-xs text-gray-500 mt-0.5 leading-relaxed">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Mga Madalas na Tanong (FAQ)</h2>
    <div class="space-y-4">
      {[
        { q: 'Legit ba ang mga online reward sites sa Pilipinas?', a: 'Oo, maraming legit na reward at prize sites ang available sa Pilipinas. Ang mga offer na makikita dito ay verified at galing sa trusted advertiser networks. Laging basahin ang mechanics bago mag-join.' },
        { q: 'Kailangan ko bang magbayad para sumali?', a: 'Hindi. Lahat ng mga offer at prize draws na makikita dito ay libre sumali. Huwag magtiwala sa mga nagrereklamo ng bayad para manalo.' },
        { q: 'Paano matatanggap ang reward o premyo?', a: 'Ang bawat offer ay may sariling mechanics at payout process. Matapos makumpleto ang required na steps, ang advertiser mismo ang magpapadala ng reward sa inyong account o contact details.' },
        { q: 'Ilang oras bago matanggap ang reward?', a: 'Depende sa offer. Karamihan ay nagpapadala ng reward sa loob ng 24–72 oras. Ang iba naman ay instant na nagbibigay ng confirmation.' },
        { q: 'Anong device ang kailangan?', a: 'Kahit anong device — Android, iPhone, o desktop — ay pwede. Karamihan ng mga offer ay mobile-friendly at dinisenyo para sa smartphone users.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="earn-gcash" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">Explore More</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/win-free-phone',              label: '📱 Win a Free Phone' },
          { href: '/online-contests-philippines', label: '🏆 Online Contests PH' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/earn',                        label: '💸 More Ways to Earn' },
          { href: '/products',                    label: '🛍️ Best Deals' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
