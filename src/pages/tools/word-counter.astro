---
import MainLayout from '../../layouts/main.astro';
---

<MainLayout
  title="Word Counter - Count Words, Reading Time & Readability | Smartly.sale"
  description="Free word counter with real-time stats. Get word count, character count, reading time, speaking time, Flesch readability score, and keyword frequency. Instant results in your browser."
  pageClass="tool-page"
>
  <div class="min-h-screen bg-gradient-to-br from-brand/10 via-background to-background py-4 sm:py-8 px-3 sm:px-4">
    <div class="max-w-4xl mx-auto">
      <div class="mb-4">
        <a href="/tools" class="inline-flex items-center gap-2 text-brand hover:text-brand/80 text-sm font-medium">
          ← Back to All Tools
        </a>
      </div>
      <div id="tool-root"></div>
    </div>
  </div>

  <script>
    import { createRoot } from 'react-dom/client';
    import { createElement } from 'react';
    import WordCounter from '../../components/tools/WordCounter';

    const container = document.getElementById('tool-root');
    if (container) {
      const root = createRoot(container);
      root.render(createElement(WordCounter));
    }
  </script>
</MainLayout>

<style>
  .tool-page {
    min-height: 100vh;
  }
</style>
