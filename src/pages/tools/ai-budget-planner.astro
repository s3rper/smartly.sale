---
import MainLayout from '../../layouts/main.astro';
---

<MainLayout
  title="AI Budget Planner - Smart Shopee Shopping with Claude AI | Smartly.sale"
  description="Tell Claude AI what you need and your budget. Get a personalized Shopee shopping list with item priorities, estimated prices, best time to buy, and money-saving tips."
  pageClass="tool-page"
>
  <div class="min-h-screen bg-gradient-to-br from-brand/10 via-background to-background py-4 sm:py-8 px-3 sm:px-4">
    <div class="max-w-4xl mx-auto">
      <div class="mb-4">
        <a href="/tools" class="inline-flex items-center gap-2 text-brand hover:text-brand/80 text-sm font-medium">
          ← Back to All Tools
        </a>
      </div>
      <div id="tool-root"></div>
    </div>
  </div>

  <script>
    import { createRoot } from 'react-dom/client';
    import { createElement } from 'react';
    import AIBudgetPlanner from '../../components/tools/AIBudgetPlanner';

    const container = document.getElementById('tool-root');
    if (container) {
      const root = createRoot(container);
      root.render(createElement(AIBudgetPlanner));
    }
  </script>
</MainLayout>

<style>
  .tool-page {
    min-height: 100vh;
  }
</style>
