---
import MainLayout from '../../layouts/main.astro';
---

<MainLayout
  title="Base64 Image Encoder - Free Online Tool | Smartly.sale"
  description="Convert images to Base64 strings and decode Base64 back to images. Free online Base64 image encoder with preview, supports JPG, PNG, GIF, SVG. No upload required."
  pageClass="tool-page"
>
  <div class="min-h-screen bg-gradient-to-br from-brand/10 via-background to-background py-4 sm:py-8 px-3 sm:px-4">
    <div class="max-w-4xl mx-auto">
      <!-- Back to Tools -->
      <div class="mb-4">
        <a
          href="/tools"
          class="inline-flex items-center gap-2 text-brand hover:text-brand/80 text-sm font-medium"
        >
          ← Back to All Tools
        </a>
      </div>

      <!-- Tool Component Root -->
      <div id="tool-root"></div>
    </div>
  </div>

  <!-- Load the React component -->
  <script>
    import { createRoot } from 'react-dom/client';
    import { createElement } from 'react';
    import Base64ImageEncoder from '../../components/tools/Base64ImageEncoder';

    const container = document.getElementById('tool-root');
    if (container) {
      const root = createRoot(container);
      root.render(createElement(Base64ImageEncoder));
    }
  </script>
</MainLayout>

<style>
  .tool-page {
    min-height: 100vh;
  }

  /* Checkerboard pattern for image transparency */
  :global(.bg-checkerboard) {
    background-color: #fff;
    background-image:
      linear-gradient(45deg, #f0f0f0 25%, transparent 25%),
      linear-gradient(-45deg, #f0f0f0 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #f0f0f0 75%),
      linear-gradient(-45deg, transparent 75%, #f0f0f0 75%);
    background-size: 20px 20px;
    background-position: 0 0, 0 10px, 10px -10px, -10px 0px;
  }

  :global(.dark .bg-checkerboard) {
    background-color: #1a1a1a;
    background-image:
      linear-gradient(45deg, #2a2a2a 25%, transparent 25%),
      linear-gradient(-45deg, #2a2a2a 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, #2a2a2a 75%),
      linear-gradient(-45deg, transparent 75%, #2a2a2a 75%);
  }
</style>
