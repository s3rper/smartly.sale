  }

  .method-content {
    padding: 36px;
  }

  .method-title {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 18px;
    color: #333;
  }

  .method-description {
    color: #666;
    line-height: 1.7;
    margin-bottom: 28px;
  }

  .method-stats {
    display: grid;
    gap: 18px;
  }

  .stat-item {
    display: flex;
    gap: 12px;
    align-items: start;
    padding: 18px;
    background: #f8f8f8;
    border-radius: 8px;
  }

  .stat-label {
    font-size: 0.813rem;
    color: #888;
    margin-bottom: 4px;
  }

  .stat-value {
    font-weight: 700;
    color: #333;
  }

  /* Tips Section */
  .tips-section {
    padding: 72px 20px;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .tip-card {
    background: white;
    padding: 30px;
    border-radius: 12px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    border-left: 4px solid var(--brand-orange);
  }

  .tip-card h3 {
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 14px;
    color: #333;
  }

  .tip-card p {
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  /* Warning Section */
  .warning-section {
    padding: 72px 20px;
    background: #fff5f0;
  }

  .warning-box {
