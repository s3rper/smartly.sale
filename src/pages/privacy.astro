---
import MainLayout from '../layouts/main.astro';

const pageTitle = "Privacy Policy - smartly.sale Philippines | Data Protection & Privacy";
const pageDescription = "Read smartly.sale's privacy policy. Learn how we collect, use, and protect your personal information when you visit our Shopee deals and product review site.";
---

<MainLayout 
  title={pageTitle}
  description={pageDescription}
  ogImage="/og-image.jpg"
>
  <!-- SEO Schema Markup -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Privacy Policy",
    "description": pageDescription,
    "url": "https://smartly.sale/privacy",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "name": "Home",
          "item": "https://smartly.sale"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "name": "Privacy Policy",
          "item": "https://smartly.sale/privacy"
        }
      ]
    }
  })} />

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-20">
    
    <h1 class="text-3xl md:text-4xl font-bold text-foreground mb-4">
      Privacy Policy
    </h1>
    
    <p class="text-muted-foreground mb-8">
      <strong>Effective Date:</strong> January 15, 2025<br>
      <strong>Last Updated:</strong> {new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}
    </p>

    <div class="prose prose-lg max-w-none space-y-6">
      
      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">1. Introduction</h2>
        <p class="text-muted-foreground leading-relaxed">
          Welcome to smartly.sale ("we," "our," or "us"). We are committed to protecting your privacy and personal information. 
          This Privacy Policy explains how we collect, use, disclose, and safeguard your information when you visit our website 
          <strong>smartly.sale</strong> and use our services.
        </p>
        <p class="text-muted-foreground leading-relaxed">
          By accessing or using our website, you agree to this Privacy Policy. If you do not agree with our policies and practices, 
          please do not use our website.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">2. Information We Collect</h2>
        
        <h3 class="text-xl font-bold text-foreground mb-3">2.1 Information You Provide</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">
          We may collect information that you voluntarily provide when you:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mb-4">
          <li>Subscribe to our newsletter</li>
          <li>Contact us through our contact form</li>
          <li>Leave comments or feedback</li>
          <li>Participate in surveys or promotions</li>
        </ul>
        <p class="text-muted-foreground leading-relaxed">
          This information may include your name, email address, and any other information you choose to provide.
        </p>

        <h3 class="text-xl font-bold text-foreground mb-3 mt-6">2.2 Automatically Collected Information</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">
          When you visit our website, we automatically collect certain information, including:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li><strong>Usage Data:</strong> Pages visited, time spent, links clicked</li>
          <li><strong>Device Information:</strong> Browser type, operating system, device type</li>
          <li><strong>Location Data:</strong> Approximate geographic location based on IP address</li>
          <li><strong>Cookies and Tracking:</strong> See Section 5 for details</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">3. How We Use Your Information</h2>
        <p class="text-muted-foreground leading-relaxed mb-3">
          We use the collected information for various purposes:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li>To provide and maintain our website</li>
          <li>To send newsletters and promotional materials (with your consent)</li>
          <li>To respond to your inquiries and provide customer support</li>
          <li>To analyze website usage and improve our services</li>
          <li>To detect and prevent fraud or abuse</li>
          <li>To comply with legal obligations</li>
          <li>To show relevant affiliate products and deals</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">4. Affiliate Marketing Disclosure</h2>
        <p class="text-muted-foreground leading-relaxed">
          smartly.sale participates in affiliate marketing programs, including the <strong>Shopee Affiliate Program</strong>. 
          When you click on affiliate links and make a purchase, we may earn a commission at no extra cost to you. 
        </p>
        <p class="text-muted-foreground leading-relaxed mt-3">
          We may share certain anonymized data with our affiliate partners to track sales and commissions. This data does not 
          personally identify you.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">5. Cookies and Tracking Technologies</h2>
        <p class="text-muted-foreground leading-relaxed mb-3">
          We use cookies and similar tracking technologies to:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2 mb-4">
          <li>Remember your preferences and settings</li>
          <li>Analyze website traffic and user behavior</li>
          <li>Personalize content and advertisements</li>
          <li>Track affiliate referrals and commissions</li>
        </ul>
        
        <h3 class="text-xl font-bold text-foreground mb-3">Third-Party Services</h3>
        <p class="text-muted-foreground leading-relaxed mb-3">
          We use the following third-party services that may collect information:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li><strong>Google Analytics:</strong> Website analytics and traffic analysis</li>
          <li><strong>Google Tag Manager:</strong> Tag management and tracking</li>
          <li><strong>Meta Pixel (Facebook):</strong> Advertising and conversion tracking</li>
          <li><strong>ShareThis:</strong> Social sharing functionality</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">6. Information Sharing and Disclosure</h2>
        <p class="text-muted-foreground leading-relaxed mb-3">
          We do not sell your personal information. We may share your information with:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li><strong>Service Providers:</strong> Companies that help us operate our website (hosting, analytics, email services)</li>
          <li><strong>Affiliate Partners:</strong> Only anonymized data for tracking purposes</li>
          <li><strong>Legal Requirements:</strong> When required by law or to protect our rights</li>
          <li><strong>Business Transfers:</strong> In case of merger, acquisition, or sale of assets</li>
        </ul>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">7. Data Security</h2>
        <p class="text-muted-foreground leading-relaxed">
          We implement appropriate technical and organizational measures to protect your personal information. However, no method 
          of transmission over the internet is 100% secure. While we strive to protect your data, we cannot guarantee absolute security.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">8. Your Rights and Choices</h2>
        <p class="text-muted-foreground leading-relaxed mb-3">
          You have the following rights regarding your personal information:
        </p>
        <ul class="list-disc pl-6 text-muted-foreground space-y-2">
          <li><strong>Access:</strong> Request a copy of your personal data</li>
          <li><strong>Correction:</strong> Request correction of inaccurate data</li>
          <li><strong>Deletion:</strong> Request deletion of your data</li>
          <li><strong>Opt-Out:</strong> Unsubscribe from marketing emails</li>
          <li><strong>Cookie Control:</strong> Manage cookies through your browser settings</li>
        </ul>
        <p class="text-muted-foreground leading-relaxed mt-4">
          To exercise these rights, please contact us at the email provided in Section 11.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">9. Children's Privacy</h2>
        <p class="text-muted-foreground leading-relaxed">
          Our website is not intended for children under 13 years of age. We do not knowingly collect personal information from 
          children under 13. If you believe we have collected information from a child under 13, please contact us immediately.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">10. International Users</h2>
        <p class="text-muted-foreground leading-relaxed">
          While we primarily serve users in the Philippines, our website is accessible globally. If you access our website from 
          outside the Philippines, your information may be transferred to and processed in the Philippines or other countries 
          where our service providers operate.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">11. Contact Us</h2>
        <p class="text-muted-foreground leading-relaxed">
          If you have questions about this Privacy Policy or wish to exercise your rights, please contact us:
        </p>
        <div class="bg-orange-50 p-6 rounded-lg mt-4 border border-orange-100">
          <p class="text-muted-foreground mb-2"><strong>Email:</strong> privacy@smartly.sale</p>
          <p class="text-muted-foreground mb-2"><strong>Website:</strong> <a href="/contact" class="text-brand hover:underline">smartly.sale/contact</a></p>
          <p class="text-muted-foreground"><strong>Response Time:</strong> We aim to respond within 7 business days</p>
        </div>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">12. Changes to This Privacy Policy</h2>
        <p class="text-muted-foreground leading-relaxed">
          We may update this Privacy Policy from time to time. We will notify you of any significant changes by posting the new 
          Privacy Policy on this page and updating the "Last Updated" date. Your continued use of our website after changes 
          constitutes acceptance of the updated policy.
        </p>
      </section>

      <section>
        <h2 class="text-2xl font-bold text-foreground mb-4">13. Philippine Data Privacy Act Compliance</h2>
        <p class="text-muted-foreground leading-relaxed">
          We comply with the Data Privacy Act of 2012 (Republic Act No. 10173) of the Philippines. As a Filipino-based website, 
          we are committed to protecting the personal data of Philippine citizens in accordance with local laws and regulations.
        </p>
      </section>

    </div>

    <!-- Back to Home CTA -->
    <div class="mt-12 text-center">
      <a 
        href="/" 
        class="inline-block bg-brand text-white px-8 py-3 rounded-full font-bold hover:bg-brand-hover transition-colors"
      >
        Back to Homepage
      </a>
    </div>

  </div>
</MainLayout>

<style>
  .prose h2 {
    font-family: var(--heading-font);
    scroll-margin-top: 2rem;
  }
  
  .prose h3 {
    font-family: var(--heading-font);
  }
  
  .prose p, .prose li {
    font-family: var(--body-font);
  }

  .prose section {
    margin-bottom: 3rem;
  }
</style>
