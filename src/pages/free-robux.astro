---
import MainLayout from '../layouts/main.astro';
import ContentLockerGate from '../components/ContentLockerGate';
import EmailCapturePopup from '../components/EmailCapturePopup';

// ── Bot detection: show guide content directly to crawlers ───────────────────
const userAgent = Astro.request.headers.get('user-agent') ?? '';
const isBot = /googlebot|bingbot|yandexbot|twitterbot|facebookexternalhit|linkedinbot|slackbot/i.test(userAgent);

const pageTitle       = 'Free Robux 2026 — Legit & Safe Methods (No Fake Generators)';
const pageDescription = 'Looking for free Robux? Learn the legit and verified ways to get Robux for free in 2026 — no scams, no fake generators, no password required. Unlock the guide now!';
const pageUrl         = 'https://smartly.sale/free-robux';
const today           = new Date().toISOString().split('T')[0];

// ── SSR pre-fetch ──────────────────────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const runtimeEnv = (Astro.locals as any)?.runtime?.env;
  const userId = runtimeEnv?.CPABUILD_USER_ID ?? import.meta.env.CPABUILD_USER_ID ?? process.env.CPABUILD_USER_ID ?? '48201';
  const apiKey = runtimeEnv?.CPABUILD_API_KEY ?? import.meta.env.CPABUILD_API_KEY ?? process.env.CPABUILD_API_KEY ?? '';
  if (apiKey) {
    const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
    const feedUrl  = new URL('https://d2dzcaq3bhqk1m.cloudfront.net/public/offers/feed.php');
    feedUrl.searchParams.set('user_id', userId);
    feedUrl.searchParams.set('api_key', apiKey);
    feedUrl.searchParams.set('s1', 'free-robux');
    feedUrl.searchParams.set('s2', 'organic');
    const h: Record<string, string> = { 'Accept': 'application/json, */*' };
    if (clientIp) h['X-Forwarded-For'] = clientIp;
    const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
    if (res.ok) {
      const raw = JSON.parse((await res.text()).trim());
      initialOffers = Array.isArray(raw) ? raw : (raw.offers ?? raw.data ?? []);
    }
  }
} catch { /* fallback */ }

const unlockedItems = [
  {
    icon: '🏪',
    title: 'Roblox Premium Membership (Most Direct)',
    body: 'Roblox Premium gives you a monthly Robux stipend — 450 Robux/month on the base plan, up to 2,200 Robux/month on the highest tier. You also get 10% bonus Robux on purchases. This is the most official and guaranteed way to earn Robux consistently.',
  },
  {
    icon: '🎮',
    title: 'Create and Sell Your Own Items',
    body: 'If you\'re an artist or developer, create clothing, accessories, game passes, or developer products on Roblox. Every time someone buys your creation, you earn Robux directly. Skilled creators earn thousands of Robux per month — some even cash out through Developer Exchange (DevEx).',
  },
  {
    icon: '🎁',
    title: 'Roblox Gift Cards (Win Through Contests & Offers)',
    body: 'Roblox Gift Cards are available at major retailers and online. Completing the offers above pays out real cash (via PayPal, GCash, or gift cards) that can be used to buy Roblox gift card codes — effectively converting free offer earnings into Robux.',
  },
  {
    icon: '📢',
    title: 'Microsoft Rewards Program',
    body: 'Use Microsoft Edge and Bing for daily searches to earn Microsoft Reward points. These points can be redeemed for Roblox gift cards at no extra cost. Set Bing as your default search and search a few times a day — points add up quickly.',
  },
  {
    icon: '🏆',
    title: 'Roblox Affiliate Program',
    body: 'Share a Roblox game or item link — when someone clicks your link, signs up, and makes a purchase, you earn a Robux commission. This is especially powerful if you have a social media audience, YouTube channel, or Discord community.',
  },
  {
    icon: '⚠️',
    title: 'Why "Robux Generators" Never Work',
    body: 'Every "free Robux generator" online is a scam. They ask for your username, password, or personal information — then they hack your account, steal your items, or sell your data. Roblox\'s systems make it technically impossible for any third-party to add Robux to your account.',
  },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-01",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",        "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Free Robux",  "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Are there legit ways to get free Robux?",
      "acceptedAnswer": { "@type": "Answer", "text": "There are a few official ways to earn Robux without buying them directly: Roblox Premium membership (monthly stipend), creating and selling items/game passes, and the Roblox affiliate program." }
    },
    {
      "@type": "Question",
      "name": "Are free Robux generators real?",
      "acceptedAnswer": { "@type": "Answer", "text": "No. All 'free Robux generator' sites are scams. Roblox's systems make it technically impossible for any third party to add Robux to your account. Never give your Roblox password to any third-party site." }
    },
    {
      "@type": "Question",
      "name": "How much does Robux cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "400 Robux costs $4.99 USD. Roblox Premium members get 10% more Robux on every purchase plus a monthly stipend. Payment methods include credit cards, PayPal, Google Play, and App Store." }
    },
    {
      "@type": "Question",
      "name": "Can you convert Robux to real money?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — through the Roblox Developer Exchange (DevEx), developers can convert Robux into real cash. A minimum of 30,000 Robux is required, and you must be a Roblox Premium subscriber." }
    },
    {
      "@type": "Question",
      "name": "What can you do with Robux?",
      "acceptedAnswer": { "@type": "Answer", "text": "Robux can be used to buy avatar items, clothing, accessories, game passes, private servers, and developer products inside Roblox games. You can also gift Robux-purchased items to other players." }
    },
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="free Robux 2026, how to get free Robux, free Robux no scam, Robux generator fake, free Roblox Robux, Roblox Premium free Robux, Microsoft Rewards Robux"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#065f46] via-[#047857] to-[#059669] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        🟢 Legit Only — No Scam Generators — Updated {today}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Free Robux 2026 —<br class="hidden sm:block" />
        <span class="text-yellow-300">Legit Methods, No Scams</span>
      </h1>
      <p class="text-green-100 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Tired of fake Robux generators? Unlock our guide of verified, working
        ways to get Robux for free — no password required, no scams.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-green-100">
        <span>✅ 100% Scam-free methods</span>
        <span>🔒 No password needed</span>
        <span>📱 Works on any device</span>
        <span>🌏 Works worldwide</span>
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Free Robux</span>
  </nav>

  <!-- ── Intro ──────────────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">Why Are There So Many Fake "Free Robux" Sites?</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      <strong>Roblox</strong> has hundreds of millions of players worldwide and is one of the most
      popular platforms among young people. Because of this massive audience, the internet is
      flooded with "free Robux" scams — fake generators, phishing sites, and apps that harvest
      your login credentials.
    </p>
    <p class="text-gray-600 leading-relaxed mb-4">
      The truth is: <strong>there is no legit "Robux generator"</strong> that adds Robux to your
      account for free with zero effort. But there are <strong>real methods</strong> to grow your
      Robux balance — and we cover all of them in our guide below.
    </p>

    <!-- Robux pricing reference -->
    <div class="grid grid-cols-3 gap-3 mb-5">
      {[
        { robux: '400',   price: '$4.99',  label: 'Starter'  },
        { robux: '800',   price: '$9.99',  label: 'Popular'  },
        { robux: '1,700', price: '$19.99', label: 'Value'    },
      ].map(({ robux, price, label }) => (
        <div class="bg-green-50 border border-green-100 rounded-xl p-3 text-center">
          <div class="text-lg font-extrabold text-green-700">{robux}</div>
          <div class="text-xs text-green-500 font-semibold">Robux</div>
          <div class="text-xs text-gray-500 mt-1">{price}</div>
          <div class="text-xs text-gray-400">{label}</div>
        </div>
      ))}
    </div>

    <!-- Scam warning -->
    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-4">
      <p class="text-sm font-bold text-red-700 mb-2">🚨 Red Flags of Fake Robux Sites</p>
      <ul class="text-xs text-red-600 space-y-1">
        <li>❌ They ask for your Roblox password</li>
        <li>❌ Robux appear "instantly" — no verification required</li>
        <li>❌ They ask for payment before delivering Robux</li>
        <li>❌ No clear terms of service or verifiable company</li>
        <li>❌ Uses the words "hack", "exploit", or "unlimited"</li>
      </ul>
    </div>
  </article>

  <!-- ── Content Locker / Bot-visible guide ────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-10">
    {isBot ? (
      <!-- Search crawlers see the full guide directly for indexing -->
      <article class="space-y-6">
        <h2 class="text-xl font-bold text-gray-900">6 Legit Ways to Get Free Robux (2026)</h2>
        {unlockedItems.map((item) => (
          <section>
            <h3 class="text-base font-bold text-gray-800 mb-1">{item.icon} {item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
          </section>
        ))}
      </article>
    ) : (
      <ContentLockerGate
        client:visible
        initialOffers={initialOffers}
        s1="free-robux"
        s2="organic"
        accent="green"
        lockedEmoji="🟢"
        lockedLabel="Legit Free Robux Methods — 6 Working Methods (No Scam)"
        lockedDescription="Complete 1 offer to unlock our 6 legit methods for getting Robux — no generators, no scams."
        unlockedTitle="🟢 Your Legit Robux Guide is Unlocked!"
        unlockedItems={unlockedItems}
      />
    )}
  </div>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        { q: 'Are there legit ways to get free Robux?', a: 'There are a few official ways to earn Robux without buying them: Roblox Premium membership (monthly stipend), creating and selling items or game passes, and the Roblox affiliate program.' },
        { q: 'Are free Robux generators real?', a: 'No. All "free Robux generator" sites are scams. Roblox\'s systems make it technically impossible for any third party to add Robux to your account. Never give your Roblox password to any third-party site.' },
        { q: 'How much does Robux cost?', a: '400 Robux costs $4.99 USD. Roblox Premium members get 10% more Robux on every purchase plus a monthly stipend. Payment can be made via credit card, PayPal, Google Play, or the App Store.' },
        { q: 'Can you convert Robux to real money?', a: 'Yes — through the Roblox Developer Exchange (DevEx), developers can convert Robux into real cash. A minimum of 30,000 Robux is required and you must be a Premium subscriber.' },
        { q: 'What can you do with Robux?', a: 'Robux can be used to buy avatar clothing, accessories, game passes, private servers, and developer products inside Roblox games. You can also gift Robux-purchased items to friends.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="free-robux" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">More Free Rewards</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/free-imvu-credits',           label: '💜 Free IMVU Credits'   },
          { href: '/free-mlbb-diamonds',          label: '💎 Free MLBB Diamonds'  },
          { href: '/free-fire-codes',             label: '🔥 Free Fire Codes'     },
          { href: '/free-gaming-credits',         label: '🎮 Free Gaming Credits' },
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online'   },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards'     },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-green-300 hover:text-green-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
