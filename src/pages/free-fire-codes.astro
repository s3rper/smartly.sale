---
import MainLayout from '../layouts/main.astro';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Free Fire Redeem Codes Philippines Today 2026 — Working Codes + How to Redeem';
const pageDescription = 'Looking for the latest Free Fire redeem codes in the Philippines? Get our daily code list plus a step-by-step guide on how to redeem them fast before they expire.';
const pageUrl         = 'https://smartly.sale/free-fire-codes';
const today           = new Date().toISOString().split('T')[0];

const unlockedItems = [
  {
    icon: '🔥',
    title: `Where to Find Today's Active Codes (${today})`,
    body: 'Garena releases redeem codes through three main channels: (1) The official Free Fire Philippines Facebook page — codes are posted in status updates and pinned stories, usually in the morning. (2) The Free Fire official YouTube channel — codes are embedded in video thumbnails and pinned comments during live events. (3) The in-game News tab — navigate to Calendar → Newsfeed inside Free Fire for officially posted codes. Because codes typically expire within 12–18 hours, check these sources every morning and redeem immediately. Never rely on third-party websites claiming to have "today\'s codes" — most post expired codes or fabricated strings to drive traffic.',
  },
  {
    icon: '⚡',
    title: 'How to Redeem Free Fire Codes — Step-by-Step',
    body: 'Redeeming is quick: (1) Go to reward.ff.garena.com on your mobile browser or PC. (2) Log in using your Free Fire linked account — Facebook, Google, Apple, or VK. Guest accounts cannot redeem codes; you must link your account first. (3) Enter the 12-character alphanumeric code exactly as shown (codes are case-sensitive). (4) Click Confirm. The site will show a success or error message immediately. (5) Open Free Fire → go to your in-game Mailbox → collect your reward. It may take up to 24 hours to appear, but usually arrives within a few minutes.',
  },
  {
    icon: '📅',
    title: 'When Are New Codes Released?',
    body: 'Garena follows a pattern for code releases: expect new codes during every major in-game event (Clash Squad Season starts, Anniversary events, New Year, Valentine\'s, Independence Day Philippines), on BOOYAH Day (Free Fire\'s anniversary around August), during esports broadcast events on YouTube/Facebook, and at the beginning of every new season. Weekend codes are common — Garena uses them to boost engagement during peak play hours. Set a phone alarm at 9–10 AM on Fridays and Saturdays and check the official FB page first thing.',
  },
  {
    icon: '🎁',
    title: 'What Rewards Can You Get from Redeem Codes?',
    body: 'The value of redeem code rewards varies widely. Common code rewards include: Gold (in-game currency for character upgrades), weapon skins (temporary 7-day or permanent), character skin fragments, Diamond vouchers (worth 1–5 actual Diamonds each), pets and pet food, emotes, memory fragments, and special event tokens. The biggest rewards — permanent legendary skins — are only given during anniversary and major milestone events. Day-of-launch codes for new Clash Squad seasons sometimes include permanent gun skin fragments.',
  },
  {
    icon: '💡',
    title: 'Free Fire Events — The Real Diamond Source',
    body: 'In-game events give far more cumulative value than redeem codes alone. The Rampage, Anniversary, and Booyah Day events feature multi-week reward tracks with permanent skins, Diamonds, and exclusive items. Daily Missions (complete 3–5 tasks per day) build up event tokens that exchange for high-value prizes. The Rate Up Shop and Login Calendar events give a mix of permanent and limited items throughout each season. Top Free Fire Philippines players report earning 2,000–5,000 Diamonds\' worth of content per season purely through active event participation.',
  },
  {
    icon: '🏆',
    title: 'Free Fire Partner & Creator Program',
    body: 'Garena Philippines operates an active influencer and creator program. Apply through the Free Fire Partner portal if you have a TikTok, YouTube, or Facebook gaming page with at least 1,000–5,000 followers. Approved Partners receive monthly Diamond allocations, early access to new events and characters, exclusive skin bundles to give away to followers, and priority support. Even micro-creators (1k–10k followers) in the Philippines are regularly accepted. This is the most direct path to consistent free Diamond income from the game itself.',
  },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-01",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Free Fire Codes Philippines", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Where can I get legit Free Fire redeem codes?", "acceptedAnswer": { "@type": "Answer", "text": "The official sources are the Free Fire Philippines Facebook page, the official website, and in-game events. Third-party sites claiming to always have new codes are usually unreliable." } },
    { "@type": "Question", "name": "How do I redeem a Free Fire code?", "acceptedAnswer": { "@type": "Answer", "text": "Go to reward.ff.garena.com → Log in with your Free Fire account → Enter the 12-character code → Confirm → Collect in your in-game mailbox." } },
    { "@type": "Question", "name": "How long before Free Fire codes expire?", "acceptedAnswer": { "@type": "Answer", "text": "Codes typically expire within 12 to 18 hours. Redeem them as soon as you see a new code posted." } },
    { "@type": "Question", "name": "Is Free Fire free to play?", "acceptedAnswer": { "@type": "Answer", "text": "Yes, the game is free. Some premium items require Diamonds, but you can get many free items through events and redeem codes." } },
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="free fire redeem codes Philippines today, free fire codes 2026, garena free fire codes Philippines, FF redeem codes working, free fire diamonds Philippines"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#7f1d1d] via-[#b91c1c] to-[#ef4444] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        🔥 Free Fire Codes — Updated {today}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Free Fire Redeem Codes<br class="hidden sm:block" />
        <span class="text-yellow-300">Philippines — Today's List</span>
      </h1>
      <p class="text-red-100 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Our daily code list and complete redeem guide — updated every day
        with the latest working codes before they expire.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-red-100">
        <span>✅ Working codes updated daily</span>
        <span>⚡ 12-hour validity</span>
        <span>🎁 Diamonds, skins & more</span>
        <span>🔒 Safe — no password needed</span>
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Free Fire Codes Philippines</span>
  </nav>

  <!-- ── Intro ──────────────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">Why Are Free Fire Codes Always in Demand?</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      <strong>Garena Free Fire</strong> is one of the most popular mobile games in the Philippines —
      and because of this, thousands of players search for <strong>free redeem codes</strong> every day.
      These codes unlock exclusive items like weapon skins, character costumes,
      diamonds, and other premium rewards at no cost.
    </p>
    <p class="text-gray-600 leading-relaxed mb-4">
      The challenge is that <strong>codes expire fast</strong> — usually within 12 to 18 hours.
      That's why you need to stay updated and redeem them as soon as you see a new code.
      Our guide shows you how to always be first in line for the latest working codes.
    </p>

    <!-- Steps preview -->
    <div class="grid sm:grid-cols-3 gap-3 mb-6">
      {[
        { n: '1', icon: '📋', title: 'Get the Code', body: 'Find today\'s working codes in the guide below.' },
        { n: '2', icon: '📝', title: 'Copy the Code', body: 'Pick a code and copy it.' },
        { n: '3', icon: '🎁', title: 'Redeem on FF', body: 'Go to reward.ff.garena.com and enter the code.' },
      ].map(({ n, icon, title, body }) => (
        <div class="bg-red-50 border border-red-100 rounded-xl p-4 text-center">
          <div class="w-8 h-8 rounded-full bg-red-600 text-white text-sm font-bold flex items-center justify-center mx-auto mb-2">{n}</div>
          <div class="text-xl mb-1">{icon}</div>
          <p class="font-bold text-gray-900 text-xs mb-0.5">{title}</p>
          <p class="text-[11px] text-gray-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Free Fire Codes Guide ─────────────────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-10">
    <article class="space-y-6">
      <h2 class="text-xl font-bold text-gray-900">6 Legit Ways to Get Free Fire Codes & Diamonds</h2>
      {unlockedItems.map((item) => (
        <section>
          <h3 class="text-base font-bold text-gray-800 mb-1">{item.icon} {item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
        </section>
      ))}
    </article>
  </div>

  <!-- ── Free Fire Diamond Prices Philippines ─────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Free Fire Diamond Prices in the Philippines (PHP)</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-4">
      When you do buy Diamonds, always top up through <strong>Codashop</strong> or the <strong>official Garena website</strong> — not from the in-app store, which charges slightly higher platform fees.
    </p>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
        <thead>
          <tr class="bg-red-50 text-red-800">
            <th class="text-left px-4 py-3 font-bold">Diamonds</th>
            <th class="text-center px-4 py-3 font-bold">Price (PHP)</th>
            <th class="text-left px-4 py-3 font-bold">Best For</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { d: '70',   php: '₱60',   use: 'Avatar accessories, Gold Royale spins' },
            { d: '140',  php: '₱115',  use: 'Diamond Royale (1–2 spins)' },
            { d: '355',  php: '₱290',  use: 'Character abilities upgrade' },
            { d: '720',  php: '₱560',  use: 'Faded Wheel events' },
            { d: '1450', php: '₱1,100', use: 'Luck Royale skin sets' },
            { d: '2180', php: '₱1,650', use: 'Full outfit bundles or event packs' },
          ].map(({ d, php, use }) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-bold text-red-600">{d} 💎</td>
              <td class="px-4 py-3 text-center text-gray-600">{php}</td>
              <td class="px-4 py-3 text-gray-500 text-xs">{use}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 mt-3">Prices approximate as of 2026. Codashop often runs bonus Diamond promotions — check before every top-up.</p>
  </section>

  <!-- ── Free Fire vs MLBB vs Roblox ──────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Which Game Gives the Most Free Currency?</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-4">
      Filipino mobile gamers often play multiple titles. Here's a quick comparison of which platforms are most generous with free premium currency:
    </p>
    <div class="grid sm:grid-cols-3 gap-4">
      {[
        { game: 'Free Fire', rating: '★★★★☆', why: 'Frequent redeem codes + active event system. Regular Booyah Day and Anniversary events give substantial free items.', color: 'border-red-200 bg-red-50' },
        { game: 'MLBB', rating: '★★★★☆', why: 'Daily login fragments and seasonal rank rewards add up. Starlight events have a free track with real value.', color: 'border-blue-200 bg-blue-50' },
        { game: 'Roblox', rating: '★★★☆☆', why: 'No real freebie system in-game. Value comes from Microsoft Rewards externally and the Creator Program.', color: 'border-green-200 bg-green-50' },
      ].map(({ game, rating, why, color }) => (
        <div class={`border rounded-xl p-4 ${color}`}>
          <p class="font-bold text-gray-800 text-sm mb-1">{game}</p>
          <p class="text-yellow-500 text-xs mb-2">{rating}</p>
          <p class="text-xs text-gray-600 leading-relaxed">{why}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        { q: 'Where can I get legit Free Fire redeem codes?', a: 'The official sources are the Free Fire Philippines Facebook page, the official website, and in-game events. Third-party sites are usually unreliable.' },
        { q: 'How do I redeem a Free Fire code?', a: 'Go to reward.ff.garena.com → Log in → Enter the 12-character code → Confirm → Collect in your in-game mailbox.' },
        { q: 'How long before codes expire?', a: 'Codes typically expire within 12 to 18 hours. Redeem them as soon as you see a new one posted.' },
        { q: 'Is Free Fire free to play?', a: 'Yes, the game is free. Some premium items require Diamonds, but you can get many free items through events and codes.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="free-fire-codes" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">More Free Rewards</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/free-mlbb-diamonds',          label: '💎 Free MLBB Diamonds' },
          { href: '/free-gaming-credits',         label: '🎮 Free Gaming Credits' },
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/online-contests-philippines', label: '🏆 Online Contests' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-red-300 hover:text-red-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
