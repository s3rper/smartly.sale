        const lockOverlay       = document.getElementById('generator-lock-overlay');
        const generatorEl       = document.getElementById('generator');
        const sharePanel        = document.getElementById('share-unlock-panel');

        function unlockGenerator() {
          // Remove overlay and pointer-events lock
          if (lockOverlay) lockOverlay.remove();
          if (generatorEl) {
            generatorEl.classList.remove('pointer-events-none', 'select-none');
            generatorEl.removeAttribute('aria-disabled');
          }
          // Hide share panel
          if (sharePanel) sharePanel.classList.add('hidden');
        }

        if (copyBtn && shareInput) {
          copyBtn.addEventListener('click', () => {
            // Copy to clipboard
            navigator.clipboard.writeText(shareInput.value).catch(() => {
              shareInput.select();
              document.execCommand('copy');
            });

            copyBtn.textContent = 'Copied!';
            copyBtn.disabled = true;
            copyBtn.classList.add('opacity-70');

            // Show status panel
            if (inviteStatus) inviteStatus.classList.remove('hidden');

            // Random wait: 60–120 seconds
            const waitSeconds = Math.floor(Math.random() * 61) + 60; // 60–120
            let elapsed = 0;

            const tick = window.setInterval(() => {
              elapsed += 1;
              const remaining = waitSeconds - elapsed;
              const pct = Math.min((elapsed / waitSeconds) * 100, 100);

              if (inviteProgressBar) inviteProgressBar.style.width = pct + '%';

              if (remaining > 0) {
                const mins = Math.floor(remaining / 60);
                const secs = remaining % 60;
                const timeStr = mins > 0
                  ? `${mins}m ${secs.toString().padStart(2, '0')}s`
                  : `${secs}s`;
                if (inviteCountdown) inviteCountdown.textContent = timeStr;

                const phase = pct < 40 ? 'Checking IMVU chat for your invite…'
                            : pct < 75 ? 'Invite detected — verifying users…'
                            : 'Almost ready — unlocking generator…';
                if (inviteStatusText) inviteStatusText.textContent = phase;
              } else {
                window.clearInterval(tick);
                if (inviteCountdown) inviteCountdown.textContent = 'Done!';
                if (inviteStatusText) inviteStatusText.textContent = '✅ Invite verified! Generator is now unlocked.';
                if (inviteProgressBar) inviteProgressBar.style.width = '100%';
                unlockGenerator();
              }
            }, 1000);
          });
        }

        // ── Generator Logic ────────────────────────────────────────────────────
        const form = document.getElementById('imvu-generator-form');
        const progressBar = document.getElementById('generator-progress-bar');
        const progressText = document.getElementById('generator-progress-text');
        const result = document.getElementById('generator-result');
        const button = document.getElementById('generator-submit');

        if (!form || !progressBar || !progressText || !result || !button) return;

        form.addEventListener('submit', (event) => {
          event.preventDefault();

          const username = document.getElementById('generator-username');
          const credits = document.getElementById('generator-credits');

          const chosenUsername = username instanceof HTMLInputElement ? username.value.trim() : '';
          const chosenCredits = credits instanceof HTMLSelectElement ? credits.value : '99,999';

          if (!chosenUsername) {
            progressText.textContent = 'Enter an IMVU username to generate credits.';
            result.textContent = '';
            return;
          }

          let progress = 0;
          button.setAttribute('disabled', 'true');
          button.textContent = 'Generating...';
          result.textContent = '';
          progressBar.style.width = '0%';
          progressText.textContent = `Preparing credits for ${chosenUsername}...`;

          const steps = [
            `Checking username: ${chosenUsername}`,
            `Preparing ${chosenCredits} credits`,
            'Simulating secure connection',
            'Rendering credits animation',
            'Verification'
          ];

          const timer = window.setInterval(() => {
            progress += 20;
            progressBar.style.width = `${progress}%`;
            progressText.textContent = steps[Math.min((progress / 20) - 1, steps.length - 1)];

            if (progress >= 100) {
              window.clearInterval(timer);
              //result.textContent = `Credits have now added to ${chosenUsername}.`;
              result.textContent = `Please verify you are not a bot ${chosenUsername}.`;
              button.removeAttribute('disabled');
              button.textContent = 'Run Generator Again';
              _tx();
            }
          }, 500);
        });
      });
    </script>
