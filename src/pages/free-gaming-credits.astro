---
import MainLayout from '../layouts/main.astro';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Free Gaming Credits Philippines 2026 — MLBB, Free Fire, Roblox & More';
const pageDescription = 'Want free gaming credits for MLBB, Free Fire, Roblox, and other games? Read our complete guide to legit and working methods in the Philippines.';
const pageUrl         = 'https://smartly.sale/free-gaming-credits';
const today           = new Date().toISOString().split('T')[0];

const unlockedItems = [
  {
    icon: '💎',
    title: 'MLBB Diamonds — Daily Login & Events',
    body: 'Mobile Legends has one of the most generous free reward systems of any mobile game in the Philippines. Log in every day without fail to collect Starlight Fragments and event tokens, even on days you don\'t play a match. Every Season includes a free event track alongside the paid Starlight Pass — completing all free track tasks across a 2-month season typically yields enough fragments for a full skin or 100+ Diamonds. Ranked rewards at the end of each season also distribute fragments, tickets, and exclusive items based on your peak rank. MLBB is the #1 game for free diamond farming among Filipino mobile gamers.',
  },
  {
    icon: '🔥',
    title: 'Free Fire Diamonds — Redeem Codes',
    body: 'Garena releases official Free Fire redeem codes through their official Facebook page, YouTube channel, and in-game news feed. Codes expire in 12–18 hours, so check the official Free Fire Philippines Facebook page every morning. Each code typically rewards Diamond vouchers (1–5 Diamonds each), weapon skin fragments, or Gold. During major events (Anniversary, Booyah Day), codes include permanent skin fragments and larger Diamond bundles. Redeem at reward.ff.garena.com — the process takes under 2 minutes and rewards appear in your in-game mailbox within minutes.',
  },
  {
    icon: '🟢',
    title: 'Robux — Microsoft Rewards + Creator Program',
    body: 'Getting free Robux requires a different approach than MLBB or Free Fire. The most reliable external method is Microsoft Rewards: download Microsoft Edge, set Bing as your default search, and earn reward points through daily searches and quizzes. Points can be redeemed for Roblox digital gift cards at no cost. Inside the game, the Roblox Creator Program lets you design and sell items — even basic clothing templates earn Robux passively when listed in the marketplace. For players with social media presence, the Roblox Affiliate Program pays Robux commissions when new users sign up and spend through your referral links.',
  },
  {
    icon: '💰',
    title: 'The Universal Method: GCash → Codashop',
    body: 'The most flexible strategy works for any game with any premium currency. Earn GCash through legitimate reward programs — short surveys, app testing, and video-watching platforms pay out PHP 50–500+ per month to active Filipino users. Once you have GCash balance, use Codashop (codashop.com) — the leading game top-up platform in Southeast Asia — to buy credits for MLBB, Free Fire, Genshin Impact, COD Mobile, Valorant, or any other supported game. Codashop accepts GCash directly and frequently runs promo events offering bonus credits on specific packages. This approach eliminates the need to use your bank card for game purchases entirely.',
  },
  {
    icon: '🎁',
    title: 'Gift Card Contests & Online Giveaways',
    body: 'Legitimate Philippine gaming communities regularly run gift card giveaways on Facebook, Instagram, and Discord. Look for verified pages from game publishers (official MLBB PH, Garena PH, Roblox), gaming peripheral brands (SteelSeries, Razer), and reputable gaming media pages. Always verify a giveaway is legitimate before participating: real giveaways never ask for your account credentials or a "registration fee." Joining active Discord gaming servers in the Philippines is one of the best ways to find early notifications for legitimate giveaways.',
  },
  {
    icon: '📱',
    title: 'In-Game Events — Maximize Every Season',
    body: 'Every major mobile game runs 2–4 major events per season with free reward tracks. The key is consistency, not intensity. Log in every day, complete the daily 3–5 tasks, and participate in whatever mini-game the event offers. Most players leave significant free rewards uncollected simply by missing the last 2 weeks of an event. Set a phone reminder to check each game\'s event calendar weekly. For COD Mobile, the Battle Pass free track gives enough credits for cosmetics. For Genshin Impact, daily commissions and Abyss clear rewards give consistent Primogems. These small amounts compound into substantial savings over a year of active play.',
  },
];

const games = [
  { name: 'Mobile Legends', currency: 'Diamonds', icon: '💎', color: 'bg-blue-50 border-blue-200 text-blue-800' },
  { name: 'Free Fire',       currency: 'Diamonds', icon: '🔥', color: 'bg-red-50 border-red-200 text-red-800' },
  { name: 'Roblox',          currency: 'Robux',    icon: '🟢', color: 'bg-green-50 border-green-200 text-green-800' },
  { name: 'COD Mobile',      currency: 'CP',       icon: '⚔️', color: 'bg-gray-50 border-gray-200 text-gray-800' },
  { name: 'Valorant',        currency: 'VP',       icon: '🎯', color: 'bg-rose-50 border-rose-200 text-rose-800' },
  { name: 'Genshin Impact',  currency: 'Primogems',icon: '✨', color: 'bg-amber-50 border-amber-200 text-amber-800' },
];

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": pageUrl,
  "publisher": { "@type": "Organization", "name": "smartly.sale" },
  "dateModified": today
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Free Gaming Credits Philippines", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How can I get free gaming credits in the Philippines?", "acceptedAnswer": { "@type": "Answer", "text": "The most effective method is to earn GCash through online reward programs and then use GCash to top up your game. You can also get credits through in-game events and redeem codes." } },
    { "@type": "Question", "name": "Which game is easiest to get free credits for?", "acceptedAnswer": { "@type": "Answer", "text": "Mobile Legends has the longest and most generous events for free rewards in the Philippines. Free Fire is a close second due to their regular redeem code releases." } },
    { "@type": "Question", "name": "Can I use GCash for game top-ups?", "acceptedAnswer": { "@type": "Answer", "text": "Yes! GCash is accepted by Codashop, UniPin, Seagm, and official game stores. Earn GCash through reward programs and use it to top up any game." } },
    { "@type": "Question", "name": "Are reward programs safe for gaming credits?", "acceptedAnswer": { "@type": "Answer", "text": "Legitimate reward programs will never ask for your game account credentials — only your email and basic information. All offers on this page come from verified advertiser networks." } },
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="free gaming credits Philippines, free game credits Philippines 2026, free diamonds Philippines, free top up Philippines, free game currency Philippines"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(collectionSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#581c87] via-[#7c3aed] to-[#9333ea] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        🎮 All Games — Free Credits Guide — {today}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Free Gaming Credits —<br class="hidden sm:block" />
        <span class="text-yellow-300">For Every Game in Philippines 2026</span>
      </h1>
      <p class="text-purple-200 text-base sm:text-lg max-w-xl mx-auto mb-6">
        MLBB, Free Fire, Roblox, COD Mobile, and more. Our complete
        gaming credits guide — legit methods for every game.
      </p>

      <!-- Game pills -->
      <div class="flex flex-wrap justify-center gap-2">
        {games.map(({ name, icon }) => (
          <span class="inline-flex items-center gap-1.5 bg-white/10 border border-white/20 rounded-full px-3 py-1.5 text-xs font-medium text-white">
            <span>{icon}</span><span>{name}</span>
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Free Gaming Credits Philippines</span>
  </nav>

  <!-- ── Intro + Game grid ──────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">The Universal Strategy for Free Game Credits</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      No matter what game you play — MLBB, Free Fire, Roblox, COD Mobile, or Genshin Impact —
      they all use premium currency for in-game purchases. The problem is that credits run out fast,
      and direct purchases can get expensive.
    </p>
    <p class="text-gray-600 leading-relaxed mb-4">
      The best strategy is to <strong>earn GCash or gift cards</strong> through
      legit online reward programs — then use what you earn to top up your game.
      This is the most flexible approach because it works for any game.
    </p>

    <!-- Game table -->
    <div class="grid sm:grid-cols-3 gap-3 mb-6">
      {games.map(({ name, currency, icon, color }) => (
        <div class={`flex items-center gap-3 p-3 rounded-xl border ${color}`}>
          <span class="text-2xl">{icon}</span>
          <div>
            <p class="font-bold text-sm">{name}</p>
            <p class="text-xs opacity-75">{currency}</p>
          </div>
        </div>
      ))}
    </div>
  </article>

  <!-- ── Free Gaming Credits Guide ────────────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-10">
    <article class="space-y-6">
      <h2 class="text-xl font-bold text-gray-900">6 Legit Ways to Get Free Gaming Credits</h2>
      {unlockedItems.map((item) => (
        <section>
          <h3 class="text-base font-bold text-gray-800 mb-1">{item.icon} {item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
        </section>
      ))}
    </article>
  </div>

  <!-- ── Per-Game Top-Up Guide ─────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Game-by-Game Top-Up Guide for the Philippines</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-5">
      Every game has a different top-up system. Here's what you need to know for the most popular titles in the Philippines:
    </p>
    <div class="space-y-4">
      {[
        {
          game: 'Mobile Legends: Bang Bang (MLBB)',
          icon: '💎',
          currency: 'Diamonds',
          topup: 'Codashop or mobilelegends.com/topup',
          price: '₱60 = 56 Diamonds (standard). Bonus events: ₱60 = 70–84 Diamonds.',
          id: 'Profile → My Account → User ID shown below your username',
        },
        {
          game: 'Garena Free Fire',
          icon: '🔥',
          currency: 'Diamonds',
          topup: 'Codashop or garena.com/topup',
          price: '₱60 = 70 Diamonds (standard). Bonus events: ₱60 = 84–100 Diamonds.',
          id: 'Profile → Player ID shown on your avatar profile page',
        },
        {
          game: 'Roblox',
          icon: '🟢',
          currency: 'Robux',
          topup: 'Roblox.com or Codashop (gift cards)',
          price: '$4.99 = 400 Robux. Premium 450: $4.99/month + benefits.',
          id: 'Not needed — Roblox uses account login for all purchases',
        },
        {
          game: 'COD Mobile',
          icon: '⚔️',
          currency: 'COD Points (CP)',
          topup: 'Codashop or call of duty website',
          price: '₱110 = 80 CP. ₱1,100 = 900 CP. Best value at larger bundles.',
          id: 'Settings → My Profile → UID shown under your username',
        },
        {
          game: 'Genshin Impact',
          icon: '✨',
          currency: 'Genesis Crystals (converts to Primogems)',
          topup: 'genshin.hoyoverse.com/topup or Codashop',
          price: '₱75 = 60 Genesis Crystals. First top-up doubles the amount.',
          id: 'Menu → Account → My Info → UID displayed on screen',
        },
      ].map(({ game, icon, currency, topup, price, id }) => (
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xl">{icon}</span>
            <h3 class="font-bold text-gray-800 text-sm">{game}</h3>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-xs">
            <div>
              <span class="font-semibold text-gray-600">Currency:</span>
              <span class="text-gray-500 ml-1">{currency}</span>
            </div>
            <div>
              <span class="font-semibold text-gray-600">Top-up via:</span>
              <span class="text-gray-500 ml-1">{topup}</span>
            </div>
            <div class="sm:col-span-2">
              <span class="font-semibold text-gray-600">Price (PH):</span>
              <span class="text-gray-500 ml-1">{price}</span>
            </div>
            <div class="sm:col-span-2">
              <span class="font-semibold text-gray-600">Find your ID:</span>
              <span class="text-gray-500 ml-1">{id}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Top-Up Platforms Comparison ──────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">Best Game Top-Up Platforms in the Philippines</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
        <thead>
          <tr class="bg-purple-50 text-purple-800">
            <th class="text-left px-4 py-3 font-bold">Platform</th>
            <th class="text-center px-4 py-3 font-bold">GCash</th>
            <th class="text-center px-4 py-3 font-bold">Games Supported</th>
            <th class="text-left px-4 py-3 font-bold">Best For</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { platform: 'Codashop',  gcash: '✅', games: '50+', best: 'Promos & bonus credits' },
            { platform: 'UniPin',    gcash: '✅', games: '30+', best: 'Backup when Codashop is down' },
            { platform: 'Seagm',     gcash: '✅', games: '100+', best: 'Widest game selection' },
            { platform: 'In-App',    gcash: '✅', games: '1 (own)',  best: 'Convenience only (higher cost)' },
            { platform: 'GCash GameShop', gcash: '✅', games: '20+', best: 'Direct GCash integration' },
          ].map(({ platform, gcash, games, best }) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-800">{platform}</td>
              <td class="px-4 py-3 text-center">{gcash}</td>
              <td class="px-4 py-3 text-center text-gray-600">{games}</td>
              <td class="px-4 py-3 text-gray-500 text-xs">{best}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        { q: 'How can I get free gaming credits in the Philippines?', a: 'The most effective method is to earn GCash through online reward programs and then use GCash to top up your game.' },
        { q: 'Which game is easiest to get free credits for?', a: 'Mobile Legends has the longest and most generous events for free rewards in the Philippines. Free Fire is a close second due to their regular redeem code releases.' },
        { q: 'Can I use GCash for game top-ups?', a: 'Yes! GCash is accepted by Codashop, UniPin, Seagm, and official game stores.' },
        { q: 'Are reward programs safe for gaming credits?', a: 'Legitimate reward programs will never ask for your game account credentials — only your email and basic information. All offers here come from verified networks.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="free-gaming-credits" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">Game-Specific Guides</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/free-mlbb-diamonds',          label: '💎 Free MLBB Diamonds' },
          { href: '/free-fire-codes',             label: '🔥 Free Fire Codes' },
          { href: '/free-robux',      label: '🟢 Free Robux Philippines' },
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/win-free-phone',              label: '📱 Win a Free Phone' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-purple-300 hover:text-purple-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
