---
import MainLayout from '../../layouts/main.astro';
import { shopeeProducts } from '../../lib/shopee-loader';
import { transformCMSProduct } from '../../types/product';
import { baseUrl } from '../../lib/base-url';

// ── Price bracket definitions ──────────────────────────────────────────────────

interface PriceBracket {
  slug: string;
  label: string;
  maxPrice: number;
  metaTitle: string;
  metaDescription: string;
  keywords: string;
  heading: string;
  intro: string;
}

const BRACKETS: PriceBracket[] = [
  {
    slug: 'under-100',
    label: 'Under PHP 100',
    maxPrice: 100,
    metaTitle: 'Best Shopee Deals Under PHP 100 Philippines 2026 | smartly.sale',
    metaDescription: 'Discover the best Shopee products under PHP 100 in the Philippines. Affordable finds, accessories, and bargain deals — all under a hundred pesos.',
    keywords: 'shopee under 100, cheapest shopee products, budget finds philippines, shopee deals under 100 pesos',
    heading: 'Best Shopee Finds Under PHP 100',
    intro: 'Looking for affordable Shopee products that won\'t break the bank? These items are all under PHP 100 — perfect for accessories, small gadgets, and everyday essentials. We update this list daily with the latest deals.',
  },
  {
    slug: 'under-200',
    label: 'Under PHP 200',
    maxPrice: 200,
    metaTitle: 'Best Shopee Deals Under PHP 200 Philippines 2026 | smartly.sale',
    metaDescription: 'Browse the best Shopee Philippines products under PHP 200. Budget-friendly finds, gadgets, and daily essentials curated for smart Filipino shoppers.',
    keywords: 'shopee under 200, budget shopee deals, cheap products shopee philippines, shopee finds under 200',
    heading: 'Best Shopee Finds Under PHP 200',
    intro: 'Great deals don\'t have to be expensive. These Shopee products are all priced under PHP 200 — from useful accessories to trending items. Updated daily so you never miss a bargain.',
  },
  {
    slug: 'under-500',
    label: 'Under PHP 500',
    maxPrice: 500,
    metaTitle: 'Best Shopee Deals Under PHP 500 Philippines 2026 | smartly.sale',
    metaDescription: 'Top Shopee products under PHP 500 in the Philippines. Budget gadgets, fashion, home essentials, and more — curated daily for Filipino shoppers.',
    keywords: 'shopee under 500, best shopee deals under 500, budget gadgets shopee, cheap shopee finds philippines',
    heading: 'Best Shopee Finds Under PHP 500',
    intro: 'PHP 500 goes a long way on Shopee Philippines. This curated list features the best products under PHP 500 — including budget gadgets, fashion staples, home essentials, and trending finds. Refreshed daily.',
  },
  {
    slug: 'under-1000',
    label: 'Under PHP 1,000',
    maxPrice: 1000,
    metaTitle: 'Best Shopee Deals Under PHP 1,000 Philippines 2026 | smartly.sale',
    metaDescription: 'Find the best Shopee Philippines products under PHP 1,000. Quality gadgets, fashion, beauty, and home items — all under a thousand pesos.',
    keywords: 'shopee under 1000, best shopee products under 1000, shopee deals philippines, quality budget products shopee',
    heading: 'Best Shopee Finds Under PHP 1,000',
    intro: 'Under PHP 1,000, you can get surprisingly high-quality products on Shopee Philippines. From reliable gadgets to stylish fashion pieces — here are our top picks, updated daily.',
  },
  {
    slug: 'under-2000',
    label: 'Under PHP 2,000',
    maxPrice: 2000,
    metaTitle: 'Best Shopee Deals Under PHP 2,000 Philippines 2026 | smartly.sale',
    metaDescription: 'Best Shopee Philippines products under PHP 2,000. Mid-range gadgets, home appliances, fashion brands, and more — curated for value-conscious shoppers.',
    keywords: 'shopee under 2000, mid-range shopee products, shopee appliances under 2000, best value shopee philippines',
    heading: 'Best Shopee Finds Under PHP 2,000',
    intro: 'The PHP 1,000-2,000 range is the sweet spot for quality on Shopee Philippines. Expect reliable gadgets, brand-name fashion, kitchen appliances, and more. Curated and updated daily.',
  },
  {
    slug: 'under-5000',
    label: 'Under PHP 5,000',
    maxPrice: 5000,
    metaTitle: 'Best Shopee Deals Under PHP 5,000 Philippines 2026 | smartly.sale',
    metaDescription: 'Top Shopee Philippines products under PHP 5,000. Smartphones, laptops accessories, appliances, and premium finds — handpicked for Filipino shoppers.',
    keywords: 'shopee under 5000, best shopee products under 5000, budget phones shopee, shopee appliances philippines',
    heading: 'Best Shopee Finds Under PHP 5,000',
    intro: 'Under PHP 5,000, Shopee Philippines offers serious value — budget smartphones, quality earphones, home appliances, and more. Our editors pick the best items in this range, updated daily.',
  },
];

// ── Static paths ──────────────────────────────────────────────────────────────

export function getStaticPaths() {
  return BRACKETS.map(b => ({
    params: { bracket: b.slug },
    props: { bracket: b },
  }));
}

// ── Page data ─────────────────────────────────────────────────────────────────

const { bracket } = Astro.props as { bracket: PriceBracket };

/** Parse "₱1,234" → 1234 */
function parsePrice(priceStr: string | undefined): number {
  if (!priceStr) return 0;
  return Number(priceStr.replace(/[^0-9.]/g, '')) || 0;
}

const allProducts = shopeeProducts
  .filter(p => !p.fieldData._draft && !p.fieldData._archived)
  .map(p => ({ cms: p, ui: transformCMSProduct(p) }))
  .filter(({ ui }) => {
    const price = parsePrice(ui.price);
    return price > 0 && price <= bracket.maxPrice;
  })
  .sort((a, b) => parsePrice(a.ui.price) - parsePrice(b.ui.price))
  .slice(0, 48);

const canonicalUrl = `https://smartly.sale/deals/${bracket.slug}`;

// ── Structured data ───────────────────────────────────────────────────────────

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Deals", "item": "https://smartly.sale/deals" },
    { "@type": "ListItem", "position": 3, "name": bracket.label, "item": canonicalUrl },
  ]
};

const itemListSchema = allProducts.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": bracket.heading,
  "description": bracket.metaDescription,
  "url": canonicalUrl,
  "numberOfItems": allProducts.length,
  "itemListElement": allProducts.slice(0, 10).map(({ ui }, idx) => ({
    "@type": "ListItem",
    "position": idx + 1,
    "url": `https://smartly.sale/product/${ui.slug}`,
    "name": ui.name,
  })),
} : null;

---

<MainLayout
  title={bracket.metaTitle}
  description={bracket.metaDescription}
  canonicalUrl={canonicalUrl}
  keywords={bracket.keywords}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    {itemListSchema && <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />}
  </Fragment>

  <!-- Breadcrumb -->
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4 pb-2" aria-label="Breadcrumb">
    <ol class="flex items-center gap-1.5 text-sm text-muted-foreground">
      <li><a href="/" class="hover:text-brand transition-colors">Home</a></li>
      <li class="before:content-['/'] before:mx-1.5">Deals</li>
      <li class="before:content-['/'] before:mx-1.5 text-foreground font-medium">{bracket.label}</li>
    </ol>
  </nav>

  <!-- Hero -->
  <section class="py-8 bg-gradient-to-b from-brand/5 to-transparent border-b border-border">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl md:text-4xl font-bold text-foreground mb-3">{bracket.heading}</h1>
      <p class="text-muted-foreground max-w-2xl leading-relaxed">{bracket.intro}</p>
      <p class="text-sm text-muted-foreground mt-2">{allProducts.length} products found &middot; Updated daily</p>
    </div>
  </section>

  <!-- Price bracket navigation -->
  <nav class="bg-card border-b border-border sticky top-14 z-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex gap-2 overflow-x-auto no-scrollbar">
        {BRACKETS.map(b => (
          <a
            href={`/deals/${b.slug}`}
            class={`whitespace-nowrap px-4 py-2 rounded-full text-sm font-medium border transition-colors ${
              b.slug === bracket.slug
                ? 'bg-brand text-white border-brand'
                : 'bg-card text-muted-foreground border-border hover:border-brand hover:text-brand'
            }`}
          >
            {b.label}
          </a>
        ))}
      </div>
    </div>
  </nav>

  <!-- Product grid -->
  <section class="py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      {allProducts.length === 0 ? (
        <div class="text-center py-16">
          <p class="text-xl text-muted-foreground mb-4">No products found in this price range right now.</p>
          <p class="text-sm text-muted-foreground">Check back soon — we update our inventory daily.</p>
          <a href="/products" class="inline-block mt-6 px-6 py-3 bg-brand text-white rounded-xl font-semibold hover:bg-brand/90 transition-colors">Browse All Products</a>
        </div>
      ) : (
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
          {allProducts.map(({ ui }) => (
            <a href={`/product/${ui.slug}`} class="group bg-card border border-border rounded-xl overflow-hidden hover:border-brand hover:shadow-md transition-all">
              <div class="aspect-square bg-muted/30 overflow-hidden">
                {ui.images[0] ? (
                  <img
                    src={ui.images[0]}
                    alt={ui.name}
                    class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                    width="300"
                    height="300"
                  />
                ) : (
                  <div class="w-full h-full flex items-center justify-center text-muted-foreground text-4xl">📦</div>
                )}
              </div>
              <div class="p-3">
                <h3 class="text-sm font-medium text-foreground line-clamp-2 mb-2 group-hover:text-brand transition-colors">{ui.name}</h3>
                <div class="flex items-center gap-2">
                  <span class="text-brand font-bold text-lg">{ui.price}</span>
                  {ui.discount && <span class="text-xs bg-red-100 text-red-600 px-1.5 py-0.5 rounded font-medium">-{ui.discount}</span>}
                </div>
                {ui.soldText && <p class="text-xs text-muted-foreground mt-1">{ui.soldText} sold</p>}
                {ui.shopRating && <p class="text-xs text-amber-500 mt-1">{'★'.repeat(Math.round(ui.shopRating))} {ui.shopRating.toFixed(1)}</p>}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>

  <!-- Cross-links to other brackets -->
  <section class="py-10 bg-muted/20 border-t border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-foreground mb-4">Browse More Price Ranges</h2>
      <div class="grid sm:grid-cols-3 gap-3">
        {BRACKETS.filter(b => b.slug !== bracket.slug).map(b => (
          <a href={`/deals/${b.slug}`} class="group p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-sm transition-all">
            <p class="font-semibold text-foreground group-hover:text-brand transition-colors">{b.label}</p>
            <p class="text-xs text-muted-foreground mt-1">Best Shopee deals {b.label.toLowerCase()}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-10 border-t border-border">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-xl font-bold text-foreground mb-4">Frequently Asked Questions</h2>
      <div class="space-y-3">
        <details class="group bg-card border border-border rounded-xl overflow-hidden" open>
          <summary class="flex items-center px-5 py-3 cursor-pointer font-semibold text-foreground hover:text-brand transition-colors list-none text-sm">
            <span>What are the best Shopee products {bracket.label.toLowerCase()}?</span>
            <span class="text-brand text-lg shrink-0 ml-6 transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-5 pb-4 text-muted-foreground text-sm border-t border-border pt-3">
            We curate the best Shopee Philippines products {bracket.label.toLowerCase()} daily. Our picks include gadgets, fashion, home essentials, and beauty items — all verified to be in stock and highly rated by real buyers.
          </div>
        </details>
        <details class="group bg-card border border-border rounded-xl overflow-hidden">
          <summary class="flex items-center px-5 py-3 cursor-pointer font-semibold text-foreground hover:text-brand transition-colors list-none text-sm">
            <span>Are Shopee products {bracket.label.toLowerCase()} worth buying?</span>
            <span class="text-brand text-lg shrink-0 ml-6 transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-5 pb-4 text-muted-foreground text-sm border-t border-border pt-3">
            Yes! Many Shopee Philippines products {bracket.label.toLowerCase()} offer excellent value. We recommend checking seller ratings (4.7+ stars), reading reviews with photos, and buying from Shopee Mall sellers when possible.
          </div>
        </details>
        <details class="group bg-card border border-border rounded-xl overflow-hidden">
          <summary class="flex items-center px-5 py-3 cursor-pointer font-semibold text-foreground hover:text-brand transition-colors list-none text-sm">
            <span>How often is this deals page updated?</span>
            <span class="text-brand text-lg shrink-0 ml-6 transition-transform group-open:rotate-45">+</span>
          </summary>
          <div class="px-5 pb-4 text-muted-foreground text-sm border-t border-border pt-3">
            This page is updated daily with fresh product data from Shopee Philippines. Prices and availability may change — click through to Shopee for the latest pricing.
          </div>
        </details>
      </div>
    </div>
  </section>

  <!-- Internal links for SEO -->
  <section class="py-8 bg-card border-t border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="text-sm text-muted-foreground mb-3">Explore more on smartly.sale</p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/products" class="text-sm text-brand hover:underline">All Products</a>
        <a href="/best-deals" class="text-sm text-brand hover:underline">Best Deals</a>
        <a href="/categories" class="text-sm text-brand hover:underline">Categories</a>
        <a href="/blog" class="text-sm text-brand hover:underline">Blog & Guides</a>
        <a href="/earn-gcash" class="text-sm text-brand hover:underline">Earn GCash</a>
        <a href="/shopee-sales-2026" class="text-sm text-brand hover:underline">Shopee Sale Calendar</a>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
