---
import MainLayout from '../layouts/main.astro';

const pageTitle = "Shopee Free Hidden Voucher Reveal Tool - Unlock Secret Discounts 2025";
const pageDescription = "Discover hidden Shopee vouchers, flash deals, and secret discounts! Use our free voucher reveal tool to maximize savings and find P20-P200 vouchers before you shop.";
const ogImage = "https://cdn.prod.website-files.com/662c296bd4d3a8028c713c69/691e8c7794ae6bf5912f6ad7_11329060.png";

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Shopee Hidden Voucher Reveal Tool",
  "applicationCategory": "UtilityApplication",
  "description": "Interactive tool to discover hidden Shopee vouchers, flash deals, and secret discounts in the Philippines",
  "operatingSystem": "All",
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "PHP"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.8",
    "reviewCount": "1247"
  }
};
---

<MainLayout 
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
>
  <!-- Schema.org structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="bonus-page">
    <!-- Hero Section -->
    <section class="hero-section">
      <div class="container">
        <div class="hero-content">
          <h1 class="hero-title">
            Shopee Free Hidden<br/>Voucher Reveal Tool
          </h1>
          <p class="hero-subtitle">
            Unlock secret vouchers and maximize your savings before you shop!
          </p>
          <div class="stats-row">
            <div class="stat-item">
              <span class="stat-number">12,847</span>
              <span class="stat-label">Vouchers Revealed</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">P2.4M</span>
              <span class="stat-label">Total Saved</span>
            </div>
            <div class="stat-item">
              <span class="stat-number">Today</span>
              <span class="stat-label">Last Updated</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Voucher Reveal Tool -->
    <section class="reveal-section">
      <div class="container">
        <div class="reveal-box">
          <div class="mystery-box" id="mysteryBox">
            <div class="box-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12"></polyline>
                <rect x="2" y="7" width="20" height="5"></rect>
                <line x1="12" y1="22" x2="12" y2="7"></line>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
            </div>
            <h2 class="box-title">Mystery Voucher Box</h2>
            <p class="box-subtitle">Click to reveal your hidden savings!</p>
          </div>

          <button class="reveal-button" id="revealButton">
            <span class="button-text">REVEAL VOUCHERS</span>
            <span class="button-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
              </svg>
            </span>
          </button>

          <div class="result-card" id="resultCard">
            <div class="confetti-container" id="confettiContainer"></div>
            <div class="result-content">
              <div class="result-icon" id="resultIcon">
                <svg xmlns="http://www.w3.org/2000/svg" width="60" height="60" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path>
                  <line x1="7" y1="7" x2="7.01" y2="7"></line>
                </svg>
              </div>
              <h3 class="result-title" id="resultTitle">Amazing Find!</h3>
              <p class="result-description" id="resultDescription">You've unlocked something special!</p>
              <div class="result-value" id="resultValue">P50 OFF</div>
              <a href="https://shopee.ph" target="_blank" rel="noopener noreferrer" class="claim-button">
                Claim on Shopee
              </a>
              <button class="reveal-again-button" id="revealAgain">
                Reveal Another
              </button>
            </div>
          </div>
        </div>

        <!-- How It Works -->
        <div class="info-box">
          <h3>What is this tool?</h3>
          <p>
            This tool helps Shopee buyers discover hidden savings and maximize their vouchers. 
            Each reveal shows you different types of vouchers and deals available on Shopee, 
            helping you save more before checking out!
          </p>
        </div>
      </div>
    </section>

    <!-- Voucher Types Grid -->
    <section class="voucher-types-section">
      <div class="container">
        <h2 class="section-title">What You Can Discover</h2>
        <div class="voucher-types-grid">
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon>
              </svg>
            </div>
            <h3>Flash Vouchers</h3>
            <p>Limited-time deals with huge discounts</p>
          </div>
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12"></polyline>
                <rect x="2" y="7" width="20" height="5"></rect>
                <line x1="12" y1="22" x2="12" y2="7"></line>
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
              </svg>
            </div>
            <h3>Surprise Vouchers</h3>
            <p>P20-P200 random discount codes</p>
          </div>
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8"></path>
                <path d="M12 18V6"></path>
              </svg>
            </div>
            <h3>Collectible Coins</h3>
            <p>Shopee coins for future purchases</p>
          </div>
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M8 14s1.5 2 4 2 4-2 4-2"></path>
                <line x1="9" y1="9" x2="9.01" y2="9"></line>
                <line x1="15" y1="9" x2="15.01" y2="9"></line>
              </svg>
            </div>
            <h3>Hidden Discounts</h3>
            <p>Secret seller vouchers</p>
          </div>
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
                <polyline points="9 22 9 12 15 12 15 22"></polyline>
              </svg>
            </div>
            <h3>Mall Vouchers</h3>
            <p>Exclusive mall store discounts</p>
          </div>
          <div class="voucher-type-card">
            <div class="type-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <h3>Expiring Soon</h3>
            <p>Urgent deals ending today</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Shopee Saver Tips -->
    <section class="tips-section">
      <div class="container">
        <h2 class="section-title">Pro Shopee Saver Tips</h2>
        <div class="tips-grid">
          <div class="tip-card">
            <div class="tip-number">1</div>
            <h3>Stack Your Vouchers</h3>
            <p>Combine store vouchers with platform vouchers for maximum savings</p>
          </div>
          <div class="tip-card">
            <div class="tip-number">2</div>
            <h3>Check Flash Deals</h3>
            <p>Shop during 12PM and 12AM for the best flash deal prices</p>
          </div>
          <div class="tip-card">
            <div class="tip-number">3</div>
            <h3>Collect Daily Coins</h3>
            <p>Open the app daily to collect free coins and exchange for vouchers</p>
          </div>
          <div class="tip-card">
            <div class="tip-number">4</div>
            <h3>Follow Favorite Shops</h3>
            <p>Get notified of exclusive follower-only vouchers</p>
          </div>
          <div class="tip-card">
            <div class="tip-number">5</div>
            <h3>Use Free Shipping</h3>
            <p>Look for free shipping vouchers to save on delivery costs</p>
          </div>
          <div class="tip-card">
            <div class="tip-number">6</div>
            <h3>Compare Prices</h3>
            <p>Check multiple sellers and calculate with vouchers for best deals</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          <div class="faq-item">
            <h3>How does this voucher reveal tool work?</h3>
            <p>
              Our tool simulates the excitement of discovering hidden Shopee vouchers! 
              Each reveal shows you different types of vouchers and deals available on Shopee. 
              While the reveal is randomized for fun, it educates you about real voucher types 
              you can find and use on Shopee Philippines.
            </p>
          </div>
          <div class="faq-item">
            <h3>Are these real vouchers I can use?</h3>
            <p>
              This is an educational tool that shows you the types of vouchers available on Shopee. 
              To get actual voucher codes, click "Claim on Shopee" to visit the official Shopee app 
              or website where you can collect real vouchers, coins, and participate in ongoing promotions.
            </p>
          </div>
          <div class="faq-item">
            <h3>How can I maximize my Shopee savings?</h3>
            <p>
              Check the Shopee app daily for flash sales, collect coins, stack multiple vouchers, 
              and shop during peak sale hours (12PM and 12AM). Follow your favorite stores for 
              exclusive follower vouchers and always check for free shipping codes!
            </p>
          </div>
          <div class="faq-item">
            <h3>When is the best time to shop on Shopee?</h3>
            <p>
              The best times are during mega sales (9.9, 10.10, 11.11, 12.12), flash deal hours 
              (12PM and 12AM daily), and when using stacked vouchers. Also check for special 
              payday sales and mid-month promotions!
            </p>
          </div>
          <div class="faq-item">
            <h3>Can I use multiple vouchers at once?</h3>
            <p>
              Yes! Shopee allows you to stack different types of vouchers. You can typically 
              combine one platform voucher, one shop voucher, one free shipping voucher, and 
              use your Shopee coins in a single transaction for maximum savings!
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="container">
        <div class="cta-box">
          <h2>Ready to Save More?</h2>
          <p>Head to Shopee now and start collecting your vouchers!</p>
          <a href="https://shopee.ph" target="_blank" rel="noopener noreferrer" class="cta-button">
            Shop on Shopee Now
          </a>
        </div>
      </div>
    </section>
  </div>

  <style>
    .bonus-page {
      min-height: 100vh;
      background: linear-gradient(135deg, #fff5f0 0%, #ffffff 100%);
    }

    .container {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
    }

    /* Hero Section */
    .hero-section {
      padding: 60px 20px 40px;
      text-align: center;
      background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
      color: white;
    }

    .hero-title {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
      line-height: 1.2;
      text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.1);
    }

    .hero-subtitle {
      font-size: 1.25rem;
      margin-bottom: 2rem;
      opacity: 0.95;
    }

    .stats-row {
      display: flex;
      justify-content: center;
      gap: 2rem;
      flex-wrap: wrap;
    }

    .stat-item {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .stat-number {
      font-size: 1.75rem;
      font-weight: 700;
    }

    .stat-label {
      font-size: 0.875rem;
      opacity: 0.9;
    }

    /* Reveal Section */
    .reveal-section {
      padding: 60px 20px;
    }

    .reveal-box {
      max-width: 600px;
      margin: 0 auto;
      text-align: center;
    }

    .mystery-box {
      background: white;
      border-radius: 24px;
      padding: 3rem 2rem;
      box-shadow: 0 10px 40px rgba(255, 107, 53, 0.15);
      margin-bottom: 2rem;
      transition: all 0.3s ease;
    }

    .mystery-box.shake {
      animation: shake 0.5s ease-in-out;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-10px) rotate(-5deg); }
      75% { transform: translateX(10px) rotate(5deg); }
    }

    .box-icon {
      margin-bottom: 1rem;
      animation: float 3s ease-in-out infinite;
      color: #ff6b35;
    }

    .box-icon svg {
      width: 80px;
      height: 80px;
      display: inline-block;
    }

    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    .box-title {
      font-size: 2rem;
      font-weight: 700;
      color: #ff6b35;
      margin-bottom: 0.5rem;
    }

    .box-subtitle {
      color: #666;
      font-size: 1.125rem;
    }

    .reveal-button {
      background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
      color: white;
      border: none;
      padding: 1.5rem 3rem;
      border-radius: 50px;
      font-size: 1.5rem;
      font-weight: 700;
      cursor: pointer;
      box-shadow: 0 10px 30px rgba(255, 107, 53, 0.3);
      transition: all 0.3s ease;
      display: inline-flex;
      align-items: center;
      gap: 0.75rem;
      position: relative;
      overflow: hidden;
    }

    .reveal-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
    }

    .reveal-button:active {
      transform: translateY(0);
    }

    .reveal-button.spinning {
      animation: spin 1s ease-in-out;
    }

    @keyframes spin {
      0% { transform: rotate(0deg) scale(1); }
      50% { transform: rotate(180deg) scale(1.1); }
      100% { transform: rotate(360deg) scale(1); }
    }

    .button-icon {
      display: flex;
      align-items: center;
      animation: sparkle 1.5s ease-in-out infinite;
    }

    .button-icon svg {
      width: 24px;
      height: 24px;
    }

    @keyframes sparkle {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.2); }
    }

    /* Result Card */
    .result-card {
      display: none;
      background: white;
      border-radius: 24px;
      padding: 3rem 2rem;
      box-shadow: 0 20px 60px rgba(255, 107, 53, 0.2);
      margin-top: 2rem;
      position: relative;
      overflow: hidden;
      animation: slideUp 0.5s ease-out;
    }

    .result-card.show {
      display: block;
    }

    @keyframes slideUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .confetti-container {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      pointer-events: none;
      overflow: hidden;
    }

    .confetti {
      position: absolute;
      width: 10px;
      height: 10px;
      background: #ff6b35;
      animation: confetti-fall 3s ease-out forwards;
    }

    @keyframes confetti-fall {
      to {
        transform: translateY(100vh) rotate(360deg);
        opacity: 0;
      }
    }

    .result-content {
      position: relative;
      z-index: 1;
    }

    .result-icon {
      margin-bottom: 1rem;
      animation: bounce 0.6s ease-out;
      color: #ff6b35;
      display: flex;
      justify-content: center;
    }

    .result-icon svg {
      width: 60px;
      height: 60px;
    }

    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }

    .result-title {
      font-size: 2rem;
      font-weight: 700;
      color: #ff6b35;
      margin-bottom: 0.5rem;
    }

    .result-description {
      color: #666;
      font-size: 1.125rem;
      margin-bottom: 1.5rem;
    }

    .result-value {
      font-size: 3rem;
      font-weight: 800;
      color: #ff6b35;
      margin-bottom: 2rem;
      text-shadow: 2px 2px 4px rgba(255, 107, 53, 0.2);
    }

    .claim-button {
      display: inline-block;
      background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
      color: white;
      padding: 1rem 2.5rem;
      border-radius: 50px;
      font-size: 1.25rem;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 10px 30px rgba(255, 107, 53, 0.3);
      transition: all 0.3s ease;
      margin-bottom: 1rem;
    }

    .claim-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 40px rgba(255, 107, 53, 0.4);
    }

    .reveal-again-button {
      display: block;
      margin: 1rem auto 0;
      background: white;
      color: #ff6b35;
      border: 2px solid #ff6b35;
      padding: 0.75rem 2rem;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .reveal-again-button:hover {
      background: #ff6b35;
      color: white;
    }

    .info-box {
      background: linear-gradient(135deg, #fff9f5 0%, #ffe9db 100%);
      border-radius: 16px;
      padding: 2rem;
      margin-top: 3rem;
      border-left: 4px solid #ff6b35;
    }

    .info-box h3 {
      color: #ff6b35;
      font-size: 1.5rem;
      margin-bottom: 1rem;
    }

    .info-box p {
      color: #555;
      line-height: 1.8;
    }

    /* Voucher Types Section */
    .voucher-types-section {
      padding: 60px 20px;
      background: white;
    }

    .section-title {
      text-align: center;
      font-size: 2.5rem;
      font-weight: 700;
      color: #333;
      margin-bottom: 3rem;
    }

    .voucher-types-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2rem;
    }

    .voucher-type-card {
      background: linear-gradient(135deg, #fff9f5 0%, #ffffff 100%);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
      transition: all 0.3s ease;
      border: 2px solid transparent;
    }

    .voucher-type-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(255, 107, 53, 0.15);
      border-color: #ff6b35;
    }

    .type-icon {
      margin-bottom: 1rem;
      color: #ff6b35;
      display: flex;
      justify-content: center;
    }

    .type-icon svg {
      width: 48px;
      height: 48px;
    }

    .voucher-type-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #ff6b35;
      margin-bottom: 0.5rem;
    }

    .voucher-type-card p {
      color: #666;
      line-height: 1.6;
    }

    /* Tips Section */
    .tips-section {
      padding: 60px 20px;
      background: linear-gradient(135deg, #fff5f0 0%, #ffffff 100%);
    }

    .tips-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 2rem;
    }

    .tip-card {
      background: white;
      border-radius: 16px;
      padding: 2rem;
      box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
      transition: all 0.3s ease;
      border-left: 4px solid #ff6b35;
    }

    .tip-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 30px rgba(255, 107, 53, 0.15);
    }

    .tip-number {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
      color: white;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      font-size: 1.25rem;
      font-weight: 700;
      margin-bottom: 1rem;
    }

    .tip-card h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #333;
      margin-bottom: 0.75rem;
    }

    .tip-card p {
      color: #666;
      line-height: 1.6;
    }

    /* FAQ Section */
    .faq-section {
      padding: 60px 20px;
      background: white;
    }

    .faq-list {
      max-width: 800px;
      margin: 0 auto;
    }

    .faq-item {
      background: linear-gradient(135deg, #fff9f5 0%, #ffffff 100%);
      border-radius: 16px;
      padding: 2rem;
      margin-bottom: 1.5rem;
      border-left: 4px solid #ff6b35;
    }

    .faq-item h3 {
      font-size: 1.25rem;
      font-weight: 700;
      color: #ff6b35;
      margin-bottom: 1rem;
    }

    .faq-item p {
      color: #555;
      line-height: 1.8;
    }

    /* CTA Section */
    .cta-section {
      padding: 80px 20px;
      background: linear-gradient(135deg, #ff6b35 0%, #ff8c42 100%);
      text-align: center;
      color: white;
    }

    .cta-box h2 {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 1rem;
    }

    .cta-box p {
      font-size: 1.25rem;
      margin-bottom: 2rem;
      opacity: 0.95;
    }

    .cta-button {
      display: inline-block;
      background: white;
      color: #ff6b35;
      padding: 1.25rem 3rem;
      border-radius: 50px;
      font-size: 1.5rem;
      font-weight: 700;
      text-decoration: none;
      box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
      transition: all 0.3s ease;
    }

    .cta-button:hover {
      transform: translateY(-3px);
      box-shadow: 0 15px 40px rgba(0, 0, 0, 0.3);
    }

    /* Mobile Responsive */
    @media (max-width: 768px) {
      .hero-title {
        font-size: 2rem;
      }

      .hero-subtitle {
        font-size: 1rem;
      }

      .stats-row {
        gap: 1rem;
      }

      .stat-number {
        font-size: 1.5rem;
      }

      .box-icon svg {
        width: 60px;
        height: 60px;
      }

      .box-title {
        font-size: 1.5rem;
      }

      .reveal-button {
        padding: 1.25rem 2rem;
        font-size: 1.25rem;
      }

      .result-title {
        font-size: 1.5rem;
      }

      .result-value {
        font-size: 2.5rem;
      }

      .section-title {
        font-size: 2rem;
      }

      .voucher-types-grid,
      .tips-grid {
        grid-template-columns: 1fr;
      }

      .cta-box h2 {
        font-size: 2rem;
      }

      .cta-button {
        font-size: 1.25rem;
        padding: 1rem 2rem;
      }
    }
  </style>

  <script>
    const vouchers = [
      {
        title: 'Flash Voucher Unlocked!',
        description: 'Limited-time flash deal',
        value: 'P100 OFF',
        minSpend: 'Min spend P500'
      },
      {
        title: 'Surprise Voucher!',
        description: 'Random discount code',
        value: 'P50 OFF',
        minSpend: 'Min spend P300'
      },
      {
        title: 'Collectible Coins!',
        description: 'Free Shopee coins',
        value: '200 COINS',
        minSpend: 'Use on any purchase'
      },
      {
        title: 'Hidden Discount!',
        description: 'Secret seller voucher',
        value: 'P75 OFF',
        minSpend: 'Min spend P400'
      },
      {
        title: 'Mall Voucher!',
        description: 'Exclusive mall store discount',
        value: 'P150 OFF',
        minSpend: 'Min spend P800'
      },
      {
        title: 'Expiring Soon!',
        description: 'Urgent deal ending today',
        value: 'P200 OFF',
        minSpend: 'Min spend P1000'
      },
      {
        title: 'Free Shipping!',
        description: 'No delivery fees',
        value: 'FREE SHIP',
        minSpend: 'No minimum spend'
      },
      {
        title: 'Birthday Bonus!',
        description: 'Special birthday voucher',
        value: 'P120 OFF',
        minSpend: 'Min spend P600'
      }
    ];

    function createConfetti() {
      const container = document.getElementById('confettiContainer');
      if (!container) return;

      container.innerHTML = '';
      
      const colors = ['#ff6b35', '#ff8c42', '#ffd93d', '#6bcf7f', '#4d9de0'];
      
      for (let i = 0; i < 50; i++) {
        const confetti = document.createElement('div');
        confetti.className = 'confetti';
        confetti.style.left = Math.random() * 100 + '%';
        confetti.style.backgroundColor = colors[Math.floor(Math.random() * colors.length)];
        confetti.style.animationDelay = Math.random() * 0.5 + 's';
        confetti.style.animationDuration = (Math.random() * 2 + 2) + 's';
        container.appendChild(confetti);
      }
    }

    function revealVoucher() {
      const button = document.getElementById('revealButton');
      const mysteryBox = document.getElementById('mysteryBox');
      const resultCard = document.getElementById('resultCard');
      const resultTitle = document.getElementById('resultTitle');
      const resultDescription = document.getElementById('resultDescription');
      const resultValue = document.getElementById('resultValue');

      if (!button || !mysteryBox || !resultCard) return;

      // Add spinning animation to button
      button.classList.add('spinning');
      mysteryBox.classList.add('shake');

      // Random voucher
      const randomVoucher = vouchers[Math.floor(Math.random() * vouchers.length)];

      setTimeout(() => {
        button.classList.remove('spinning');
        mysteryBox.classList.remove('shake');
        
        // Update result card
        if (resultTitle) resultTitle.textContent = randomVoucher.title;
        if (resultDescription) resultDescription.textContent = randomVoucher.description + ' - ' + randomVoucher.minSpend;
        if (resultValue) resultValue.textContent = randomVoucher.value;
        
        // Show result
        resultCard.classList.add('show');
        
        // Create confetti
        createConfetti();

        // Track event
        if (typeof window !== 'undefined' && window.dataLayer) {
          window.dataLayer.push({
            event: 'voucher_revealed',
            voucher_type: randomVoucher.title,
            voucher_value: randomVoucher.value
          });
        }

        // Scroll to result
        resultCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }, 1000);
    }

    function revealAgain() {
      const resultCard = document.getElementById('resultCard');
      if (resultCard) {
        resultCard.classList.remove('show');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', () => {
      const revealButton = document.getElementById('revealButton');
      const revealAgainButton = document.getElementById('revealAgain');

      if (revealButton) {
        revealButton.addEventListener('click', revealVoucher);
      }

      if (revealAgainButton) {
        revealAgainButton.addEventListener('click', revealAgain);
      }
    });
  </script>
</MainLayout>
