---
import MainLayout from '../layouts/main.astro';
import ContentLockerGate from '../components/ContentLockerGate';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Free MLBB Diamonds Philippines 2026 — Legit Diamond Farming Guide';

// ── Bot detection: show guide content directly to crawlers ───────────────────
const userAgent = Astro.request.headers.get('user-agent') ?? '';
const isBot = /googlebot|bingbot|yandexbot|twitterbot|facebookexternalhit|linkedinbot|slackbot/i.test(userAgent);

const pageDescription = 'Want free MLBB diamonds? Unlock our complete Diamond Farming Guide — complete 1 offer and start using these proven, legit methods today!';
const pageUrl         = 'https://smartly.sale/free-mlbb-diamonds';
const today           = new Date().toISOString().split('T')[0];

// ── SSR pre-fetch ──────────────────────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const runtimeEnv = (Astro.locals as any)?.runtime?.env;
  const userId = runtimeEnv?.CPABUILD_USER_ID ?? import.meta.env.CPABUILD_USER_ID ?? process.env.CPABUILD_USER_ID ?? '48201';
  const apiKey = runtimeEnv?.CPABUILD_API_KEY ?? import.meta.env.CPABUILD_API_KEY ?? process.env.CPABUILD_API_KEY ?? '';
  if (apiKey) {
    const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
    const feedUrl  = new URL('https://d2dzcaq3bhqk1m.cloudfront.net/public/offers/feed.php');
    feedUrl.searchParams.set('user_id', userId);
    feedUrl.searchParams.set('api_key', apiKey);
    feedUrl.searchParams.set('s1', 'mlbb-diamonds');
    feedUrl.searchParams.set('s2', 'organic');
    const h: Record<string, string> = { 'Accept': 'application/json, */*' };
    if (clientIp) h['X-Forwarded-For'] = clientIp;
    const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
    if (res.ok) {
      const raw = JSON.parse((await res.text()).trim());
      initialOffers = Array.isArray(raw) ? raw : (raw.offers ?? raw.data ?? []);
    }
  }
} catch { /* fallback to client-side */ }

const unlockedItems = [
  { icon: '💎', title: 'Daily Login Bonuses', body: 'Log in every day to collect free Starlight Fragments and Diamonds on the ML Events page. There are always new events handing out free rewards.' },
  { icon: '🎮', title: 'Elite Pass & Starlight Events', body: 'Every new Season comes with mini-games and challenges that reward Diamond fragments — complete them all to maximize your earnings.' },
  { icon: '🏆', title: 'Ranked Mode Rewards', body: 'Climb the ranks for seasonal rewards including Fragments, Tickets, and sometimes Diamond Credits. The higher your rank, the bigger the reward.' },
  { icon: '📱', title: 'Moonton Exclusive Surveys', body: 'Moonton sends survey invites to registered emails. Complete them for exclusive in-game items and occasionally Diamonds.' },
  { icon: '🎁', title: 'Friend Referral System', body: 'Invite friends to MLBB using your referral code. When they reach a certain rank, you receive Diamond vouchers as a reward.' },
  { icon: '⚡', title: 'Third-Party Reward Programs', body: 'Platforms that pay out GCash or gift cards (like the offers above) can be converted into MLBB Diamonds through the in-game top-up using GCash.' },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-01",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Free MLBB Diamonds", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Are there legit ways to get free MLBB Diamonds?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — through daily login bonuses, seasonal events, ranked rewards, and reward platforms that pay out GCash which can be converted into a Diamond top-up." } },
    { "@type": "Question", "name": "Are third-party diamond sites safe?", "acceptedAnswer": { "@type": "Answer", "text": "Not all of them. Many are scams. The safest methods are official Moonton events and legitimate reward platforms that pay GCash — they never ask for your account credentials." } },
    { "@type": "Question", "name": "How much does 1 MLBB Diamond cost?", "acceptedAnswer": { "@type": "Answer", "text": "Approximately PHP 0.80 to PHP 1.00 per Diamond when topping up on the official platform. 257 Diamonds costs around PHP 250." } },
    { "@type": "Question", "name": "How do I top up MLBB with GCash?", "acceptedAnswer": { "@type": "Answer", "text": "Go to the official Moonton website or Codashop.com → select MLBB → enter your Game ID → choose the diamond amount → pay with GCash." } },
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="free MLBB diamonds Philippines, free mobile legends diamonds, how to get free diamonds in MLBB, MLBB diamond farming guide 2026, free mobile legends Philippines"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#1a1463] via-[#2c1f7a] to-[#4a1fa8] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        💎 MLBB Diamond Farming Guide — Updated {today}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        How to Get Free<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-cyan-300">
          MLBB Diamonds in 2026
        </span>
      </h1>
      <p class="text-blue-200 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Unlock our complete diamond farming guide — complete 1 offer below
        to access all the legit methods for getting free diamonds.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-blue-200">
        <span>✅ No account hacking</span>
        <span>💎 100% Legit methods</span>
        <span>📱 Mobile-friendly</span>
        <span>🔒 Safe & verified</span>
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Free MLBB Diamonds Philippines</span>
  </nav>

  <!-- ── Intro ──────────────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">Can You Actually Get Free Diamonds in MLBB?</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      One of the most searched questions among Mobile Legends players in the Philippines —
      <strong>how do you get free diamonds?</strong> The answer is yes, there are legitimate ways,
      but you need to know where to look and which methods actually work.
    </p>
    <p class="text-gray-600 leading-relaxed mb-4">
      Our complete guide covers <strong>6 proven methods</strong> — from official Moonton events
      to reward platforms that pay out <strong>GCash credits</strong> you can convert into a
      diamond top-up. No account hacking, no scams — all 100% safe and legal.
    </p>

    <!-- Warning box -->
    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
      <p class="text-sm font-bold text-red-700 mb-2">⚠️ Avoid Diamond Generator Sites</p>
      <p class="text-xs text-red-600 leading-relaxed">
        There are many fake "diamond generator" sites online — all of them are scams. They ask for
        your username and password to "hack" your account. Never give your credentials to
        third-party sites. Only use the methods listed in this guide.
      </p>
    </div>
  </article>

  <!-- ── Content Locker / Bot-visible guide ────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-10">
    {isBot ? (
      <article class="space-y-6">
        <h2 class="text-xl font-bold text-gray-900">6 Legit Ways to Get Free MLBB Diamonds</h2>
        {unlockedItems.map((item) => (
          <section>
            <h3 class="text-base font-bold text-gray-800 mb-1">{item.icon} {item.title}</h3>
            <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
          </section>
        ))}
      </article>
    ) : (
      <ContentLockerGate
        client:visible
        initialOffers={initialOffers}
        s1="mlbb-diamonds"
        s2="organic"
        accent="blue"
        lockedEmoji="💎"
        lockedLabel="Free MLBB Diamond Farming Guide (6 Methods)"
        lockedDescription="Complete 1 offer to unlock our full guide — 100% legit, no account hacking required."
        unlockedTitle="💎 Your Diamond Farming Guide is Unlocked!"
        unlockedItems={unlockedItems}
      />
    )}
  </div>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        { q: 'Are there legit ways to get free MLBB Diamonds?', a: 'Yes — through daily login bonuses, seasonal events, ranked rewards, and reward platforms that pay out GCash which can be converted into a Diamond top-up.' },
        { q: 'Are third-party diamond sites safe?', a: 'Not all of them. Many are scams. The safest methods are official Moonton events and legitimate reward platforms that pay GCash — they never ask for your account credentials.' },
        { q: 'How much does 1 MLBB Diamond cost?', a: 'Approximately PHP 0.80 to PHP 1.00 per Diamond when topping up on the official platform. 257 Diamonds costs around PHP 250.' },
        { q: 'How do I top up MLBB with GCash?', a: 'Go to the official Moonton website or Codashop.com → select MLBB → enter your Game ID → choose the diamond amount → pay with GCash.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="mlbb-diamonds" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">More Free Rewards</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/free-fire-codes',             label: '🔥 Free Fire Codes' },
          { href: '/free-gaming-credits',         label: '🎮 Free Gaming Credits' },
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/win-free-phone',              label: '📱 Win a Free Phone' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
