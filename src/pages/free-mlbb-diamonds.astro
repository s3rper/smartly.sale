---
import MainLayout from '../layouts/main.astro';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Free MLBB Diamonds Philippines 2026 — Legit Diamond Farming Guide';
const pageDescription = 'Want free MLBB diamonds? Read our complete Diamond Farming Guide — proven, legit methods to earn diamonds in Mobile Legends without spending money.';
const pageUrl         = 'https://smartly.sale/free-mlbb-diamonds';
const today           = new Date().toISOString().split('T')[0];

const unlockedItems = [
  {
    icon: '💎',
    title: 'Daily Login Bonuses',
    body: 'Mobile Legends rewards consistent players generously. Log in every single day — even if you don\'t play a match — to collect your daily login streak bonus. After 7 consecutive days, the rewards scale up significantly, including Starlight Fragments and occasionally direct Diamonds or vouchers. On the Events tab, there are always active mini-campaigns that reward Diamond fragments for simple tasks like watching a skin preview, sharing to Facebook, or completing a training mission. These tiny fragments accumulate faster than you\'d expect — many players collect enough for a full skin over a single season without spending anything.',
  },
  {
    icon: '🎮',
    title: 'Starlight & Elite Pass Events',
    body: 'Each MLBB Season (roughly every 1–2 months) comes with a free event track alongside the paid Starlight Pass. The free track has enough rewards to earn substantial fragment and item prizes if you complete the daily missions consistently. The paid Starlight Pass costs Diamonds but often pays back more than its cost in exclusive skins and fragments. If you\'re grinding the free track diligently — completing all tasks, participating in all sub-events — you can accumulate enough fragments to redeem for permanent skins and Diamond vouchers over 2–3 seasons.',
  },
  {
    icon: '🏆',
    title: 'Ranked Mode Seasonal Rewards',
    body: 'Every season, MLBB distributes rewards based on your final rank before the season resets. Reaching Grandmaster or higher unlocks skin fragments and ticket rewards. Epic and Legend rank players receive exclusive Recall Effects and sometimes Diamond vouchers. Even at lower ranks (Elite, Master), you receive enough Ticket fragments to exchange for items in the Fragment Shop. The key is to play ranked consistently during the season rather than rushing at the end — the rewards scale with your peak rank achieved during the season, not just your end rank.',
  },
  {
    icon: '📱',
    title: 'Moonton Surveys & Beta Testing',
    body: 'Moonton actively recruits their player base for feedback. Players who have linked their email to their Moonton account regularly receive survey invitations — typically 5–10 minutes to complete. Completed surveys reward exclusive avatar frames, Starlight Fragments, and occasionally Diamond vouchers. Moonton also runs beta testing programs for new heroes and features: beta testers receive early access rewards and sometimes significant Diamond bonuses for filing bug reports.',
  },
  {
    icon: '🎁',
    title: 'Referral Program — Invite Friends',
    body: 'MLBB\'s referral program is underutilized by most players. Share your unique referral code (found under your Profile → Invite Friends) with people who haven\'t played MLBB before. When a new player uses your code, creates an account, and reaches a specific rank milestone (usually Warrior Rank III), you receive a Diamond voucher reward. The more friends you refer who actually play and rank up, the more Diamond vouchers you accumulate. Focus on referring friends who are genuinely interested in MOBAs — a friend who plays consistently through Gold or Epic is far more valuable than one who quits after 2 games.',
  },
  {
    icon: '⚡',
    title: 'Earn GCash → Top Up via Codashop',
    body: 'This is the most flexible method and works for any amount. Legitimate reward programs pay out real GCash to Filipino users. Once you have GCash loaded up — even just PHP 50–100 — you can top up MLBB Diamonds directly through Codashop (codashop.com) which accepts GCash payments. Codashop frequently runs promo events where you get bonus Diamonds on specific top-up amounts. For example, a PHP 110 top-up might get you 257 Diamonds normally, but during a promo, you might get 300–350 for the same amount. Check Codashop\'s promotions tab before every top-up.',
  },
];

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-01",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Free MLBB Diamonds", "item": pageUrl }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "Are there legit ways to get free MLBB Diamonds?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — through daily login bonuses, seasonal events, ranked rewards, and reward platforms that pay out GCash which can be converted into a Diamond top-up." } },
    { "@type": "Question", "name": "Are third-party diamond sites safe?", "acceptedAnswer": { "@type": "Answer", "text": "Not all of them. Many are scams. The safest methods are official Moonton events and legitimate reward platforms that pay GCash — they never ask for your account credentials." } },
    { "@type": "Question", "name": "How much does 1 MLBB Diamond cost?", "acceptedAnswer": { "@type": "Answer", "text": "Approximately PHP 0.80 to PHP 1.00 per Diamond when topping up on the official platform. 257 Diamonds costs around PHP 250." } },
    { "@type": "Question", "name": "How do I top up MLBB with GCash?", "acceptedAnswer": { "@type": "Answer", "text": "Go to the official Moonton website or Codashop.com → select MLBB → enter your Game ID → choose the diamond amount → pay with GCash." } },
  ]
};
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  keywords="free MLBB diamonds Philippines, free mobile legends diamonds, how to get free diamonds in MLBB, MLBB diamond farming guide 2026, free mobile legends Philippines"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#1a1463] via-[#2c1f7a] to-[#4a1fa8] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/15 border border-white/25 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        💎 MLBB Diamond Farming Guide — Updated {today}
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        How to Get Free<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-300 to-cyan-300">
          MLBB Diamonds in 2026
        </span>
      </h1>
      <p class="text-blue-200 text-base sm:text-lg max-w-xl mx-auto mb-6">
        Our complete diamond farming guide — all legit, proven methods
        for getting free diamonds in Mobile Legends.
      </p>
      <div class="flex flex-wrap justify-center gap-4 text-sm text-blue-200">
        <span>✅ No account hacking</span>
        <span>💎 100% Legit methods</span>
        <span>📱 Mobile-friendly</span>
        <span>🔒 Safe & verified</span>
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Free MLBB Diamonds Philippines</span>
  </nav>

  <!-- ── Intro ──────────────────────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-6">
    <h2 class="text-xl font-bold text-gray-900 mt-4 mb-3">Can You Actually Get Free Diamonds in MLBB?</h2>
    <p class="text-gray-600 leading-relaxed mb-4">
      One of the most searched questions among Mobile Legends players in the Philippines —
      <strong>how do you get free diamonds?</strong> The answer is yes, there are legitimate ways,
      but you need to know where to look and which methods actually work.
    </p>
    <p class="text-gray-600 leading-relaxed mb-4">
      Our complete guide covers <strong>6 proven methods</strong> — from official Moonton events
      to reward platforms that pay out <strong>GCash credits</strong> you can convert into a
      diamond top-up. No account hacking, no scams — all 100% safe and legal.
    </p>

    <!-- Warning box -->
    <div class="bg-red-50 border border-red-200 rounded-xl p-4 mb-6">
      <p class="text-sm font-bold text-red-700 mb-2">⚠️ Avoid Diamond Generator Sites</p>
      <p class="text-xs text-red-600 leading-relaxed">
        There are many fake "diamond generator" sites online — all of them are scams. They ask for
        your username and password to "hack" your account. Never give your credentials to
        third-party sites. Only use the methods listed in this guide.
      </p>
    </div>
  </article>

  <!-- ── MLBB Diamond Farming Guide ───────────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-10">
    <article class="space-y-6">
      <h2 class="text-xl font-bold text-gray-900">6 Legit Ways to Get Free MLBB Diamonds</h2>
      {unlockedItems.map((item) => (
        <section>
          <h3 class="text-base font-bold text-gray-800 mb-1">{item.icon} {item.title}</h3>
          <p class="text-sm text-gray-600 leading-relaxed">{item.body}</p>
        </section>
      ))}
    </article>
  </div>

  <!-- ── MLBB Diamond Top-Up Guide PH ─────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">How to Top Up MLBB Diamonds in the Philippines</h2>
    <p class="text-sm text-gray-600 leading-relaxed mb-5">
      When you do decide to top up, here are the best methods for Filipino players — with prices and step-by-step instructions:
    </p>
    <div class="space-y-4">
      {[
        {
          method: 'Codashop (Best Value + Promos)',
          steps: 'Go to codashop.com → Select Mobile Legends → Enter your Game ID and Server ID (found under your ML profile) → Choose Diamond amount → Pay with GCash. Codashop frequently runs bonus Diamond promos.',
          badge: 'Recommended',
          badgeColor: 'bg-blue-100 text-blue-700',
        },
        {
          method: 'Official Moonton Website',
          steps: 'Visit mobilelegends.com/topup → Log in with your Moonton account → Select amount → Pay with credit card, PayPal, or GCash. Prices are identical to the in-game store.',
          badge: 'Official',
          badgeColor: 'bg-green-100 text-green-700',
        },
        {
          method: 'In-App Purchase (Direct)',
          steps: 'Open MLBB → Shop → Diamonds → Select amount → Pay via Google Play / App Store (GCash or credit card linked to your account). Slightly higher cost due to platform fees.',
          badge: 'Convenient',
          badgeColor: 'bg-purple-100 text-purple-700',
        },
        {
          method: 'UniPin / Seagm',
          steps: 'Create an account at unipin.com → Select MLBB → Enter your Game ID → Choose Diamond package → Pay with GCash or bank transfer. Good alternative when Codashop promos are not active.',
          badge: 'Alternative',
          badgeColor: 'bg-gray-100 text-gray-700',
        },
      ].map(({ method, steps, badge, badgeColor }) => (
        <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
          <div class="flex items-center gap-2 mb-2">
            <span class="font-bold text-gray-800 text-sm">{method}</span>
            <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${badgeColor}`}>{badge}</span>
          </div>
          <p class="text-xs text-gray-600 leading-relaxed">{steps}</p>
        </div>
      ))}
    </div>

    <div class="mt-5 bg-blue-50 border border-blue-200 rounded-xl p-4">
      <p class="text-sm font-bold text-blue-800 mb-1">💡 Pro Tip: Always Check for Promo Events</p>
      <p class="text-xs text-blue-700 leading-relaxed">
        Moonton and Codashop both run regular Diamond bonus events — often tied to MLBB anniversaries, major esports events (MPL Philippines), or seasonal milestones. Wait for a 2x Diamond event before your biggest top-up to get maximum value. These events are announced on the official MLBB Philippines Facebook page.
      </p>
    </div>
  </section>

  <!-- ── MLBB Diamond Pricing Reference ────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-10">
    <h2 class="text-xl font-bold text-gray-900 mb-4">MLBB Diamond Prices in the Philippines (PHP)</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border border-gray-200 rounded-xl overflow-hidden">
        <thead>
          <tr class="bg-blue-50 text-blue-800">
            <th class="text-left px-4 py-3 font-bold">Diamonds</th>
            <th class="text-center px-4 py-3 font-bold">Price (PHP)</th>
            <th class="text-center px-4 py-3 font-bold">Cost per Diamond</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { diamonds: '11',   price: '₱15',   cpp: '~₱1.36' },
            { diamonds: '56',   price: '₱60',   cpp: '~₱1.07' },
            { diamonds: '110',  price: '₱110',  cpp: '~₱1.00' },
            { diamonds: '220',  price: '₱220',  cpp: '~₱1.00' },
            { diamonds: '570',  price: '₱550',  cpp: '~₱0.96' },
            { diamonds: '1170', price: '₱1,100', cpp: '~₱0.94' },
          ].map(({ diamonds, price, cpp }) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-bold text-blue-700">{diamonds} 💎</td>
              <td class="px-4 py-3 text-center text-gray-600">{price}</td>
              <td class="px-4 py-3 text-center text-gray-500 text-xs">{cpp}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-xs text-gray-400 mt-3">Prices approximate as of 2026. Top up through Codashop for the best rates and bonus Diamond promos.</p>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Frequently Asked Questions</h2>
    <div class="space-y-4">
      {[
        { q: 'Are there legit ways to get free MLBB Diamonds?', a: 'Yes — through daily login bonuses, seasonal events, ranked rewards, and reward platforms that pay out GCash which can be converted into a Diamond top-up.' },
        { q: 'Are third-party diamond sites safe?', a: 'Not all of them. Many are scams. The safest methods are official Moonton events and legitimate reward platforms that pay GCash — they never ask for your account credentials.' },
        { q: 'How much does 1 MLBB Diamond cost?', a: 'Approximately PHP 0.80 to PHP 1.00 per Diamond when topping up on the official platform. 257 Diamonds costs around PHP 250.' },
        { q: 'How do I top up MLBB with GCash?', a: 'Go to the official Moonton website or Codashop.com → select MLBB → enter your Game ID → choose the diamond amount → pay with GCash.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="mlbb-diamonds" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-8 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">More Free Rewards</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/free-fire-codes',             label: '🔥 Free Fire Codes' },
          { href: '/free-gaming-credits',         label: '🎮 Free Gaming Credits' },
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/win-free-phone',              label: '📱 Win a Free Phone' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
