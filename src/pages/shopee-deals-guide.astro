      <h2 class="text-2xl font-bold text-foreground text-center mb-3">Shop by Budget</h2>
      <p class="text-sm text-muted-foreground text-center mb-8">Find the best Shopee deals for every price range — updated daily</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
        {[
          { href: '/deals/under-100',  label: 'Under PHP 100',   emoji: '🪙', desc: 'Accessories, tools, small items' },
          { href: '/deals/under-200',  label: 'Under PHP 200',   emoji: '💰', desc: 'Phone cases, organizers' },
          { href: '/deals/under-500',  label: 'Under PHP 500',   emoji: '🔥', desc: 'Earbuds, kitchen gadgets' },
          { href: '/deals/under-1000', label: 'Under PHP 1,000', emoji: '⭐', desc: 'Smart watches, appliances' },
          { href: '/deals/under-2000', label: 'Under PHP 2,000', emoji: '💎', desc: 'Tablets, air fryers' },
          { href: '/deals/under-5000', label: 'Under PHP 5,000', emoji: '🏆', desc: 'Smartphones, laptops' },
        ].map(({ href, label, emoji, desc }) => (
          <a href={href} class="flex flex-col items-center gap-2 p-4 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
