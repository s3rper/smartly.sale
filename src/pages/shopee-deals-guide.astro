      </div>
    </div>
  </section>

  <!-- How We Pick Deals — E-E-A-T Section -->
  <section class="py-10 bg-white border-b border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-foreground mb-4">How We Pick Deals</h2>
      <p class="text-muted-foreground mb-6">Our team manually reviews Shopee products every day. We don't just list random items. Here's our process:</p>
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {[
          { step: '1', title: 'Verify Sellers', desc: 'We check seller ratings, badges, and review authenticity before recommending any product.' },
          { step: '2', title: 'Compare Prices', desc: 'We compare prices across sellers and track price history to ensure you get genuine discounts.' },
          { step: '3', title: 'Read Real Reviews', desc: 'We analyze buyer reviews with photos to verify product quality and accurate descriptions.' },
          { step: '4', title: 'Test Value', desc: 'We evaluate cost-per-use and durability to recommend items that deliver real value for money.' },
        ].map(({ step, title, desc }) => (
          <div class="p-4 bg-muted/30 rounded-xl border border-border">
            <div class="w-8 h-8 bg-brand text-white rounded-full flex items-center justify-center text-sm font-bold mb-3">{step}</div>
            <p class="font-semibold text-foreground mb-1">{title}</p>
            <p class="text-sm text-muted-foreground">{desc}</p>
          </div>
        ))}
