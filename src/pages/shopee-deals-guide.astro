    </div>
  </section>

  <!-- Sale Calendar CTA -->
  <section class="py-12 bg-gradient-to-b from-orange-50 to-white">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl font-bold text-foreground mb-3">Never Miss a Shopee Sale</h2>
      <p class="text-muted-foreground mb-6">Check the complete schedule of every Shopee sale event in 2026</p>
      <a href="/shopee-sales-2026" class="inline-flex items-center px-6 py-3 bg-brand text-white rounded-full font-semibold hover:bg-orange-700 transition-colors">
