      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {[
          { href: '/blog/shopee-6-6-mid-year-sale-2026-best-deals-guide', title: 'Shopee 6.6 Mid-Year Sale Guide 2026', desc: 'Best deals, voucher codes & flash sale schedules for June 2026' },
          { href: '/blog/best-budget-phones-under-5000-shopee-philippines-2026', title: 'Best Phones Under PHP 5,000', desc: 'Top budget smartphones compared — Xiaomi, realme, Samsung' },
          { href: '/blog/shopee-free-voucher-discount-codes-2025', title: 'Shopee Free Voucher & Discount Codes', desc: 'Updated daily with working promo codes and exclusive deals' },
          { href: '/blog/shopee-hidden-vouchers-secret-codes', title: 'Hidden Vouchers & Secret Codes', desc: 'Find vouchers most shoppers miss and save big on every purchase' },
          { href: '/blog/shopee-free-shipping-voucher-guide', title: 'Free Shipping Voucher Guide', desc: 'Never pay for delivery again with these proven methods' },
          { href: '/blog/smart-shopee-shopping-hacks-philippines', title: 'Smart Shopee Shopping Hacks', desc: 'Maximize vouchers, get free shipping, and save on every checkout' },
          { href: '/blog/shopee-quality-check-guide-before-buying', title: 'Product Quality Check Guide', desc: 'Verify quality and avoid scams before you buy' },
