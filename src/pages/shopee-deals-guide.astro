      <div class="flex flex-wrap justify-center gap-3">
        <a href="#categories" class="px-5 py-2.5 bg-brand text-white rounded-full text-sm font-semibold hover:bg-orange-700 transition-colors">Browse by Category</a>
        <a href="#budget" class="px-5 py-2.5 bg-white border border-border text-foreground rounded-full text-sm font-semibold hover:border-brand transition-colors">Shop by Budget</a>
