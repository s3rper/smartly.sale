          <details class="group bg-card border border-border rounded-xl overflow-hidden" open={i === 0}>
            <summary class="flex items-center px-6 py-5 cursor-pointer font-semibold text-foreground hover:text-brand transition-colors list-none">
              <span class="flex-1">{faq.q}</span>
              <span class="text-brand text-xl shrink-0 ml-6 transition-transform group-open:rotate-45">+</span>
