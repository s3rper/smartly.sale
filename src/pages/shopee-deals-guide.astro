---
import MainLayout from '../layouts/main.astro';
import { blogPosts } from '../lib/blog-data';

const pageTitle = "Complete Shopee Deals Guide Philippines 2026 — Best Deals, Vouchers & Shopping Tips";
const pageDescription = "Your ultimate guide to Shopee Philippines deals in 2026. Find the best products, voucher codes, flash sale schedules, shopping tips, and budget-friendly picks across all categories.";
const pageKeywords = "Shopee deals guide 2026, best Shopee deals Philippines, Shopee voucher codes, Shopee shopping tips, Shopee sale schedule, budget shopping Shopee PH";

// Get shopping-related blog posts for the topic cluster links
const shoppingPosts = blogPosts.filter(p => {
  const cat = p.category?.toLowerCase() ?? '';
  return cat.includes('deal') || cat.includes('shopping') || cat.includes('buying')
    || cat.includes('product-review') || cat.includes('budget') || cat.includes('fashion')
    || cat.includes('home') || cat.includes('beauty') || cat.includes('kitchen')
    || cat.includes('tech-gadget') || cat.includes('local');
}).slice(0, 12);

const pillarSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": "https://smartly.sale/shopee-deals-guide",
  "mainEntity": {
    "@type": "Article",
    "headline": "Complete Shopee Deals Guide Philippines 2026",
    "author": { "@type": "Organization", "name": "smartly.sale" },
    "publisher": {
      "@type": "Organization",
      "name": "smartly.sale",
      "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" }
    },
    "datePublished": "2026-06-05",
    "dateModified": new Date().toISOString().split('T')[0]
  }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Shopee Deals Guide", "item": "https://smartly.sale/shopee-deals-guide" }
  ]
};

const faqs = [
  {
    q: "How do I find the best deals on Shopee Philippines?",
    a: "Use smartly.sale to browse curated deals by category and budget. Collect vouchers early, stack shop + platform + free shipping vouchers, and shop during flash sale windows (12AM, 12PM, 6PM, 9PM) on sale days. Enable ShopeePay for extra cashback."
  },
  {
    q: "When are the biggest Shopee sales in 2026?",
    a: "The biggest Shopee Philippines sales in 2026 are: 3.3 Mega Shopping Day, 4.4 Summer Sale, 5.5 Brands Festival, 6.6 Mid-Year Sale, 7.7 Lucky Sale, 8.8 Mega Flash Sale, 9.9 Super Shopping Day, 10.10 Brands Festival, 11.11 Big Sale, and 12.12 Birthday Sale. Payday sales also run on the 15th and 30th of each month."
  },
  {
    q: "How can I tell if a Shopee product is legit or fake?",
    a: "Check the seller's Star Seller or Preferred Seller badge, read verified buyer reviews with photos, compare prices across multiple sellers, look for Shopee Mall products (official brand stores), and check the return/refund policy. Avoid deals that seem too good to be true."
  },
  {
    q: "What is voucher stacking on Shopee?",
    a: "Voucher stacking means applying multiple discount codes on a single order: a shop voucher (from the seller), a platform voucher (from Shopee), and a free shipping voucher. This can save you 30-50% on your total order. Collect all three types before checkout."
  },
  {
    q: "Paano mag-ipon gamit ang Shopee? (How to save money on Shopee?)",
    a: "Mag-collect ng vouchers bago mag-sale, gamitin ang ShopeePay para sa extra cashback, mag-add to cart bago mag-flash sale, at mag-compare ng prices sa iba't ibang sellers. Mag-check din ng smartly.sale para sa curated deals at budget guides."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

function jsonLd(obj: unknown): string {
  return JSON.stringify(obj)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  ogImage="https://smartly.sale/og-image.jpg"
  canonicalUrl="https://smartly.sale/shopee-deals-guide"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(pillarSchema)} />
    <script type="application/ld+json" set:html={jsonLd(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={jsonLd(faqSchema)} />
    <meta name="keywords" content={pageKeywords} />
  </Fragment>

  <!-- Breadcrumb -->
  <div class="bg-muted/50 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href="/" class="hover:text-brand transition-colors">Home</a>
        <span class="text-border">/</span>
        <span class="text-foreground font-medium">Shopee Deals Guide 2026</span>
      </nav>
    </div>
  </div>

  <!-- Hero -->
  <section class="py-12 md:py-16 bg-gradient-to-b from-orange-50 to-white border-b border-border">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-foreground mb-4">
        Complete Shopee Deals Guide Philippines 2026
