        <a href="/online-contests-philippines" class="group rounded-2xl border border-purple-200 hover:border-purple-400 bg-card p-6 transition-all hover:-translate-y-0.5 hover:shadow-md">
          <p class="font-bold text-foreground mb-2 group-hover:text-brand transition-colors">Online Contests PH</p>
