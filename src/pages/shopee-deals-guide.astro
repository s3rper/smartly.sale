    </div>
  </section>

  <!-- Shop by Category — Topic Cluster Hub -->
  <section id="categories" class="py-12 bg-muted/20 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-foreground text-center mb-3">Shop by Category</h2>
      <p class="text-sm text-muted-foreground text-center mb-8">Browse curated Shopee deals across all major product categories</p>
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
        <a href="/category/gadgets" class="flex flex-col items-center gap-2 p-5 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
          <span class="text-3xl">📱</span>
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Gadgets & Tech</span>
          <span class="text-xs text-muted-foreground">Phones, earbuds, power banks</span>
        </a>
        <a href="/category/home-living" class="flex flex-col items-center gap-2 p-5 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
          <span class="text-3xl">🏠</span>
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Home & Living</span>
          <span class="text-xs text-muted-foreground">Fans, kitchen, organizers</span>
        </a>
        <a href="/category/fashion" class="flex flex-col items-center gap-2 p-5 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
          <span class="text-3xl">👗</span>
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Fashion</span>
          <span class="text-xs text-muted-foreground">Bags, shoes, clothes</span>
        </a>
        <a href="/category/beauty" class="flex flex-col items-center gap-2 p-5 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
          <span class="text-3xl">💄</span>
          <span class="text-sm font-semibold text-foreground group-hover:text-brand transition-colors">Beauty & Health</span>
          <span class="text-xs text-muted-foreground">Skincare, makeup, wellness</span>
        </a>
        <a href="/category/sports-outdoor" class="flex flex-col items-center gap-2 p-5 bg-card border border-border rounded-xl hover:border-brand hover:shadow-md transition-all text-center group">
