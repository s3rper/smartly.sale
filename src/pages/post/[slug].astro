---
import MainLayout from '../../layouts/main.astro';
import PostContent from '../../components/PostContent';
import { blogPosts } from '../../lib/blog-data';

// SSR dynamic route — works for both hardcoded and auto-generated posts
const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

// Genuinely missing post → 404 (not a redirect, which Google treats as a soft-404).
if (!post) {
  return new Response(null, { status: 404, statusText: 'Not Found' });
}

// Canonical-namespace enforcement: hardcoded posts live at /blog/<slug>.
// Permanently redirect so the two route namespaces never index the same content.
if (!(post as any).generated) {
  return Astro.redirect(`/blog/${post.slug}`, 301);
}

const pageTitle = post.metaTitle || `${post.title} - smartly.sale`;
const pageDescription = post.metaDescription || post.excerpt;
const canonicalUrl = `https://smartly.sale/post/${post.slug}`;
const keywords = post.keywords?.join(', ') || undefined;

// Noindex thin generated posts to protect site from Google's Helpful Content penalty
const wordCount = (post as any).wordCount ?? 0;
const isGenerated = (post as any).generated === true;
const shouldNoindex = isGenerated && wordCount < 600;

// Safely serialize JSON for embedding in <script> tags.
// JSON.stringify alone doesn't escape < > & — the browser HTML parser can
// truncate the block on closing-script-tag or other sequences, producing invalid JSON.
function jsonLd(obj: unknown): string {
  return JSON.stringify(obj)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.metaDescription || post.excerpt,
  "image": post.featuredImage,
  "url": canonicalUrl,
  "datePublished": post.publishDate,
  "dateModified": (post as any).modifiedDate || post.publishDate,
  "author": {
    "@type": "Person",
    "name": post.author,
    "url": "https://smartly.sale/about"
  },
  "publisher": { "@id": "https://smartly.sale/#organization" },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": canonicalUrl
  },
  "isPartOf": { "@id": "https://smartly.sale/#website" },
  "inLanguage": "en-PH",
  ...((post as any).wordCount && { "wordCount": (post as any).wordCount }),
  ...(post.readTime && { "timeRequired": `PT${post.readTime}M` })
};

const breadcrumbData = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://smartly.sale/blog" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": canonicalUrl }
  ]
};

// FAQPage schema — generated posts ship a `faqs` array rendered by PostContent.
const faqs = (post as any).faqs as { q: string; a: string }[] | undefined;
const faqSchema = (faqs && faqs.length > 0) ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a },
  })),
} : null;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={post.featuredImage}
  keywords={keywords}
  canonicalUrl={canonicalUrl}
  noindex={shouldNoindex}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(articleSchema)} />
    <script type="application/ld+json" set:html={jsonLd(breadcrumbData)} />
    {faqSchema && <script type="application/ld+json" set:html={jsonLd(faqSchema)} />}
    <meta property="article:published_time" content={post.publishDate} />
    <meta property="article:author" content={post.author} />
    <meta property="article:section" content={post.category} />
    {post.tags?.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <PostContent client:load post={post} />
</MainLayout>
