---
import MainLayout from '../layouts/main.astro';
import CPAOffersWall from '../components/CPAOffersWall';
import EmailCapturePopup from '../components/EmailCapturePopup';

const pageTitle       = 'Win a Free Phone in the Philippines 2026 — Legit iPhone & Samsung Giveaways';
const pageDescription = 'Looking for a free phone Philippines? Discover legitimate online prize draws for iPhone 17 Pro, Samsung S25, and more. Libre sumali — claim your entry now!';
const pageUrl         = 'https://smartly.sale/win-free-phone';
const today           = new Date().toISOString().split('T')[0];

// ── SSR pre-fetch ─────────────────────────────────────────────────────────────
let initialOffers: unknown[] = [];
try {
  const clientIp = Astro.request.headers.get('x-forwarded-for')?.split(',')[0]?.trim() || '';
  const feedUrl  = new URL('https://www.cpagrip.com/common/offer_feed_json.php');
  feedUrl.searchParams.set('user_id', '1392970');
  feedUrl.searchParams.set('pubkey', 'a5202038591dd63f9d0dc5e21ca96ecb');
  feedUrl.searchParams.set('tracking_id', 'win-free-phone');
  const h: Record<string, string> = { 'Accept': 'application/json, */*' };
  if (clientIp) h['X-Forwarded-For'] = clientIp;
  const res = await fetch(feedUrl.toString(), { headers: h, signal: AbortSignal.timeout(8_000) });
  if (res.ok) {
    const raw = JSON.parse((await res.text()).trim());
    initialOffers = Array.isArray(raw) ? raw : [];
  }
} catch { /* fallback to client-side */ }

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": pageTitle,
  "description": pageDescription,
  "image": "https://smartly.sale/og-image.jpg",
  "author": { "@type": "Organization", "name": "smartly.sale" },
  "publisher": { "@type": "Organization", "name": "smartly.sale", "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" } },
  "datePublished": "2026-01-15",
  "dateModified": today,
  "mainEntityOfPage": { "@type": "WebPage", "@id": pageUrl }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",          "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Win Free Phone", "item": pageUrl }
  ]
};

const phones = [
  { name: 'iPhone 17 Pro', emoji: '📱', price: '₱80,000+', img: '📱' },
  { name: 'Samsung Galaxy S25', emoji: '📲', price: '₱55,000+', img: '📲' },
  { name: 'Samsung A55', emoji: '📳', price: '₱22,000+', img: '📳' },
];
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonicalUrl={pageUrl}
  ogType="article"
  keywords="win free phone Philippines, libreng cellphone Philippines, iPhone giveaway Philippines, Samsung giveaway Philippines, win iPhone 17 pro, free smartphone Philippines 2026"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <meta property="article:published_time" content="2026-01-15" />
    <meta property="article:modified_time" content={today} />
    <meta property="article:section" content="Giveaways" />
    <meta property="article:tag" content="win free phone Philippines" />
    <meta property="article:tag" content="iPhone giveaway" />
    <meta property="article:tag" content="Samsung giveaway" />
  </Fragment>

  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-[#0f3460] text-white py-14 px-4">
    <div class="max-w-3xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 bg-white/10 border border-white/20 rounded-full px-4 py-1.5 text-xs font-semibold tracking-wide mb-5 uppercase">
        📱 Active Giveaways — Limited Slots
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-4">
        Win a Free Phone<br class="hidden sm:block" />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-blue-300">
          Legit Online Giveaways Philippines 2026
        </span>
      </h1>
      <p class="text-blue-200 text-base sm:text-lg max-w-xl mx-auto mb-8">
        Mayroon kang pagkakataong manalo ng brand-new smartphone — libre at walang bayad.
        Piliin ang iyong gusto at i-claim na ang iyong entry.
      </p>

      <!-- Active phone prizes -->
      <div class="flex flex-wrap justify-center gap-3">
        {phones.map(({ name, price }) => (
          <div class="bg-white/10 border border-white/20 rounded-2xl px-5 py-3 text-center backdrop-blur-sm">
            <p class="font-bold text-white text-sm">{name}</p>
            <p class="text-xs text-blue-200 mt-0.5">Retail value {price}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── Breadcrumb ─────────────────────────────────────────────────────────── -->
  <nav class="max-w-3xl mx-auto px-4 py-3 text-xs text-gray-400" aria-label="Breadcrumb">
    <a href="/" class="hover:text-gray-600">Home</a>
    <span class="mx-2">›</span>
    <span class="text-gray-700 font-medium">Win Free Phone Philippines</span>
  </nav>

  <!-- ── Educational Content ───────────────────────────────────────────────── -->
  <article class="max-w-3xl mx-auto px-4 pb-8">
    <h2 class="text-xl font-bold text-gray-900 mt-8 mb-4">Totoo Ba Ang Libreng Cellphone Online?</h2>
    <p class="text-gray-600 leading-relaxed mb-5">
      Ito ang tanong ng marami. Ang sagot ay <strong>oo — posible</strong>, pero kailangan mong malaman kung saan
      hahanapin ang mga legit na giveaway. Karamihan ng mga prize draws na ito ay ginagamit ng mga companies
      bilang <strong>marketing campaign</strong>. Binibigyan ka nila ng pagkakataong manalo ng premium gadget
      kapalit ng iyong participation — tulad ng pag-fill ng form o pagsali sa draw.
    </p>
    <p class="text-gray-600 leading-relaxed mb-5">
      Ang mga smartphone brands at tech companies ay regular na nag-o-organisa ng mga online prize draws para
      ma-promote ang kanilang mga produkto. Sa pamamagitan ng mga verified advertiser networks, maaari kang
      direktang sumali sa mga aktibong giveaway na available sa iyong rehiyon — <strong>libre at walang catch</strong>.
    </p>

    <!-- Red flags -->
    <div class="bg-red-50 border border-red-200 rounded-2xl p-6 mb-8">
      <h3 class="font-bold text-red-700 text-sm mb-4 flex items-center gap-2">
        <span>🚨</span> Mga Palatandaan ng Scam — Iwasan Ito!
      </h3>
      <ul class="space-y-2 text-sm text-red-600">
        <li class="flex items-start gap-2"><span>❌</span> Nagrereklamo ng bayad para ma-claim ang premyo</li>
        <li class="flex items-start gap-2"><span>❌</span> Hinahanap ang iyong bank account number o PIN</li>
        <li class="flex items-start gap-2"><span>❌</span> Nagre-require ng "processing fee" bago ipadala ang phone</li>
        <li class="flex items-start gap-2"><span>❌</span> Walang malinaw na mechanics o terms and conditions</li>
      </ul>
    </div>
  </article>

  <!-- ── Phone Comparison Table ─────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 py-8">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Mga Smartphone na Maaari Mong Manalo</h2>
    <div class="overflow-x-auto mb-5">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="bg-gray-100 text-gray-700">
            <th class="text-left px-4 py-3 rounded-tl-xl">Phone Model</th>
            <th class="text-left px-4 py-3">Retail Price</th>
            <th class="text-left px-4 py-3">Key Specs</th>
            <th class="text-left px-4 py-3 rounded-tr-xl">Availability</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {[
            { model: 'iPhone 17 Pro', price: '₱80,000+', specs: 'A19 chip, 48MP camera, 6.3"', avail: 'Limited draws' },
            { model: 'Samsung Galaxy S25', price: '₱55,000+', specs: 'Snapdragon 8 Gen 4, AI features', avail: 'Active draws' },
            { model: 'Samsung Galaxy A55', price: '₱22,000+', specs: 'AMOLED 120Hz, 5000mAh', avail: 'Active draws' },
            { model: 'Realme / Xiaomi Budget', price: '₱8,000–15,000', specs: '5G, 50MP, fast charge', avail: 'Frequent draws' },
          ].map(({ model, price, specs, avail }) => (
            <tr class="hover:bg-gray-50">
              <td class="px-4 py-3 font-medium text-gray-800">{model}</td>
              <td class="px-4 py-3 text-blue-600 font-semibold">{price}</td>
              <td class="px-4 py-3 text-gray-600">{specs}</td>
              <td class="px-4 py-3 text-gray-500">{avail}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="text-sm text-gray-500">Ang availability ng bawat model ay depende sa kasalukuyang marketing campaigns ng advertisers at sa iyong lokasyon.</p>
  </section>

  <!-- ── How Phone Giveaways Work ─────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-8">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Paano Gumagana ang Phone Giveaways?</h2>
    <div class="grid sm:grid-cols-3 gap-5 mb-5">
      {[
        { n: '1', icon: '📋', title: 'Mag-register', body: 'I-fill ang iyong basic info (name, email, at location) sa offer form.' },
        { n: '2', icon: '✅', title: 'Kumpletuhin ang Steps', body: 'Sundin ang simpleng mechanics — minsan survey, minsan quiz, minsan download ng app.' },
        { n: '3', icon: '📱', title: 'Hintayin ang Results', body: 'Makakatanggap ka ng notification via email o SMS kung ikaw ay napili bilang winner.' },
      ].map(({ n, icon, title, body }) => (
        <div class="bg-gray-50 border border-gray-100 rounded-2xl p-5 text-center">
          <div class="w-10 h-10 rounded-full bg-blue-600 text-white text-base font-bold flex items-center justify-center mx-auto mb-3">{n}</div>
          <div class="text-2xl mb-2">{icon}</div>
          <h3 class="font-bold text-gray-900 text-sm mb-1">{title}</h3>
          <p class="text-sm text-gray-500 leading-relaxed">{body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ── Offer Wall ─────────────────────────────────────────────────────────── -->
  <div class="max-w-3xl mx-auto px-4 mb-4">
    <div class="flex items-center gap-3 mb-1">
      <h2 class="text-lg font-bold text-gray-900">Active Phone Giveaways Near You</h2>
      <span class="relative flex h-2.5 w-2.5">
        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-emerald-400"></span>
      </span>
    </div>
    <p class="text-sm text-gray-500 mb-5">Available sa inyong lokasyon. Mag-claim bago mapuno ang slots.</p>
  </div>

  <div class="max-w-3xl mx-auto px-4">
    <CPAOffersWall
      client:visible
      initialOffers={initialOffers}
      s1="win-free-phone"
      s2="organic"
    />
  </div>

  <!-- ── Tips Section ───────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 py-10">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Tips para Mapataas ang Tsansa Mo na Manalo</h2>
    <div class="grid sm:grid-cols-2 gap-5">
      {[
        { icon: '⚡', title: 'Mag-enter Kaagad', body: 'Mas maaga kang pumasok, mas malaki ang tsansa. Maraming giveaway ang nagsasara ng entries nang maaga.' },
        { icon: '📝', title: 'Kumpletuhin Lahat ng Fields', body: 'Tiyaking kumpleto at tama ang lahat ng iyong impormasyon para mabisa ang iyong entry.' },
        { icon: '🔔', title: 'I-check ang Email', body: 'Ang winner notification ay ipinapadala sa email. Siguraduhing aktibo ang email na iyong ginamit.' },
        { icon: '📋', title: 'Basahin ang Mechanics', body: 'Maunawaan ang bawat hakbang ng mechanics para masiguradong valid ang iyong entry.' },
      ].map(({ icon, title, body }) => (
        <div class="flex gap-4 p-5 bg-gray-50 rounded-xl border border-gray-100">
          <span class="text-2xl flex-shrink-0">{icon}</span>
          <div>
            <h3 class="font-semibold text-gray-900 text-sm">{title}</h3>
            <p class="text-sm text-gray-500 mt-0.5 leading-relaxed">{body}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── FAQ ────────────────────────────────────────────────────────────────── -->
  <section class="max-w-3xl mx-auto px-4 pb-12">
    <h2 class="text-xl font-bold text-gray-900 mb-5">Mga Madalas na Tanong</h2>
    <div class="space-y-4">
      {[
        { q: 'Posible bang manalo ng libreng cellphone online sa Pilipinas?', a: 'Oo, posible. Maraming legitimate na companies ang nag-ooffer ng gadget giveaways bilang marketing strategy. Kailangan lang kumpletuhin ang mechanics.' },
        { q: 'Legit ba ang mga iPhone at Samsung giveaway online?', a: 'Hindi lahat, kaya mahalaga na sumali ka lang sa verified na networks. Ang mga offer dito ay galing sa trusted advertiser networks.' },
        { q: 'Paano malalaman kung nanalo ka na?', a: 'Makakatanggap ka ng confirmation sa email o contact number mo. Ang mga winner ay ina-announce sa loob ng ilang araw hanggang ilang linggo.' },
        { q: 'Kailangan ba ng bayad para sumali?', a: 'Hinding-hindi. Ang lahat ng legit na giveaway ay libre. Kung hinihiling ng contest na magbayad para manalo, iyon ay scam.' },
      ].map(({ q, a }) => (
        <details class="group border border-gray-200 rounded-xl overflow-hidden">
          <summary class="flex items-center justify-between gap-3 px-5 py-4 cursor-pointer font-semibold text-sm text-gray-900 hover:bg-gray-50 select-none">
            {q}
            <span class="text-gray-400 group-open:rotate-180 transition-transform text-lg leading-none">›</span>
          </summary>
          <div class="px-5 pb-4 text-sm text-gray-600 leading-relaxed border-t border-gray-100 pt-3">{a}</div>
        </details>
      ))}
    </div>
  </section>

  <EmailCapturePopup client:load source="win-free-phone" />

  <!-- ── Internal Links ─────────────────────────────────────────────────────── -->
  <section class="bg-gray-50 border-t border-gray-100 py-10 px-4">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-sm font-bold text-gray-700 mb-5 uppercase tracking-wide">Explore More</h2>
      <div class="flex flex-wrap gap-3">
        {[
          { href: '/earn-gcash',                  label: '💰 Earn GCash Online' },
          { href: '/online-contests-philippines', label: '🏆 Online Contests PH' },
          { href: '/free-gift-cards-philippines', label: '🎁 Free Gift Cards' },
          { href: '/earn',                        label: '💸 More Ways to Earn' },
          { href: '/products',                    label: '🛍️ Best Deals' },
        ].map(({ href, label }) => (
          <a href={href} class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-blue-300 hover:text-blue-700 transition-colors">
            {label}
          </a>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
