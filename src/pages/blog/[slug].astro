---
import MainLayout from '../../layouts/main.astro';
import PostContent from '../../components/PostContent';
import BlogCard from '../../components/BlogCard';
import AdUnit from '../../components/AdUnit.astro';
import RelatedOffers from '../../components/RelatedOffers.astro';
import { blogPosts, getRelatedPosts } from '../../lib/blog-data';
import { baseUrl } from '../../lib/base-url';

const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = getRelatedPosts(post.id, post.category, 3);

const cat = post.category?.toLowerCase() ?? '';
const offersCategory: 'gaming' | 'earning' | 'deals' | 'shopping' =
  cat.includes('gaming') || cat === 'mobile-gaming' ? 'gaming'
  : cat.includes('giveaway') || cat.includes('contest') ? 'earning'
  : cat.includes('deal') || cat.includes('budget') ? 'deals'
  : 'shopping';
const fullUrl = `https://smartly.sale/blog/${post.slug}`;

function jsonLd(obj: unknown): string {
  return JSON.stringify(obj)
    .replace(/</g, '\\u003c')
    .replace(/>/g, '\\u003e')
    .replace(/&/g, '\\u0026');
}

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.metaDescription,
  "image": post.featuredImage,
  "url": fullUrl,
  "datePublished": post.publishDate,
  "dateModified": new Date().toISOString().split('T')[0],
  "author": { "@type": "Person", "name": post.author, "url": "https://smartly.sale/about" },
  "publisher": {
    "@type": "Organization",
    "name": "smartly.sale",
    "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": fullUrl },
  "keywords": post.keywords.join(', ')
};

const categoryLabel = post.category ? post.category.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) : null;
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Blog",  "item": "https://smartly.sale/blog" },
    ...(categoryLabel ? [{ "@type": "ListItem", "position": 3, "name": categoryLabel, "item": `https://smartly.sale/blog?category=${post.category}` }] : []),
    { "@type": "ListItem", "position": categoryLabel ? 4 : 3, "name": post.title, "item": fullUrl }
  ]
};
---

<MainLayout
  title={post.metaTitle}
  description={post.metaDescription}
  ogImage={post.featuredImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={jsonLd(articleSchema)} />
    <script type="application/ld+json" set:html={jsonLd(breadcrumbSchema)} />
    <meta name="keywords" content={post.keywords.join(', ')} />
    <meta name="author" content={post.author} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.publishDate} />
    <meta property="article:author" content={post.author} />
    <meta property="article:section" content={post.category} />
    {post.tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <!-- Breadcrumb -->
  <div class="bg-muted/50 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href={baseUrl} class="hover:text-brand transition-colors">Home</a>
        <span class="text-border">/</span>
        <a href={`${baseUrl}/blog`} class="hover:text-brand transition-colors">Blog</a>
        {post.category && (
          <>
            <span class="text-border">/</span>
            <a href={`${baseUrl}/blog?category=${post.category}`} class="hover:text-brand transition-colors capitalize">{post.category.replace(/-/g, ' ')}</a>
          </>
        )}
        <span class="text-border">/</span>
        <span class="text-foreground font-medium truncate max-w-xs">{post.title}</span>
      </nav>
    </div>
  </div>

  <!-- Ad unit between breadcrumb and article -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
    <AdUnit format="auto" />
  </div>

  <!-- Post content — client:load so article HTML is server-rendered (SEO + LCP) -->
  <PostContent client:load post={post} />

  <!-- Ad unit after article, before related posts -->
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
    <AdUnit format="auto" />
  </div>

  <!-- Internal links to revenue pages -->
  <RelatedOffers category={offersCategory} />

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 bg-muted/30 border-t border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-8">You Might Also Like</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(relatedPost => (
            <BlogCard post={relatedPost} client:load />
          ))}
        </div>
      </div>
    </section>
  )}
</MainLayout>
