---
import MainLayout from '../../layouts/main.astro';
import PostContent from '../../components/PostContent';
import BlogCard from '../../components/BlogCard';
import { blogPosts, getRelatedPosts } from '../../lib/blog-data';
import { baseUrl } from '../../lib/base-url';

const { slug } = Astro.params;
const post = blogPosts.find(p => p.slug === slug);

if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = getRelatedPosts(post.id, 3);
const fullUrl = `https://smartly.sale/blog/${post.slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.metaDescription,
  "image": post.featuredImage,
  "url": fullUrl,
  "datePublished": post.publishDate,
  "dateModified": post.publishDate,
  "author": { "@type": "Organization", "name": post.author },
  "publisher": {
    "@type": "Organization",
    "name": "smartly.sale",
    "logo": { "@type": "ImageObject", "url": "https://smartly.sale/og-image.jpg" }
  },
  "mainEntityOfPage": { "@type": "WebPage", "@id": fullUrl },
  "keywords": post.keywords.join(', ')
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://smartly.sale" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://smartly.sale/blog" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": fullUrl }
  ]
};
---

<MainLayout
  title={post.metaTitle}
  description={post.metaDescription}
  ogImage={post.featuredImage}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <meta name="keywords" content={post.keywords.join(', ')} />
    <meta name="author" content={post.author} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={post.publishDate} />
    <meta property="article:author" content={post.author} />
    <meta property="article:section" content={post.category} />
    {post.tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <!-- Breadcrumb -->
  <div class="bg-muted/50 border-b border-border">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
      <nav class="flex items-center gap-2 text-sm text-muted-foreground">
        <a href={baseUrl} class="hover:text-brand transition-colors">Home</a>
        <span class="text-border">/</span>
        <a href={`${baseUrl}/blog`} class="hover:text-brand transition-colors">Blog</a>
        <span class="text-border">/</span>
        <span class="text-foreground font-medium truncate max-w-xs">{post.title}</span>
      </nav>
    </div>
  </div>

  <!-- Post content (same component as auto-generated posts) -->
  <PostContent client:only="react" post={post} />

  <!-- Related posts -->
  {relatedPosts.length > 0 && (
    <section class="py-16 bg-muted/30 border-t border-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl md:text-3xl font-bold text-foreground mb-8">You Might Also Like</h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {relatedPosts.map(relatedPost => (
            <BlogCard post={relatedPost} client:load />
          ))}
        </div>
      </div>
    </section>
  )}
</MainLayout>
