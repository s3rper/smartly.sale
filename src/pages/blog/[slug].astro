---
import MainLayout from '../../layouts/main.astro';
import { blogPosts, getRelatedPosts } from '../../lib/blog-data';
import { baseUrl } from '../../lib/base-url';
import BlogCard from '../../components/BlogCard';
import { Calendar, Clock, Tag, Share2, Facebook, Twitter, Link as LinkIcon } from 'lucide-react';

// Get the slug from params
const { slug } = Astro.params;

// Find the post by slug
const post = blogPosts.find(p => p.slug === slug);

// If post not found, return 404
if (!post) {
  return Astro.redirect('/404');
}

const relatedPosts = getRelatedPosts(post.id, 3);

const formattedDate = new Date(post.publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric'
});

const fullUrl = `https://smartly.sale/blog/${post.slug}`;
---

<MainLayout 
  title={post.metaTitle}
  description={post.metaDescription}
  ogImage={post.featuredImage}
>
  <!-- SEO Meta Tags -->
  <meta name="keywords" content={post.keywords.join(', ')} slot="head" />
  <meta name="author" content={post.author} slot="head" />
  <meta property="article:published_time" content={post.publishDate} slot="head" />
  <meta property="article:author" content={post.author} slot="head" />
  <meta property="article:section" content={post.category} slot="head" />
  {post.tags.map(tag => (
    <meta property="article:tag" content={tag} slot="head" />
  ))}

  <!-- Schema Markup for Article -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    "headline": post.title,
    "description": post.metaDescription,
    "image": post.featuredImage,
    "datePublished": post.publishDate,
    "dateModified": post.publishDate,
    "author": {
      "@type": "Organization",
      "name": post.author
    },
    "publisher": {
      "@type": "Organization",
      "name": "smartly.sale",
      "logo": {
        "@type": "ImageObject",
        "url": "https://smartly.sale/og-image.jpg"
      }
    },
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": fullUrl
    },
    "keywords": post.keywords.join(', ')
  })} />

  <!-- Breadcrumb Schema - Fixed for Google Search Console -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Home",
        "item": "https://smartly.sale"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Blog",
        "item": "https://smartly.sale/blog"
      },
      {
        "@type": "ListItem",
        "position": 3,
        "name": post.title
      }
    ]
  })} />

  <article class="bg-white">
    <!-- Breadcrumb Navigation -->
    <div class="bg-gray-50 py-4 mb-8">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <nav class="flex items-center gap-2 text-sm text-gray-600">
          <a href={baseUrl} class="hover:text-brand transition-colors">Home</a>
          <span>/</span>
          <a href={`${baseUrl}/blog`} class="hover:text-brand transition-colors">Blog</a>
          <span>/</span>
          <span class="text-gray-900 font-medium line-clamp-1">{post.title}</span>
        </nav>
      </div>
    </div>

    <!-- Article Header -->
    <header class="pb-8 md:pb-12">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Category Badge -->
        <div class="mb-6">
          <span class="inline-block bg-brand text-white px-4 py-2 rounded-full text-sm font-semibold uppercase tracking-wide">
            {post.category.replace('-', ' ')}
          </span>
        </div>

        <!-- Title -->
        <h1 class="text-3xl md:text-5xl font-bold text-gray-900 mb-8 leading-tight">
          {post.title}
        </h1>

        <!-- Meta Information -->
        <div class="flex flex-wrap items-center gap-6 text-gray-600 mb-6">
          <div class="flex items-center gap-2">
            <Calendar className="w-5 h-5" />
            <span>{formattedDate}</span>
          </div>
          <div class="flex items-center gap-2">
            <Clock className="w-5 h-5" />
            <span>{post.readTime} min read</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-sm">By {post.author}</span>
          </div>
        </div>

        <!-- Tags -->
        {post.tags.length > 0 && (
          <div class="flex items-center gap-3 flex-wrap">
            <Tag className="w-5 h-5 text-gray-400" />
            {post.tags.map(tag => (
              <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm hover:bg-gray-200 transition-colors">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- Featured Image -->
    <div class="mb-12 md:mb-16">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <img
          src={post.featuredImage}
          alt={post.featuredImageAlt}
          class="w-full h-auto rounded-2xl shadow-xl"
          loading="eager"
        />
      </div>
    </div>

    <!-- Article Content -->
    <div class="pb-12 md:pb-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="prose prose-lg max-w-none">
          <Fragment set:html={post.content} />
        </div>

        <!-- Call to Action -->
        <div class="mt-16 p-8 md:p-10 bg-gradient-to-r from-orange-50 to-orange-100 rounded-2xl border-2 border-brand shadow-lg">
          <h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">Ready to Shop?</h3>
          <p class="text-gray-700 text-lg mb-8">
            Check out these products and more on Shopee Philippines. Use our links to support our blog!
          </p>
          <a
            href={`${baseUrl}/products`}
            class="inline-flex items-center justify-center px-8 py-4 bg-brand text-white font-bold rounded-full hover:opacity-90 transition-all transform hover:scale-105 shadow-md"
          >
            Browse Products
          </a>
        </div>

        <!-- Share Buttons -->
        <div class="mt-12 pt-12 border-t border-gray-200">
          <h4 class="text-xl font-bold text-gray-900 mb-4">Share this article:</h4>
          <div class="flex flex-wrap gap-4">
            <a
              href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(fullUrl)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-6 py-3 bg-brand text-white rounded-full hover:opacity-90 transition-all transform hover:scale-105 shadow-md font-bold"
            >
              <Facebook className="w-5 h-5" />
              <span>Share on Facebook</span>
            </a>
            <a
              href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(fullUrl)}&text=${encodeURIComponent(post.title)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-center gap-2 px-6 py-3 bg-brand text-white rounded-full hover:opacity-90 transition-all transform hover:scale-105 shadow-md font-bold"
            >
              <Twitter className="w-5 h-5" />
              <span>Share on Twitter</span>
            </a>
            <button
              onclick={`navigator.clipboard.writeText('${fullUrl}'); alert('Link copied to clipboard!');`}
              class="flex items-center gap-2 px-6 py-3 bg-gray-100 text-gray-900 border-2 border-gray-300 rounded-full hover:bg-gray-200 transition-all transform hover:scale-105 shadow-md font-bold"
            >
              <LinkIcon className="w-5 h-5" />
              <span>Copy Link</span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="py-16 md:py-20 bg-gray-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">You Might Also Like</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {relatedPosts.map(relatedPost => (
              <BlogCard post={relatedPost} client:load />
            ))}
          </div>
        </div>
      </section>
    )}
  </article>
</MainLayout>

<style>
  /* Rich Text Styling */
  .prose {
    color: #374151;
    font-size: 1.125rem;
    line-height: 1.8;
  }

  .prose h2 {
    font-size: 2em;
    font-weight: 700;
    color: #111827;
    margin-top: 2.5em;
    margin-bottom: 1em;
    line-height: 1.3;
  }

  .prose h2:first-child {
    margin-top: 0;
  }

  .prose h3 {
    font-size: 1.5em;
    font-weight: 700;
    color: #1f2937;
    margin-top: 2em;
    margin-bottom: 0.875em;
    line-height: 1.4;
  }

  .prose h4 {
    font-size: 1.25em;
    font-weight: 600;
    color: #374151;
    margin-top: 1.75em;
    margin-bottom: 0.75em;
    line-height: 1.5;
  }

  .prose p {
    margin-bottom: 1.5em;
    line-height: 1.8;
  }

  .prose ul, .prose ol {
    margin-top: 1.5em;
    margin-bottom: 1.5em;
    padding-left: 1.75em;
  }

  .prose li {
    margin-bottom: 0.75em;
    line-height: 1.75;
  }

  .prose li::marker {
    color: var(--brand-orange);
  }

  .prose strong {
    font-weight: 600;
    color: #111827;
  }

  .prose a {
    color: var(--brand-orange);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .prose a:hover {
    color: var(--brand-orange-hover);
  }

  .line-clamp-1 {
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Mobile adjustments */
  @media (max-width: 768px) {
    .prose {
      font-size: 1rem;
    }

    .prose h2 {
      font-size: 1.75em;
      margin-top: 2em;
    }

    .prose h3 {
      font-size: 1.375em;
      margin-top: 1.75em;
    }

    .prose h4 {
      font-size: 1.125em;
      margin-top: 1.5em;
    }

    .prose p {
      margin-bottom: 1.25em;
    }

    .prose ul, .prose ol {
      margin-top: 1.25em;
      margin-bottom: 1.25em;
      padding-left: 1.5em;
    }

    .prose li {
      margin-bottom: 0.625em;
    }
  }

  @media (max-width: 640px) {
    .prose {
      font-size: 0.9375rem;
    }
  }
</style>
