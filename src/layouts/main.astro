---
import '../../generated/fonts.css';
import '../site-components/global.css';
import '../styles/global.css';
import Navbar from '../components/Navbar';
import Footer from '../components/Footer';

interface Props {
title?: string;
description?: string;
ogImage?: string;
pageClass?: string;
viewport?: string;
keywords?: string;
canonicalUrl?: string;
noindex?: boolean;
}

const {
title = 'smartly.sale - Best Shopee Deals & Viral Products Philippines 2025',
description = 'Discover trending Shopee products, viral finds, budget gadgets, and exclusive deals in the Philippines. Smart shopping made easy with curated reviews and affiliate links.',
ogImage = 'https://smartly.sale/og-image.jpg',
pageClass = '',
viewport = 'width=device-width, initial-scale=1.0',
keywords,
canonicalUrl,
noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? `https://smartly.sale${Astro.url.pathname}`;
---

<html lang="en-PH" class={pageClass}>
<head>
<meta charset="utf-8" />
<!-- dataLayer queue init — must be first so deferred GTM picks up early pushes -->
<script is:inline>window.dataLayer=window.dataLayer||[];</script>

<!-- Defer all analytics until page is interactive (reduces TBT/LCP on mobile) -->
<script is:inline>
(function(){
  function loadAnalytics(){
    if(window._analyticsLoaded)return;
    window._analyticsLoaded=true;

    /* Google Tag Manager — handles GA4 internally, no separate gtag script needed */
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PXRK86GQ');

    /* Facebook Pixel */
    if(!window._fbqLoaded){window._fbqLoaded=true;
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init','849998290917290');fbq('track','PageView');}

    /* ShareThis */
    var st=document.createElement('script');st.async=true;
    st.src='https://platform-api.sharethis.com/js/sharethis.js#property=691e9ef6247a56d61d0bb8a3&product=sop';
    document.head.appendChild(st);
  }

  if('requestIdleCallback' in window){
    requestIdleCallback(loadAnalytics,{timeout:4000});
  } else {
    window.addEventListener('load',function(){setTimeout(loadAnalytics,1500)});
  }
})();
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=849998290917290&ev=PageView&noscript=1"
/></noscript>

<!-- Google AdSense -->
<script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4578835227737176" crossorigin="anonymous"></script>

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<meta name="viewport" content={viewport} />
<meta name="generator" content={Astro.generator} />

<!-- SEO Meta Tags -->
<title>{title}</title>
{noindex && <meta name="robots" content="noindex, nofollow" />}
<meta name="description" content={description} />
<meta name="keywords" content={keywords ?? "Shopee Philippines, viral products, budget gadgets, trending deals, affiliate shopping, smartly.sale, Shopee finds, best Shopee products, Philippine online shopping, Shopee reviews"} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content="smartly.sale - Best Shopee Deals & Viral Products Philippines" />
<meta property="og:site_name" content="smartly.sale" />
<meta property="og:locale" content="en_PH" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={resolvedCanonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content="smartly.sale - Best Shopee Deals & Viral Products Philippines" />

<!-- Performance Optimization -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://buttons-config.sharethis.com" crossorigin />
<link rel="preconnect" href="https://platform-cdn.sharethis.com" crossorigin />
<link rel="dns-prefetch" href="https://l.sharethis.com" />
<link rel="dns-prefetch" href="https://count-server.sharethis.com" />
<link rel="dns-prefetch" href="https://shopee.ph" />
<!-- Non-blocking load for critical fonts (Inter + Poppins) — runs parallel to CSS bundle -->
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" as="style" crossorigin onload="this.onload=null;this.rel='stylesheet'" />
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Poppins:wght@300;400;500;600;700&display=swap" /></noscript>

<!-- Canonical URL -->
<link rel="canonical" href={resolvedCanonical} />

<!-- OneSignal Web Push — only initialises when app ID is configured -->
{import.meta.env.PUBLIC_ONESIGNAL_APP_ID && (
  <script is:inline define:vars={{ _osAppId: import.meta.env.PUBLIC_ONESIGNAL_APP_ID }}>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(function(OneSignal) {
      OneSignal.init({
        appId: _osAppId,
        notifyButton: { enable: false },
        promptOptions: {
          slidedown: {
            prompts: [{
              type: "push",
              autoPrompt: true,
              text: {
                actionMessage: "Get notified about new FREE prizes and giveaways available in your area!",
                acceptButton: "Yes, Alert Me!",
                cancelButton: "No thanks"
              },
              delay: { pageViews: 1, timeDelay: 8 }
            }]
          }
        }
      });
    });
    (function(){
      var s = document.createElement('script');
      s.src  = 'https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js';
      s.defer = true;
      document.head.appendChild(s);
    })();
  </script>
)}

<!-- Facebook CAPI — fire server-side ViewContent on each page view for better attribution -->
<script is:inline>
(function(){
  function fireCAPI(){
    try {
      var fbp = document.cookie.match(/_fbp=([^;]+)/);
      var fbc = document.cookie.match(/_fbc=([^;]+)/);
      var fbclid = new URLSearchParams(window.location.search).get('fbclid');
      fetch('/api/capi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        keepalive: true,
        body: JSON.stringify({
          eventName: 'ViewContent',
          eventId: 'pv-' + Date.now() + '-' + Math.random().toString(36).slice(2),
          url: window.location.href,
          userAgent: navigator.userAgent,
          fbp: fbp ? fbp[1] : undefined,
          fbc: fbc ? fbc[1] : undefined,
          fbclid: fbclid || undefined,
        }),
      }).catch(function(){});
    } catch(e){}
  }
  if(document.readyState === 'complete') {
    setTimeout(fireCAPI, 500);
  } else {
    window.addEventListener('load', function(){ setTimeout(fireCAPI, 500); });
  }
})();
</script>

<!-- Page-specific structured data / meta injected by individual pages -->
<slot name="head" />

<!-- Organization Structured Data -->
<script type="application/ld+json" is:inline>{JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "smartly.sale",
  "url": "https://smartly.sale",
  "logo": "https://smartly.sale/og-image.jpg",
  "description": "Discover trending Shopee products, viral finds, and budget gadgets in the Philippines.",
  "sameAs": [
    "https://www.facebook.com/smartlysale",
    "https://www.tiktok.com/@smartlysale"
  ]
})}</script>
</head>
<body class="min-h-screen flex flex-col">
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PXRK86GQ"
height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<!-- Scroll progress bar -->
<div id="scroll-progress-bar" aria-hidden="true"></div>
<script is:inline>
(function(){
  var bar = document.getElementById('scroll-progress-bar');
  if (!bar) return;
  window.addEventListener('scroll', function(){
    var st = document.documentElement.scrollTop || document.body.scrollTop;
    var sh = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    bar.style.width = (sh > 0 ? (st / sh) * 100 : 0) + '%';
  }, { passive: true });
})();
</script>

<Navbar client:only="react" />

<main class="flex-grow">
<slot />
</main>

<Footer client:only="react" />
</body>
</html>

<style is:global>
html {
scroll-behavior: smooth;
}

body {
overflow-x: hidden;
}

/* Hide ShareThis social sharing widget */
.st-sticky-share-buttons {
display: none !important;
}
</style>
