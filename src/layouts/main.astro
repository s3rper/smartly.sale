---
import '../site-components/global.css';
import '../styles/global.css';
import NavbarStatic from '../components/NavbarStatic.astro';
import Footer from '../components/Footer';
// import TelegramCTA from '../components/TelegramCTA.astro';

interface Props {
title?: string;
description?: string;
ogImage?: string;
ogType?: string;
pageClass?: string;
viewport?: string;
canonicalUrl?: string;
noindex?: boolean;
}

const {
title = 'smartly.sale - Best Shopee Deals & Viral Products Philippines 2026',
description = 'Discover trending Shopee products, viral finds, budget gadgets, and exclusive deals in the Philippines. Smart shopping made easy with curated reviews and affiliate links.',
ogImage = 'https://smartly.sale/og-image.jpg',
ogType = 'website',
pageClass = '',
viewport = 'width=device-width, initial-scale=1.0',
canonicalUrl,
noindex = false,
} = Astro.props;

const resolvedCanonical = canonicalUrl ?? `https://smartly.sale${Astro.url.pathname}`;
---

<html lang="en-PH" dir="ltr" class={pageClass}>
<head>
<meta charset="utf-8" />

<!-- Google tag (gtag.js) — DO NOT REMOVE: direct GA4 tag required for verification -->
<script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-BWPR8CV7BR"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-BWPR8CV7BR');
</script>

<!-- dataLayer queue init for deferred GTM -->

<!-- Defer other analytics until page is interactive (reduces TBT/LCP on mobile) -->
<script is:inline>
(function(){
  function loadAnalytics(){
    if(window._analyticsLoaded)return;
    window._analyticsLoaded=true;

    /* Google Tag Manager — handles GA4 internally, no separate gtag script needed */
    (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-PXRK86GQ');

    /* Facebook Pixel */
    if(!window._fbqLoaded){window._fbqLoaded=true;
    !function(f,b,e,v,n,t,s)
    {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
    n.callMethod.apply(n,arguments):n.queue.push(arguments)};
    if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
    n.queue=[];t=b.createElement(e);t.async=!0;
    t.src=v;s=b.getElementsByTagName(e)[0];
    s.parentNode.insertBefore(t,s)}(window,document,'script',
    'https://connect.facebook.net/en_US/fbevents.js');
    fbq('init','849998290917290');fbq('track','PageView');}

    /* ShareThis */
    var st=document.createElement('script');st.async=true;
    st.src='https://platform-api.sharethis.com/js/sharethis.js#property=691e9ef6247a56d61d0bb8a3&product=sop';
    document.head.appendChild(st);

    /* Google AdSense — deferred to reduce TBT/LCP impact */
    var as=document.createElement('script');as.async=true;as.crossOrigin='anonymous';
    as.src='https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-4578835227737176';
    document.head.appendChild(as);
  }

  if('requestIdleCallback' in window){
    requestIdleCallback(loadAnalytics,{timeout:4000});
  } else {
    window.addEventListener('load',function(){setTimeout(loadAnalytics,1500)});
  }
})();
</script>
<noscript><img height="1" width="1" style="display:none"
src="https://www.facebook.com/tr?id=849998290917290&ev=PageView&noscript=1"
/></noscript>

<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="manifest" href="/manifest.json" />
<link rel="apple-touch-icon" href="/og-image.jpg" />
<link rel="alternate" type="application/rss+xml" title="smartly.sale RSS Feed" href="/feed.xml" />
<meta name="viewport" content={viewport} />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#C24F00" />
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta http-equiv="X-Content-Type-Options" content="nosniff" />

<!-- SEO Meta Tags -->
<title>{title}</title>
{noindex ? <meta name="robots" content="noindex, nofollow" /> : <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />}
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={resolvedCanonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="smartly.sale" />
<meta property="og:locale" content="en_PH" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={resolvedCanonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
<meta name="twitter:image:alt" content={title} />

<!-- Additional SEO signals -->
<meta name="geo.region" content="PH" />
<meta name="geo.placename" content="Philippines" />
<meta name="ICBM" content="14.5995, 120.9842" />
<meta name="rating" content="general" />

<!-- Performance Optimization -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<!-- ShareThis — dns-prefetch only (deferred, not critical path) -->
<link rel="dns-prefetch" href="https://platform-api.sharethis.com" />
<!-- cf.shopee.ph is the actual product image CDN — preconnect (not just dns-prefetch) saves ~100-300ms -->
<link rel="preconnect" href="https://cf.shopee.ph" crossorigin />
<link rel="dns-prefetch" href="https://shopee.ph" />
<!-- Deferred analytics — pre-resolve DNS so they start faster after idle callback fires -->
<link rel="dns-prefetch" href="https://connect.facebook.net" />
<link rel="preconnect" href="https://pagead2.googlesyndication.com" crossorigin />
<link rel="dns-prefetch" href="https://www.googletagmanager.com" />
<!-- Preload the hero headline font (Inter 700) to speed up LCP text rendering -->
<link rel="preload" href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuFuYAZ9hiA.woff2" as="font" type="font/woff2" crossorigin />
<!-- Non-blocking load for Google Fonts CSS — subset to actually used weights -->
<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" as="style" crossorigin onload="this.onload=null;this.rel='stylesheet'" />
<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@500;600;700&display=swap" /></noscript>

<!-- Canonical URL -->
<link rel="canonical" href={resolvedCanonical} />

<!-- Hreflang — single-language site, self-referencing + x-default for AI/search engines -->
<link rel="alternate" hreflang="en-PH" href={resolvedCanonical} />
<link rel="alternate" hreflang="x-default" href={resolvedCanonical} />

<!-- OneSignal Web Push — only initialises when app ID is configured -->
{import.meta.env.PUBLIC_ONESIGNAL_APP_ID && (
  <script is:inline define:vars={{ _osAppId: import.meta.env.PUBLIC_ONESIGNAL_APP_ID }}>
    window.OneSignalDeferred = window.OneSignalDeferred || [];
    OneSignalDeferred.push(function(OneSignal) {
      OneSignal.init({
        appId: _osAppId,
        notifyButton: { enable: false },
        promptOptions: {
          slidedown: {
            prompts: [{
              type: "push",
              autoPrompt: true,
              text: {
                actionMessage: "Get notified about new FREE prizes and giveaways available in your area!",
                acceptButton: "Yes, Alert Me!",
                cancelButton: "No thanks"
              },
              delay: { pageViews: 1, timeDelay: 8 }
            }]
          }
        }
      });
    });
    (function(){
      var s = document.createElement('script');
      s.src  = 'https://cdn.onesignal.com/sdks/web/v16/OneSignalSDK.page.js';
      s.defer = true;
      document.head.appendChild(s);
    })();
  </script>
)}

<!-- Facebook CAPI — deferred until idle so it doesn't impact TBT/LCP -->
<script is:inline>
(function(){
  function fireCAPI(){
    try {
      var fbp = document.cookie.match(/_fbp=([^;]+)/);
      var fbc = document.cookie.match(/_fbc=([^;]+)/);
      var fbclid = new URLSearchParams(window.location.search).get('fbclid');
      fetch('/api/capi', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        keepalive: true,
        body: JSON.stringify({
          eventName: 'ViewContent',
          eventId: 'pv-' + Date.now() + '-' + Math.random().toString(36).slice(2),
          url: window.location.href,
          userAgent: navigator.userAgent,
          fbp: fbp ? fbp[1] : undefined,
          fbc: fbc ? fbc[1] : undefined,
          fbclid: fbclid || undefined,
        }),
      }).catch(function(){});
    } catch(e){}
  }
  if('requestIdleCallback' in window){
    requestIdleCallback(fireCAPI, { timeout: 5000 });
  } else {
    window.addEventListener('load', function(){ setTimeout(fireCAPI, 2000); });
  }
})();
</script>

<!-- Page-specific structured data / meta injected by individual pages -->
<slot name="head" />

<!-- Organization Structured Data -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "smartly.sale",
  "url": "https://smartly.sale",
  "logo": {
    "@type": "ImageObject",
    "url": "https://smartly.sale/og-image.jpg",
    "width": 1200,
    "height": 630
  },
  "description": "Discover trending Shopee products, viral finds, and budget gadgets in the Philippines.",
  "areaServed": { "@type": "Country", "name": "PH" },
  "knowsLanguage": ["en-PH", "fil"],
  "sameAs": [
    "https://www.facebook.com/smartlysale",
    "https://www.tiktok.com/@smartlysale"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer service",
    "availableLanguage": ["English", "Filipino"],
    "url": "https://smartly.sale/contact"
  }
})} />

<!-- Speakable — helps AI Overviews & voice assistants identify citable content -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": resolvedCanonical,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", "h2", "[data-speakable]", "meta[name='description']"]
  }
})} />

<!-- SiteNavigationElement — helps Google generate sitelinks -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "SiteNavigationElement",
  "name": ["Products", "Blog", "Earn GCash", "Categories", "Best Deals", "Tools"],
  "url": [
    "https://smartly.sale/products",
    "https://smartly.sale/blog",
    "https://smartly.sale/earn-gcash",
    "https://smartly.sale/categories",
    "https://smartly.sale/best-deals",
    "https://smartly.sale/tools"
  ]
})} />

</head>
<body class="min-h-screen flex flex-col">
<!-- Skip to main content — accessibility -->
<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[9999] focus:px-4 focus:py-2 focus:bg-brand focus:text-white focus:rounded-lg focus:text-sm focus:font-bold">Skip to main content</a>

<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-PXRK86GQ"
height="0" width="0" style="display:none;visibility:hidden" title="Google Tag Manager"></iframe></noscript>
<!-- End Google Tag Manager (noscript) -->

<!-- Scroll progress bar -->
<div id="scroll-progress-bar" aria-hidden="true"></div>
<script is:inline>
(function(){
  var bar = document.getElementById('scroll-progress-bar');
  if (!bar) return;
  window.addEventListener('scroll', function(){
    var st = document.documentElement.scrollTop || document.body.scrollTop;
    var sh = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    bar.style.width = (sh > 0 ? (st / sh) * 100 : 0) + '%';
  }, { passive: true });
})();
</script>

<NavbarStatic />

<main id="main-content" class="flex-grow">
<slot />
</main>

<Footer client:idle />
</body>
</html>

<style is:global>
html {
scroll-behavior: smooth;
}

body {
overflow-x: hidden;
}

/* Hide ShareThis social sharing widget */
.st-sticky-share-buttons {
display: none !important;
}
</style>
