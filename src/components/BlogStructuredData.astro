---
interface Props {
  title: string;
  description: string;
  publishDate: string;
  modifiedDate?: string;
  author?: string;
  category?: string;
  image?: string;
  slug?: string;
}

const {
  title,
  description,
  publishDate,
  modifiedDate = publishDate,
  author = "smartly.sale Team",
  category = "Gaming Guides",
  image = "https://smartly.sale/og-image.jpg",
  slug = ""
} = Astro.props;

const siteUrl = "https://smartly.sale";
const articleUrl = slug ? `${siteUrl}/blog/${slug}` : `${siteUrl}${Astro.url.pathname}`;

// Article Schema
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "image": image,
  "author": {
    "@type": "Organization",
    "name": author,
    "url": siteUrl
  },
  "publisher": {
    "@type": "Organization",
    "name": "smartly.sale",
    "logo": {
      "@type": "ImageObject",
      "url": `${siteUrl}/og-image.jpg`
    }
  },
  "datePublished": publishDate,
  "dateModified": modifiedDate,
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": articleUrl
  }
};

// BreadcrumbList Schema - Google requires "item" field for all positions EXCEPT the last one
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Blog",
      "item": `${siteUrl}/blog`
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": title
      // Note: Last item should NOT have "item" field per Google guidelines
    }
  ]
};
---

<!-- Structured Data for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
