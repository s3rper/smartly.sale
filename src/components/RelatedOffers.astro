---
/**
 * RelatedOffers.astro
 * Pill-link row at the bottom of blog posts linking readers to revenue pages.
 * Uses descriptive, keyword-rich anchor text per SEO internal linking best practices.
 * Pass category="gaming" | "shopping" | "earning" | "deals" to get the right set of links.
 */
interface Props {
  category?: 'gaming' | 'shopping' | 'earning' | 'deals';
  heading?: string;
}

const { category = 'shopping', heading = 'More Free Rewards & Deals' } = Astro.props;

const links: Record<string, { href: string; label: string }[]> = {
  gaming: [
    { href: '/free-robux',           label: 'Get Free Robux Philippines'         },
    { href: '/free-mlbb-diamonds',   label: 'Free MLBB Diamonds Guide'           },
    { href: '/free-gaming-credits',  label: 'Free Gaming Credits Philippines'    },
    { href: '/free-fire-codes',      label: 'Free Fire Redeem Codes 2026'        },
    { href: '/free-imvu-credits',    label: 'Free IMVU Credits Claim'            },
    { href: '/earn-gcash',           label: 'Earn Free GCash Online'             },
  ],
  shopping: [
    { href: '/products',             label: 'Best Deals on Shopee Philippines'   },
    { href: '/earn-gcash',           label: 'Earn Free GCash — Legit Methods'    },
    { href: '/earn',                 label: 'Ways to Earn Money Online PH'       },
    { href: '/free-gift-cards-philippines', label: 'Free Gift Cards Philippines' },
    { href: '/win-free-phone',       label: 'Win a Free Phone Philippines'       },
    { href: '/shopee-sales-2026',    label: 'Upcoming Shopee Sales 2026'         },
  ],
  earning: [
    { href: '/earn-gcash',           label: 'Earn Free GCash Online Philippines' },
    { href: '/online-contests-philippines', label: 'Online Contests Philippines 2026' },
    { href: '/win-free-phone',       label: 'Win a Free Phone Philippines'       },
    { href: '/free-gaming-credits',  label: 'Free Gaming Credits Philippines'    },
    { href: '/free-gift-cards-philippines', label: 'Free Gift Cards Philippines' },
    { href: '/earn',                 label: 'Legit Ways to Earn Online PH'       },
  ],
  deals: [
    { href: '/best-deals',           label: 'Best Deals Philippines Today'       },
    { href: '/daily',                label: 'Daily Deals — Shopee Philippines'   },
    { href: '/shopee-sales-2026',    label: 'Upcoming Shopee Sales 2026'         },
    { href: '/products',             label: 'Trending Products on Shopee PH'     },
    { href: '/earn-gcash',           label: 'Earn Free GCash While Shopping'     },
    { href: '/free-gift-cards-philippines', label: 'Free Gift Cards Philippines' },
  ],
};

const items = links[category] ?? links['shopping'];
---

<section class="bg-gray-50 border-t border-gray-100 py-8 px-4 mt-8">
  <div class="max-w-3xl mx-auto">
    <h2 class="text-sm font-bold text-gray-700 mb-4 uppercase tracking-wide">{heading}</h2>
    <div class="flex flex-wrap gap-3">
      {items.map(({ href, label }) => (
        <a
          href={href}
          class="inline-flex items-center px-4 py-2 bg-white border border-gray-200 rounded-full text-sm text-gray-700 hover:border-orange-300 hover:text-orange-700 transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>
</section>
