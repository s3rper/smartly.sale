---
/**
 * TelegramCTA.astro
 *
 * Floating/inline CTA banner encouraging users to join the Telegram channel
 * for real-time Shopee deal alerts. Can be placed in layout footer area,
 * blog posts, or deal pages.
 *
 * Props:
 *  - variant: 'inline' (default) | 'floating' | 'compact'
 *  - channel: Telegram channel handle (default: smartlysale)
 */
interface Props {
  variant?: 'inline' | 'floating' | 'compact';
  channel?: string;
}

const { variant = 'inline', channel = 'smartlysale' } = Astro.props;
const telegramUrl = `https://t.me/${channel}`;
---

{variant === 'floating' && (
  <div class="fixed bottom-4 right-4 z-50 animate-slide-up" id="telegram-cta-floating">
    <a
      href={telegramUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="flex items-center gap-3 bg-[#229ED9] text-white px-5 py-3 rounded-2xl shadow-lg hover:bg-[#1a8bc2] transition-all hover:scale-105 group"
    >
      <svg class="w-6 h-6 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      <div>
        <p class="font-bold text-sm leading-tight">Get Daily Shopee Deals</p>
        <p class="text-xs opacity-90">Join our Telegram channel</p>
      </div>
      <button
        class="ml-2 text-white/60 hover:text-white text-lg leading-none"
        onclick="this.closest('#telegram-cta-floating').remove(); localStorage.setItem('tg-cta-dismissed','1'); event.preventDefault(); event.stopPropagation();"
        aria-label="Dismiss"
      >&times;</button>
    </a>
  </div>
  <script is:inline>
    if (localStorage.getItem('tg-cta-dismissed') === '1') {
      var el = document.getElementById('telegram-cta-floating');
      if (el) el.remove();
    }
  </script>
)}

{variant === 'inline' && (
  <section class="py-8 bg-gradient-to-r from-[#229ED9]/10 to-[#229ED9]/5 border-y border-[#229ED9]/20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row items-center gap-5">
        <div class="flex items-center gap-4 flex-1">
          <div class="w-14 h-14 bg-[#229ED9] rounded-2xl flex items-center justify-center shrink-0">
            <svg class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </div>
          <div>
            <h3 class="font-bold text-foreground text-lg">Never Miss a Deal</h3>
            <p class="text-sm text-muted-foreground">Join our Telegram channel for real-time Shopee deal alerts, flash sale notifications, and exclusive promo codes.</p>
          </div>
        </div>
        <a
          href={telegramUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 bg-[#229ED9] text-white px-6 py-3 rounded-xl font-semibold hover:bg-[#1a8bc2] transition-colors whitespace-nowrap text-sm"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          Join Telegram Channel
        </a>
      </div>
    </div>
  </section>
)}

{variant === 'compact' && (
  <a
    href={telegramUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="flex items-center gap-2 bg-[#229ED9]/10 border border-[#229ED9]/20 text-[#229ED9] px-4 py-2.5 rounded-xl hover:bg-[#229ED9]/20 transition-colors text-sm font-medium"
  >
    <svg class="w-4 h-4 shrink-0" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
    Get deal alerts on Telegram
  </a>
)}

<style>
  @keyframes slide-up {
    from { transform: translateY(100px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
  .animate-slide-up {
    animation: slide-up 0.5s ease-out;
  }
</style>
